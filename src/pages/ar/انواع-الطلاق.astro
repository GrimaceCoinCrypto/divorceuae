---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'أنواع الطلاق في الإسلام والإمارات — الطلاق الرجعي والبائن والبدعي والخلع';
const description =
  'دليل شامل لأنواع الطلاق في الإسلام والقانون الإماراتي: الطلاق الرجعي، البائن، البدعي، الطلاق الثلاث، الخلع، والتفريق القضائي — مع أحكام كل نوع وآثاره القانونية.';

const hreflang = {
  en: 'https://divorceu.ae/en/uae-divorce-law',
  ar: 'https://divorceu.ae/ar/انواع-الطلاق',
};

const breadcrumbs = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'أنواع الطلاق', url: 'https://divorceu.ae/ar/انواع-الطلاق' },
];

const divorceTypes = [
  {
    name: 'الطلاق الرجعي',
    nameEn: 'Revocable Divorce',
    desc: 'هو الطلاق الذي يملك فيه الزوج حق الرجعة دون عقد جديد خلال فترة العدة (3 حيضات أو 3 أشهر قمرية).',
    details: [
      'يقع بلفظة واحدة أو لفظتين من ألفاظ الطلاق',
      'للزوج حق المراجعة ما دامت الزوجة في العدة دون الحاجة إلى موافقتها',
      'إذا انقضت العدة دون رجعة أصبح الطلاق بائناً بينونة صغرى',
      'يُعدّ الطلاق الأول والثاني رجعياً',
    ],
    ruling: 'جائز',
  },
  {
    name: 'الطلاق البائن بينونة صغرى',
    nameEn: 'Minor Irrevocable Divorce',
    desc: 'طلاق انقضت عدته دون رجعة، أو وقع بعوض (الخلع)، أو قبل الدخول بالزوجة.',
    details: [
      'لا تجوز الرجعة بعد انقضاء العدة إلا بعقد ومهر جديدين',
      'يجوز للزوجين الزواج من بعضهما مجدداً',
      'يشمل الطلقة الأولى والثانية بعد انتهاء العدة',
      'يشمل طلاق ما قبل الدخول',
    ],
    ruling: 'جائز',
  },
  {
    name: 'الطلاق البائن بينونة كبرى',
    nameEn: 'Major Irrevocable Divorce',
    desc: 'هو الطلاق الثالث، أو مجموع ثلاث طلقات. تحرم الزوجة على زوجها تحريماً مؤقتاً حتى تتزوج زوجاً آخر زواجاً حقيقياً.',
    details: [
      'لا يحل للزوج مراجعة مطلقته إلا بعد زواجها من رجل آخر زواجاً صحيحاً ودخل بها ثم طلقها',
      'زواج المحلل (التحليل) حرام وباطل في الإسلام والقانون الإماراتي',
      'القانون الإماراتي يحظر صراحةً الزواج بنية الطلاق',
    ],
    ruling: 'تقع ولا رجعة إلا بعد زواج صحيح',
  },
  {
    name: 'الطلاق البدعي',
    nameEn: "Bid'i Divorce (Forbidden Innovation)",
    desc: 'هو الطلاق الذي يخالف سنة النبي ﷺ في كيفيته أو وقته. وأبرز أنواعه: الطلاق في الحيض، والطلاق الثلاث بلفظ واحد.',
    details: [
      'الطلاق أثناء الحيض أو النفاس: محرم وبدعة — والراجح عند جمهور العلماء وقوعه مع الإثم',
      'الطلاق الثلاث بلفظ واحد ("أنت طالق ثلاثاً"): بدعة محرمة — وفيه خلاف قوي بين الفقهاء: الجمهور يعدّه ثلاثاً، وابن تيمية وغيره يعدّه طلقة واحدة',
      'القانون الإماراتي (المادة 99 من قانون الأحوال الشخصية) يعدّ الطلاق الثلاث بلفظ واحد طلقة رجعية واحدة',
    ],
    ruling: 'محرم ومنهي عنه — يقع مع الإثم',
  },
  {
    name: 'الخلع',
    nameEn: "Khul'a (Wife-Initiated Divorce)",
    desc: 'هو طلاق تطلبه الزوجة مقابل ردّ المهر أو تقديم عوض مالي للزوج للإفراج عنها.',
    details: [
      'حق شرعي وقانوني مكفول للزوجة في الإمارات',
      'تردّ الزوجة المهر المقبوض للزوج كأصل عام',
      'إذا رفض الزوج تُرفع الدعوى للقضاء ويحكم القاضي بالخلع',
      'يُعدّ الخلع بائناً بينونة صغرى ولا رجعة فيه',
      'لا تجب العدة على المختلعة عند بعض الفقهاء إلا استبراء الرحم (حيضة واحدة)',
    ],
    ruling: 'جائز — حق الزوجة',
  },
  {
    name: 'التفريق القضائي (الفسخ)',
    nameEn: 'Judicial Separation (Faskh)',
    desc: 'هو فسخ عقد الزواج بحكم قضائي بناءً على طلب أحد الزوجين لأسباب مشروعة.',
    details: [
      'يحق للزوجة طلبه لأسباب محددة: الضرر والأذى، الهجر (4 أشهر فأكثر)، عدم النفقة، الغيبة الطويلة، المرض المعدي',
      'يحق للزوج طلبه في حالات العيب الخفي أو الغش في الزواج',
      'المحكمة تحكم بالفسخ بعد التثبت من سبب الدعوى',
      'الفسخ يُعدّ بائناً بينونة صغرى',
    ],
    ruling: 'مشروع عند توفر الأسباب',
  },
];

const faqItems = [
  {
    question: 'ما حكم الطلاق وقت الغضب؟',
    answer:
      'اختلف العلماء في الطلاق حال الغضب الشديد (الإغلاق): إذا كان الغضب قد بلغ حداً أفقد الزوج الإدراك والتمييز التام فلا يقع الطلاق عند كثير من العلماء كابن تيمية وابن القيم. أما إذا كان الزوج يعلم ما يقول وكان غضباً عادياً فيقع الطلاق عند الجمهور. والاحتياط الأسلم: استشارة عالم أو محكمة شرعية للبت في الحالة بعينها. القانون الإماراتي يأخذ بالتفريق ويُعمل بالطلاق في الغضب المعتاد.',
  },
  {
    question: 'هل الطلاق الثلاث بلفظ واحد يقع ثلاثاً؟',
    answer:
      'فيه خلاف فقهي شهير: الجمهور (المذاهب الأربعة تاريخياً) يقولون يقع ثلاثاً. وابن تيمية وابن القيم ومعهم جماعة من المحققين يقولون يقع واحدة رجعية استناداً إلى حديث ابن عباس في صحيح مسلم وأن النبي ﷺ كان يجعل الثلاث بكلمة واحدة واحدةً في زمنه. القانون الإماراتي نصّ في المادة 99 من قانون الأحوال الشخصية على اعتباره طلقة رجعية واحدة، وهو الأيسر على الناس.',
  },
  {
    question: 'ما حكم الزواج بنية الطلاق؟',
    answer:
      'الزواج بنية الطلاق حرام شرعاً ومنهي عنه؛ لأنه ضرب من التحيل وفيه خداع للمرأة وأهلها. وقد صرّح الفقهاء بأنه يشبه نكاح المتعة المحرم. أما من ناحية الصحة الشرعية: فالعقد يقع صحيحاً إذا استوفى أركانه وإن أثم صاحبه، خلافاً لمن قال ببطلانه. القانون الإماراتي يحظر الزواج بشرط التوقيت ويُبطل أي شرط يتناقض مع مقاصد الزواج.',
  },
  {
    question: 'ما هو الطلاق البدعي وهل يقع؟',
    answer:
      'الطلاق البدعي هو ما خالف السنة في وقته (كالطلاق في الحيض) أو في عدده (كالطلاق الثلاث بكلمة). وهو محرم ومنهي عنه لكنه يقع عند جمهور العلماء مع الإثم. والراجح عند المحققين كابن تيمية أن الطلاق في الحيض يقع ويُؤمر الزوج بالرجعة كما فعل النبي ﷺ مع ابن عمر.',
  },
  {
    question: 'ما كفارة اليمين بالطلاق؟',
    answer:
      'من حلف بالطلاق بصيغة اليمين (مثل: "إن فعلت كذا فأنت طالق") فقد اختلف العلماء: الجمهور يقولون يقع الطلاق عند حنث الشرط. وابن تيمية وابن القيم يقولون هذا يمين وفيه كفارة يمين (إطعام عشرة مساكين أو كسوتهم أو تحرير رقبة، فمن لم يجد فصيام ثلاثة أيام)، ولا يقع الطلاق. وقد صدر بهذا فتاوى من مجامع فقهية كبرى. يُنصح باستشارة عالم متخصص أو القضاء للنظر في الحالة بعينها.',
  },
  {
    question: 'ما الفرق بين الطلاق والخلع والفسخ في القانون الإماراتي؟',
    answer:
      'الطلاق: حق الزوج بإرادته المنفردة. الخلع: حق الزوجة مقابل ردّ المهر، ويُرفع للقضاء إن رفض الزوج. الفسخ: حكم قضائي يصدر لأسباب محددة كالضرر أو الهجر أو عدم النفقة. القانون الإماراتي ينظّم الثلاثة في قانون الأحوال الشخصية الاتحادي رقم 28 لسنة 2005 وتعديلاته.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
>
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <Breadcrumb items={breadcrumbs} lang="ar" />
        <h1 class="hero__h1">أنواع الطلاق في الإسلام والإمارات</h1>
        <p class="hero__sub">
          دليل شامل لأنواع الطلاق الفقهية والقانونية: من الطلاق الرجعي إلى البائن والبدعي والخلع والتفريق القضائي — مع أحكام كل نوع وآثاره في القانون الإماراتي.
        </p>
        <ul class="hero__trust">
          <li>✓ أنواع الطلاق الفقهية والقانونية</li>
          <li>✓ أحكام الطلاق في الغضب والحيض</li>
          <li>✓ موقف القانون الإماراتي</li>
          <li>✓ استشارة قانونية مجانية</li>
        </ul>
      </div>
      <div class="hero__form">
        <LeadForm lang="ar" variant="hero" heading="استشارة طلاق مجانية" />
      </div>
    </div>
  </header>

  <main class="container main-content">

    <!-- Intro -->
    <section class="section" aria-labelledby="intro-heading">
      <h2 id="intro-heading">نظرة عامة على أنواع الطلاق</h2>
      <p>
        الطلاق في الإسلام ليس نوعاً واحداً — بل أنواع متعددة تختلف في الأحكام والآثار والحقوق المترتبة عليها. وقد تبنّى قانون الأحوال الشخصية الإماراتي الاتحادي رقم 28 لسنة 2005 مبادئ الفقه الإسلامي مع بعض التعديلات التي تحقق المصلحة العامة.
      </p>
      <p>
        معرفة نوع الطلاق مهمة جداً لأنها تحدد: هل يحق للزوج الرجعة؟ هل تحتاج المرأة لعدة جديدة؟ هل يجوز لهما الزواج من بعضهما مجدداً؟ وما هي حقوق كل طرف؟
      </p>
    </section>

    <!-- Types of divorce -->
    <section class="section" aria-labelledby="types-heading">
      <h2 id="types-heading">أنواع الطلاق تفصيلاً</h2>

      <div class="types-list">
        {divorceTypes.map((type, i) => (
          <div class="type-card">
            <div class="type-header">
              <div class="type-num">{i + 1}</div>
              <div class="type-titles">
                <h3 class="type-name">{type.name}</h3>
                <span class="type-name-en">{type.nameEn}</span>
              </div>
              <span class="type-ruling">{type.ruling}</span>
            </div>
            <p class="type-desc">{type.desc}</p>
            <ul class="type-details">
              {type.details.map(d => (
                <li>{d}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Quick reference table -->
    <section class="section" aria-labelledby="table-heading">
      <h2 id="table-heading">جدول مقارنة أنواع الطلاق</h2>
      <div class="cost-table">
        <table>
          <thead>
            <tr>
              <th>النوع</th>
              <th>من يُوقعه</th>
              <th>هل تجوز الرجعة؟</th>
              <th>هل يحتاج عقداً جديداً؟</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>الطلاق الرجعي (1 أو 2)</td><td>الزوج</td><td>نعم — خلال العدة</td><td>لا</td></tr>
            <tr><td>البائن صغرى (بعد انقضاء العدة)</td><td>الزوج</td><td>لا — إلا بعقد جديد</td><td>نعم</td></tr>
            <tr><td>البائن كبرى (الطلقة الثالثة)</td><td>الزوج</td><td>لا — حتى تتزوج غيره</td><td>نعم (بعد زواج آخر)</td></tr>
            <tr><td>الخلع</td><td>الزوجة / القضاء</td><td>لا</td><td>نعم</td></tr>
            <tr><td>التفريق القضائي</td><td>القضاء</td><td>لا</td><td>نعم</td></tr>
            <tr><td>الطلاق البدعي</td><td>الزوج (منهي عنه)</td><td>يُعامل بحسب نوعه</td><td>يُعامل بحسب نوعه</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Divorce in anger section -->
    <section class="section" aria-labelledby="anger-heading">
      <h2 id="anger-heading">مسائل شائعة حول الطلاق</h2>

      <div class="qa-list">
        <div class="qa-card">
          <h3>الطلاق في الحيض</h3>
          <p>محرم شرعاً ويُسمى الطلاق البدعي. إذا وقع، أُمر الزوج بمراجعة زوجته فوراً ثم إن شاء طلّق في طهر لم يجامعها فيه. القانون الإماراتي يُوقع الطلاق في الحيض مع توجيه الزوج للمراجعة.</p>
        </div>
        <div class="qa-card">
          <h3>الطلاق الثلاث بكلمة واحدة في الإمارات</h3>
          <p>نصّت المادة (99) من قانون الأحوال الشخصية الإماراتي: "الطلاق المقترن بعدد لفظاً أو إشارةً لا يقع إلا واحدة." أي أن من قال "أنت طالق ثلاثاً" يُعدّ في القانون الإماراتي طلاقاً رجعياً واحداً — وهذا موافق لرأي ابن تيمية وابن القيم.</p>
        </div>
        <div class="qa-card">
          <h3>الطلاق المعلّق والطلاق بالشرط</h3>
          <p>مثاله: "إن سافرتِ بدون إذني فأنتِ طالق." وفيه خلاف فقهي: الجمهور يُوقعونه عند تحقق الشرط، وابن تيمية يجعله يميناً فيه كفارة. القانون الإماراتي (المادة 101) يُعامل الطلاق المعلّق على شرط بوقوعه عند تحقق الشرط.</p>
        </div>
      </div>
    </section>

    <!-- Related links -->
    <section class="section" aria-labelledby="related-heading">
      <h2 id="related-heading">أدلة ذات صلة</h2>
      <div class="service-links">
        <a href="/ar/قانون-الطلاق-في-الامارات" class="service-link">
          <strong>قانون الطلاق في الإمارات</strong>
          <span>شرح قانون الأحوال الشخصية الاتحادي</span>
        </a>
        <a href="/ar/الطلاق-في-الامارات" class="service-link">
          <strong>الطلاق في الإمارات — دليل شامل</strong>
          <span>الإجراءات والتكاليف والجداول الزمنية</span>
        </a>
        <a href="/ar/حقوق-الزوجة-بعد-الطلاق-الامارات" class="service-link">
          <strong>حقوق الزوجة بعد الطلاق</strong>
          <span>النفقة والمهر والمسكن والحضانة</span>
        </a>
        <a href="/ar/طلاق-للضرر" class="service-link">
          <strong>الطلاق للضرر</strong>
          <span>التفريق القضائي وأسبابه وإجراءاته</span>
        </a>
        <a href="/ar/حضانة-الاطفال-الامارات" class="service-link">
          <strong>حضانة الأطفال في الإمارات</strong>
          <span>قواعد الحضانة وأعمار الأطفال وحقوق الرؤية</span>
        </a>
        <a href="/ar/محامي-طلاق" class="service-link">
          <strong>محامي طلاق في الإمارات</strong>
          <span>ابحث عن محامٍ متخصص</span>
        </a>
      </div>
    </section>

    <FAQSection items={faqItems} lang="ar" />

    <section class="section section--cta" aria-labelledby="bottom-cta-heading" id="contact">
      <h2 id="bottom-cta-heading">هل تحتاج إلى استشارة في مسألة طلاق؟</h2>
      <p>تحدث مع محامي أحوال شخصية مؤهل خلال 24 ساعة. سري تماماً. دعم باللغتين العربية والإنجليزية.</p>
      <LeadForm lang="ar" variant="inline" />
    </section>

  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceU.AE — خدمة إحالة قانونية. ليست مكتب محاماة. المعلومات المقدمة للإرشاد فقط ولا تشكل استشارة قانونية.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/سياسة-الخصوصية">سياسة الخصوصية</a>
        <a href="/ar/إخلاء-المسؤولية">إخلاء المسؤولية</a>
        <a href="/en/">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 80px 0 60px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; line-height: 1.3; margin-bottom: 16px; }
  .hero__sub { font-size: 1.05rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.8; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.9rem; }
  .hero__trust li { opacity: 0.9; }

  .section { padding: 60px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #1e3a5f; margin-bottom: 20px; }
  .section h3 { font-size: 1.1rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 1.9; margin-bottom: 16px; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 60px 40px; margin-bottom: 60px; text-align: center; }

  /* Types list */
  .types-list { display: flex; flex-direction: column; gap: 20px; margin-top: 24px; }
  .type-card { background: #f8faff; border: 1px solid #dde6f5; border-radius: 12px; padding: 24px; }
  .type-header { display: flex; align-items: flex-start; gap: 16px; margin-bottom: 12px; flex-wrap: wrap; }
