---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'إجراءات الطلاق في الإمارات — دليل خطوة بخطوة 2025';
const description =
  'دليل شامل لإجراءات الطلاق في الإمارات: المستندات المطلوبة، تقديم الدعوى في محكمة الأحوال الشخصية، جلسة المصالحة، التكاليف، والجداول الزمنية لكل نوع من أنواع الطلاق.';

const canonical = 'https://divorceu.ae/ar/كيفية-تقديم-الطلاق-في-الامارات';

const hreflang = {
  en: 'https://divorceu.ae/en/how-to-file-for-divorce-in-dubai',
  ar: 'https://divorceu.ae/ar/كيفية-تقديم-الطلاق-في-الامارات',
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'إجراءات الطلاق في الإمارات' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ما المستندات المطلوبة لتقديم دعوى الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'المستندات الأساسية: عقد الزواج الأصلي (مصدَّق ومترجماً للعربية إن صدر بالخارج)، جوازات سفر الزوجين وصورهما، بطاقتا هوية إماراتية، إثبات الإقامة في الإمارة المختصة، وشهادات ميلاد الأطفال إن وُجدوا.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم تكلفة الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'رسوم تسجيل الدعوى في المحكمة: 600–2,000 درهم. أتعاب المحامي للطلاق بالتراضي: 5,000–15,000 درهم. الطلاق المتنازع عليه: 20,000–80,000 درهم أو أكثر. ترجمة المستندات وتصديقها: 500–2,000 درهم.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم يستغرق الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'وفق إجراءات محاكم الأحوال الشخصية في الإمارات، يستغرق الطلاق بالتراضي 1–3 أشهر. الخلع يستغرق 1–3 أشهر. الطلاق المتنازع عليه يستغرق 6–24 شهراً.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل يمكنني تقديم طلب الطلاق إلكترونياً في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'نعم جزئياً. تُتيح محاكم دبي وأبوظبي تسجيل القضايا إلكترونياً عبر تطبيقاتهما الرسمية. لكن الحضور الشخصي لا يزال مطلوباً لجلسات المصالحة والاستماع.',
      },
    },
  ],
};

const faqItems = [
  {
    question: 'ما المستندات المطلوبة لتقديم دعوى الطلاق في الإمارات؟',
    answer: 'عقد الزواج الأصلي (مصدَّق ومترجم للعربية)، جوازا السفر، بطاقتا الهوية الإماراتية، إثبات الإقامة، وشهادات ميلاد الأطفال إن وُجدوا.',
  },
  {
    question: 'كم تكلفة الطلاق في الإمارات؟',
    answer: 'رسوم المحكمة: <strong>600–2,000 درهم</strong>. أتعاب المحامي: 5,000–15,000 درهم (بالتراضي) إلى 20,000–80,000+ درهم (متنازع عليه). ترجمة وتصديق: 500–2,000 درهم.',
  },
  {
    question: 'كم يستغرق الطلاق في الإمارات؟',
    answer: 'وفق إجراءات محاكم الأحوال الشخصية: <strong>الطلاق بالتراضي 1–3 أشهر</strong>، الخلع 1–3 أشهر، الطلاق المتنازع عليه 6–24 شهراً.',
  },
  {
    question: 'هل يمكنني تقديم طلب الطلاق إلكترونياً؟',
    answer: 'نعم جزئياً — يمكن تسجيل القضايا إلكترونياً عبر تطبيقي محاكم دبي وأبوظبي. لكن الحضور الشخصي لا يزال مطلوباً لجلسات المصالحة والاستماع.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
  schema={faqSchema}
>
  <main>
    <header class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <Breadcrumb items={breadcrumbItems} lang="ar" />
          <h1 class="hero__h1">
            إجراءات الطلاق في الإمارات —<br />
            دليل خطوة بخطوة 2025
          </h1>
          <p class="hero__sub">
            تقديم دعوى الطلاق في الإمارات يستلزم التقدم إلى محكمة الأحوال الشخصية
            وإجراء جلسة مصالحة إلزامية وحضور جلسات الاستماع. يشرح هذا الدليل
            كل خطوة للمسلمين وغير المسلمين — المستندات المطلوبة والتكاليف والجداول الزمنية.
          </p>
          <ul class="hero__trust">
            <li>✓ للمسلمين وغير المسلمين</li>
            <li>✓ قائمة المستندات كاملة</li>
            <li>✓ التكاليف والجداول الزمنية</li>
            <li>✓ استشارة مجانية</li>
          </ul>
        </div>
        <div class="hero__form">
          <LeadForm lang="ar" variant="hero" heading="تحتاج مساعدة في التقديم؟ استشارة مجانية" />
        </div>
      </div>
    </header>

    <div class="container">

      <section class="section" aria-labelledby="overview-heading">
        <h2 id="overview-heading">نظرة عامة على إجراءات الطلاق في الإمارات</h2>

        <div class="summary-box">
          <h3>ملخص سريع</h3>
          <div class="summary-grid">
            <div class="summary-item">
              <span class="label">الطلاق بالتراضي</span>
              <span class="value">1–3 أشهر</span>
            </div>
            <div class="summary-item">
              <span class="label">الخلع</span>
              <span class="value">1–3 أشهر</span>
            </div>
            <div class="summary-item">
              <span class="label">الطلاق المتنازع عليه</span>
              <span class="value">6–24 شهراً</span>
            </div>
            <div class="summary-item">
              <span class="label">رسوم المحكمة</span>
              <span class="value">600–2,000 درهم</span>
            </div>
            <div class="summary-item">
              <span class="label">جلسة المصالحة</span>
              <span class="value">إلزامية (1–2 جلسة)</span>
            </div>
            <div class="summary-item">
              <span class="label">المحكمة المختصة</span>
              <span class="value">محكمة الأحوال الشخصية</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="docs-heading">
        <h2 id="docs-heading">المستندات المطلوبة لتقديم دعوى الطلاق في الإمارات</h2>
        <p>قبل التوجه إلى محكمة الأحوال الشخصية، تأكد من استيفاء المستندات التالية:</p>
        <ul class="doc-list">
          <li>
            <strong>عقد الزواج الأصلي</strong> — إذا كان صادراً من الخارج، يجب تصديقه من سفارة الإمارات في بلد الإصدار، ثم من وزارة الخارجية الإماراتية، مع ترجمة معتمدة للعربية
          </li>
          <li><strong>جوازا السفر</strong> — أصلٌ وصورة لكلا الزوجين</li>
          <li><strong>بطاقتا الهوية الإماراتية</strong> — لكلا الزوجين</li>
          <li><strong>إثبات الإقامة</strong> — عقد إيجار أو فاتورة مرافق تُثبت الإقامة في الإمارة المختصة</li>
          <li><strong>شهادات ميلاد الأطفال</strong> — إن كانت القضية تتضمن حضانةً (مصدَّقة ومترجمة)</li>
          <li><strong>عقد الزواج المسبق</strong> — إن وُجد</li>
        </ul>
        <p>
          لغير المسلمين الراغبين في تطبيق قانون 2022: قد تُطلب وثيقة تثبت الديانة
          (جواز سفر أو إفادة رسمية).
        </p>
      </section>

      <section class="section" aria-labelledby="steps-heading">
        <h2 id="steps-heading">خطوات إجراءات الطلاق في الإمارات</h2>

        <ol class="steps">
          <li>
            <h3>استشارة محامٍ متخصص</h3>
            <p>قبل أي إجراء، استشر محامي أسرة مرخّصاً لتحديد أفضل مسار قانوني لوضعك، سواء كان طلاقاً بالتراضي أو خلعاً أو تفريقاً قضائياً.</p>
          </li>
          <li>
            <h3>تجميع المستندات</h3>
            <p>احصل على جميع المستندات المطلوبة وتأكد من تصديقها وترجمتها. التقصير في هذه المرحلة يُؤخّر القضية أسابيع.</p>
          </li>
          <li>
            <h3>تقديم الدعوى في محكمة الأحوال الشخصية</h3>
            <p>يُقدَّم طلب الطلاق في محكمة الأحوال الشخصية في الإمارة التي تقيم فيها. في دبي: منطقة ديرة. يمكن البدء بالتسجيل إلكترونياً عبر تطبيق محاكم دبي. رسوم التسجيل: 600–2,000 درهم.</p>
          </li>
          <li>
            <h3>جلسة المصالحة الإلزامية</h3>
            <p>تُعيَّن جلسة مع مستشار اجتماعي معيّن من المحكمة يلتقي بالطرفين منفردَين ثم معاً. إن فشلت المصالحة وأكد الطرفان رغبتهما في الطلاق، تنتقل القضية للقاضي. عادةً تُعقد خلال 1–4 أسابيع من التقديم.</p>
          </li>
          <li>
            <h3>جلسات الاستماع</h3>
            <p>للطلاق بالتراضي: جلسة واحدة في الغالب. للطلاق المتنازع عليه: جلسات متعددة كل 4–6 أسابيع، يعرض فيها كلا الطرفين حججهما وأدلتهما.</p>
          </li>
          <li>
            <h3>صدور حكم الطلاق</h3>
            <p>يُصدر القاضي حكم الطلاق الذي يُنهي الزواج رسمياً في الإمارات.</p>
          </li>
          <li>
            <h3>تصديق الحكم وتوثيقه</h3>
            <p>للمقيمين الأجانب: يجب تصديق الحكم من وزارة العدل ثم وزارة الخارجية الإماراتية، ثم توثيقه في سفارة بلدك للاعتراف به خارج الإمارات.</p>
          </li>
        </ol>
      </section>

      <section class="section" aria-labelledby="costs-heading">
        <h2 id="costs-heading">تكاليف الطلاق في الإمارات</h2>

        <div class="cost-table-wrapper">
          <table class="cost-table">
            <thead>
              <tr>
                <th>نوع الطلاق</th>
                <th>أتعاب المحامي (درهم)</th>
                <th>رسوم المحكمة (درهم)</th>
                <th>التقدير الإجمالي</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>بالتراضي (اتفاق كامل)</td>
                <td>5,000 – 15,000</td>
                <td>600 – 1,200</td>
                <td>~6,000 – 16,000</td>
              </tr>
              <tr>
                <td>خلع</td>
                <td>5,000 – 12,000</td>
                <td>600 – 1,000</td>
                <td>~6,000 – 13,000</td>
              </tr>
              <tr>
                <td>متنازع عليه (بسيط)</td>
                <td>20,000 – 40,000</td>
                <td>1,000 – 1,500</td>
                <td>~21,000 – 42,000</td>
              </tr>
              <tr>
                <td>متنازع عليه (معقد)</td>
                <td>50,000 – 100,000+</td>
                <td>2,000+</td>
                <td>52,000 – 100,000+</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p class="table-note">الأرقام تقديرية. تتفاوت الأتعاب حسب المكتب وتعقيد القضية. استشارتنا الأولى مجانية دائماً.</p>
      </section>

      <section class="section" aria-labelledby="related-heading">
        <h2 id="related-heading">أدلة ذات صلة</h2>
        <div class="related-links">
          <a href="/ar/محامي-طلاق" class="related-link">
            <strong>محامي طلاق في الإمارات</strong>
            <span>احصل على تمثيل قانوني متخصص</span>
          </a>
          <a href="/ar/قانون-الطلاق-في-الامارات" class="related-link">
            <strong>قانون الطلاق في الإمارات</strong>
            <span>شرح القانون الاتحادي وتعديلات 2022</span>
          </a>
          <a href="/ar/حقوق-الزوجة-بعد-الطلاق-الامارات" class="related-link">
            <strong>حقوق الزوجة بعد الطلاق</strong>
            <span>النفقة والمهر وحق السكن</span>
          </a>
          <a href="/ar/حضانة-الاطفال-الامارات" class="related-link">
            <strong>حضانة الأطفال في الإمارات</strong>
            <span>من يحصل على الحضانة وكيف</span>
          </a>
        </div>
      </section>

      <FAQSection items={faqItems} lang="ar" />

      <section class="section section--cta" id="contact" aria-labelledby="cta-heading">
        <h2 id="cta-heading">تحتاج مساعدة في تقديم دعوى الطلاق؟</h2>
        <p>تحدث مع محامٍ متخصص في الطلاق مجاناً. متوفر باللغة العربية. سري تماماً.</p>
        <LeadForm lang="ar" variant="inline" />
      </section>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceU.AE — خدمة إحالة قانونية. ليست مكتب محاماة.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/">الرئيسية</a>
        <a href="/en/how-to-file-for-divorce-in-dubai">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 60px 0 50px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.7rem, 3.5vw, 2.5rem); font-weight: 800; line-height: 1.35; margin-bottom: 16px; }
  .hero__sub { font-size: 1rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.9; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.88rem; }
  .hero__trust li { opacity: 0.9; }
  .section { padding: 56px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.3rem, 2.8vw, 1.8rem); font-weight: 700; color: #1e3a5f; margin-bottom: 18px; }
  .section h3 { font-size: 1.05rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 2; margin-bottom: 14px; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 56px 40px; margin-bottom: 60px; text-align: center; }
  .summary-box { background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; padding: 28px 28px 20px; margin-top: 24px; }
  .summary-box h3 { font-size: 1rem; font-weight: 700; color: #1e3a5f; margin: 0 0 16px; }
  .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px; }
  .summary-item { display: flex; flex-direction: column; gap: 4px; }
  .summary-item .label { font-size: 0.8rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; }
  .summary-item .value { font-size: 1rem; font-weight: 700; color: #1e3a5f; }
  .doc-list { margin: 16px 0 20px 0; padding-right: 20px; display: flex; flex-direction: column; gap: 10px; }
  .doc-list li { color: #374151; line-height: 1.7; padding-right: 4px; }
  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 20px; margin-top: 24px; }
  .steps li { counter-increment: steps; padding: 22px 72px 22px 22px; position: relative; background: #f8faff; border-radius: 12px; border-right: 4px solid #2563eb; }
  .steps li::after { content: counter(steps); position: absolute; right: 18px; top: 22px; width: 36px; height: 36px; background: #2563eb; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1rem; }
  .steps li h3 { font-size: 1rem; font-weight: 700; color: #1e3a5f; margin: 0 0 8px; }
  .steps li p { font-size: 0.92rem; color: #374151; margin: 0; line-height: 1.7; }
  .cost-table-wrapper { overflow-x: auto; margin: 20px 0; }
  .cost-table { width: 100%; border-collapse: collapse; font-size: 0.92rem; }
  .cost-table th { background: #1e3a5f; color: #fff; padding: 12px 16px; text-align: right; font-weight: 600; }
  .cost-table td { padding: 12px 16px; border-bottom: 1px solid #e5e7eb; color: #374151; text-align: right; }
  .cost-table tr:nth-child(even) td { background: #f8faff; }
  .table-note { font-size: 0.8rem; color: #9ca3af; margin-top: 8px; }
  .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px; }
  .related-link { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .related-link:hover { border-color: #2563eb; }
  .related-link strong { color: #1e3a5f; font-size: 0.97rem; }
  .related-link span { color: #6b7280; font-size: 0.85rem; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 36px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.82rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem; }
  @media (max-width: 768px) { .hero__inner { grid-template-columns: 1fr; } .section--cta { padding: 40px 20px; } }
</style>
