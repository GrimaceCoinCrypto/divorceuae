---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'الطلاق في الإمارات — دليل شامل لعام 2025 للمقيمين والمغتربين';
const description =
  'دليل شامل عن الطلاق في الإمارات: القوانين، المحاكم، التكاليف، الجداول الزمنية، حضانة الأطفال والحقوق المالية. إرشادات للمسلمين وغير المسلمين.';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-in-uae',
  ar: 'https://divorceu.ae/ar/الطلاق-في-الامارات',
};

const breadcrumbs = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'الطلاق في الإمارات', url: 'https://divorceu.ae/ar/الطلاق-في-الامارات' },
];

const faqItems = [
  {
    question: 'كيف يتم الطلاق في الإمارات؟',
    answer:
      'يتم الطلاق في الإمارات أمام محكمة الأحوال الشخصية في الإمارة التي يقيم فيها الزوجان. تشمل إجراءات الطلاق تقديم طلب بالمستندات المطلوبة، وجلسة صلح إلزامية، ثم جلسات المحكمة، وأخيراً صدور حكم الطلاق.',
  },
  {
    question: 'كم يستغرق الطلاق في الإمارات؟',
    answer:
      'يستغرق الطلاق بالتراضي (الاتفاقي) في الغالب من شهر إلى 3 أشهر. أما الطلاق المتنازع عليه الذي يتضمن خلافات على الحضانة أو الأصول المالية، فقد يستغرق من 6 إلى 24 شهراً.',
  },
  {
    question: 'ما هي تكلفة الطلاق في الإمارات؟',
    answer:
      'تبدأ رسوم المحكمة من 600 إلى 2000 درهم. أما أتعاب المحامي للطلاق الاتفاقي فتتراوح بين 5000 و15000 درهم. يمكن أن تكون تكلفة الطلاق المتنازع عليه أعلى بكثير.',
  },
  {
    question: 'هل يحق للزوجة طلب الطلاق في الإمارات؟',
    answer:
      'نعم. يحق للزوجة المسلمة تقديم طلب خلع (مقابل إعادة المهر) أو طلب التفريق القضائي لأسباب محددة مثل الضرر أو الهجر أو عدم الإنفاق. وبموجب قانون 2022 لغير المسلمين، يحق لأي من الطرفين طلب الطلاق على قدم المساواة.',
  },
  {
    question: 'ما الذي يحدث للتأشيرة بعد الطلاق؟',
    answer:
      'إذا كنت مقيماً على تأشيرة زوجك، فلديك 30 يوماً بعد صدور حكم الطلاق لتغيير وضعك الإقامي. يمكنك التحول إلى تأشيرة عمل أو تأشيرة مستثمر أو تأشيرة طلاق/حضانة لمدة سنة إذا كان لديك أطفال في الإمارات.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
>
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <Breadcrumb items={breadcrumbs} lang="ar" />
        <h1 class="hero__h1">الطلاق في الإمارات — دليل شامل 2025</h1>
        <p class="hero__sub">
          سواء كنت مسلماً أو غير مسلم، مقيماً أو مواطناً إماراتياً — يغطي هذا الدليل كل ما
          تحتاج معرفته عن الطلاق في الإمارات: القوانين والمحاكم والتكاليف والجداول الزمنية وحقوقك.
        </p>
        <ul class="hero__trust">
          <li>✓ يشمل جميع الإمارات</li>
          <li>✓ قانون المسلمين وغير المسلمين</li>
          <li>✓ معلومات محدّثة لعام 2025</li>
          <li>✓ استشارة قانونية مجانية</li>
        </ul>
      </div>
      <div class="hero__form">
        <LeadForm lang="ar" variant="hero" heading="استشارة طلاق مجانية" />
      </div>
    </div>
  </header>

  <main class="container main-content">

    <!-- Key facts -->
    <section class="section" aria-labelledby="facts-heading">
      <h2 id="facts-heading">أبرز الحقائق عن الطلاق في الإمارات</h2>
      <div class="stats-grid">
        <div class="stat-card">
          <span class="stat-num">1–3</span>
          <span class="stat-label">أشهر للطلاق الاتفاقي</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">٦٠٠+ درهم</span>
          <span class="stat-label">رسوم تقديم الطلب</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">88%</span>
          <span class="stat-label">من سكان الإمارات مغتربون</span>
        </div>
        <div class="stat-card">
          <span class="stat-num">2022</span>
          <span class="stat-label">إصلاح قانوني لغير المسلمين</span>
        </div>
      </div>
    </section>

    <!-- Types of divorce -->
    <section class="section" aria-labelledby="types-heading">
      <h2 id="types-heading">أنواع الطلاق في الإمارات</h2>

      <h3>الطلاق للمسلمين</h3>
      <p>
        يخضع المسلمون في الإمارات لقانون الأحوال الشخصية الاتحادي رقم 28 لسنة 2005 المستند إلى
        أحكام الشريعة الإسلامية. وتشمل صور الطلاق:
      </p>
      <ul class="list">
        <li><strong>الطلاق (تطليق الزوج):</strong> يحق للزوج إيقاع الطلاق ويُسجَّل لدى محكمة الأحوال الشخصية</li>
        <li><strong>الخلع (بطلب الزوجة):</strong> تطلب الزوجة الطلاق مقابل إعادة المهر للزوج</li>
        <li><strong>التفريق القضائي:</strong> يمنحه القاضي بناءً على أسباب محددة كالضرر أو الهجر أو عدم النفقة</li>
        <li><strong>الطلاق بالتراضي:</strong> يتفق الطرفان على جميع الشروط مما يُسرّع الإجراءات</li>
      </ul>

      <h3>الطلاق لغير المسلمين (قانون 2022)</h3>
      <p>
        بموجب المرسوم بقانون الاتحادي رقم 41 لسنة 2022، يحق للمغتربين غير المسلمين الطلاق وفق
        مبادئ مدنية علمانية. يشمل ذلك تقسيم الأصول الزوجية بالتساوي، والحضانة المشتركة
        بشكل افتراضي، وطلب الطلاق دون الحاجة إلى إثبات ضرر أو أسباب.
      </p>
    </section>

    <!-- Process -->
    <section class="section" aria-labelledby="process-heading">
      <h2 id="process-heading">إجراءات الطلاق في الإمارات</h2>
      <ol class="steps">
        <li>
          <h3>استشارة محامي عائلة</h3>
          <p>افهم حقوقك والنتائج المحتملة واستشر محامياً متخصصاً. الاستشارة الأولى مجانية.</p>
        </li>
        <li>
          <h3>تقديم الطلب لمحكمة الأحوال الشخصية</h3>
          <p>يُقدَّم طلب الطلاق في محكمة إمارة إقامة الزوجين. المستندات المطلوبة: عقد الزواج، وجوازات السفر، والهويات الإماراتية.</p>
        </li>
        <li>
          <h3>جلسة الصلح الإلزامية</h3>
          <p>تشترط جميع محاكم الإمارات محاولة صلح قبل البدء بالإجراءات. يلتقي مستشار المحكمة بالطرفين. إذا فشل الصلح، يتابع المسار القانوني.</p>
        </li>
        <li>
          <h3>جلسات المحكمة</h3>
          <p>الطلاق الاتفاقي: يكتفي بجلسة واحدة في الغالب. الطلاق المتنازع عليه: يستلزم جلسات متعددة على مدى أشهر.</p>
        </li>
        <li>
          <h3>صدور حكم الطلاق</h3>
          <p>تصدر المحكمة حكم الطلاق النهائي. يحتاج المغتربون إلى تصديقه واعتماده للاستخدام في بلدانهم.</p>
        </li>
      </ol>
    </section>

    <!-- Costs -->
    <section class="section" aria-labelledby="costs-heading">
      <h2 id="costs-heading">تكاليف الطلاق في الإمارات</h2>
      <div class="cost-table">
        <table>
          <thead>
            <tr><th>نوع الطلاق</th><th>رسوم المحكمة</th><th>أتعاب المحامي (تقريباً)</th><th>المدة الزمنية</th></tr>
          </thead>
          <tbody>
            <tr><td>طلاق بالتراضي</td><td>600–1,500 درهم</td><td>5,000–15,000 درهم</td><td>1–3 أشهر</td></tr>
            <tr><td>طلاق متنازع عليه (بدون حضانة)</td><td>1,000–2,000 درهم</td><td>12,000–25,000 درهم</td><td>3–9 أشهر</td></tr>
            <tr><td>طلاق متنازع عليه (مع حضانة)</td><td>1,500–3,000 درهم</td><td>20,000–50,000+ درهم</td><td>6–24 شهراً</td></tr>
            <tr><td>الخلع</td><td>600–1,500 درهم</td><td>6,000–15,000 درهم</td><td>2–4 أشهر</td></tr>
          </tbody>
        </table>
        <p class="table-note">الأرقام تقديرية. يقدم كثير من المحامين استشارة أولى مجانية. تواصل معنا للحصول على تقدير لحالتك.</p>
      </div>

      <div class="cta-inline">
        <p>هل تقلقك التكاليف؟</p>
        <a href="#contact" class="btn btn--primary">احصل على تقدير مجاني</a>
      </div>
    </section>

    <!-- Related -->
    <section class="section" aria-labelledby="related-heading">
      <h2 id="related-heading">أدلة ذات صلة</h2>
      <div class="service-links">
        <a href="/ar/محامي-طلاق" class="service-link">
          <strong>محامي طلاق في الإمارات</strong>
          <span>ابحث عن محامٍ مؤهل</span>
        </a>
        <a href="/ar/محامي-طلاق-دبي" class="service-link">
          <strong>محامي طلاق دبي</strong>
          <span>التقاضي أمام محاكم دبي</span>
        </a>
        <a href="/ar/محامي-طلاق-ابوظبي" class="service-link">
          <strong>محامي طلاق أبوظبي</strong>
          <span>التقاضي أمام محاكم أبوظبي</span>
        </a>
        <a href="/ar/حضانة-الاطفال-الامارات" class="service-link">
          <strong>حضانة الأطفال في الإمارات</strong>
          <span>حقوق الحضانة والإجراءات</span>
        </a>
        <a href="/ar/حقوق-الزوجة-بعد-الطلاق-الامارات" class="service-link">
          <strong>حقوق الزوجة بعد الطلاق</strong>
          <span>النفقة والمهر والمسكن</span>
        </a>
        <a href="/ar/قانون-الطلاق-في-الامارات" class="service-link">
          <strong>قانون الطلاق في الإمارات</strong>
          <span>شرح قانون الأحوال الشخصية</span>
        </a>
      </div>
    </section>

    <FAQSection items={faqItems} lang="ar" />

    <section class="section section--cta" aria-labelledby="bottom-cta-heading" id="contact">
      <h2 id="bottom-cta-heading">احصل على استشارة قانونية مجانية عن الطلاق في الإمارات</h2>
      <p>تحدث مع محامي طلاق مؤهل خلال 24 ساعة. سري تماماً. دعم باللغتين العربية والإنجليزية.</p>
      <LeadForm lang="ar" variant="inline" />
    </section>

  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceU.AE — خدمة إحالة قانونية. ليست مكتب محاماة. المعلومات المقدمة للإرشاد فقط ولا تشكل استشارة قانونية.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/سياسة-الخصوصية">سياسة الخصوصية</a>
        <a href="/ar/إخلاء-المسؤولية">إخلاء المسؤولية</a>
        <a href="/en/">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 80px 0 60px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; line-height: 1.3; margin-bottom: 16px; }
  .hero__sub { font-size: 1.05rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.8; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.9rem; }
  .hero__trust li { opacity: 0.9; }

  .section { padding: 60px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #1e3a5f; margin-bottom: 20px; }
  .section h3 { font-size: 1.1rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 1.9; margin-bottom: 16px; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 60px 40px; margin-bottom: 60px; text-align: center; }

  .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 20px; margin-top: 24px; }
  .stat-card { background: #f8faff; border: 2px solid #2563eb; border-radius: 12px; padding: 24px 16px; text-align: center; }
  .stat-num { display: block; font-size: 1.7rem; font-weight: 800; color: #2563eb; }
  .stat-label { font-size: 0.85rem; color: #374151; }

  .list { margin: 12px 0 20px 0; padding-right: 20px; padding-left: 0; }
  .list li { margin-bottom: 8px; color: #374151; line-height: 1.7; }

  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 20px; margin-top: 24px; }
  .steps li { counter-increment: steps; padding: 20px 68px 20px 20px; position: relative; background: #f8faff; border-radius: 12px; border-right: 4px solid #2563eb; }
  .steps li::before { content: counter(steps); position: absolute; right: 18px; top: 20px; width: 32px; height: 32px; background: #2563eb; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; }
  .steps li h3 { font-size: 0.95rem; font-weight: 700; color: #1e3a5f; margin-bottom: 6px; }
  .steps li p { font-size: 0.875rem; color: #374151; margin: 0; }

  .cost-table { margin-top: 24px; overflow-x: auto; }
  .cost-table table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .cost-table th { background: #1e3a5f; color: #fff; padding: 12px 16px; text-align: right; }
  .cost-table td { padding: 10px 16px; border-bottom: 1px solid #e5e7eb; color: #374151; text-align: right; }
  .cost-table tr:nth-child(even) td { background: #f8faff; }
  .table-note { font-size: 0.8rem; color: #9ca3af; margin: 10px 0 0; }

  .cta-inline { display: flex; align-items: center; gap: 20px; margin-top: 28px; flex-wrap: wrap; }
  .cta-inline p { margin: 0; font-weight: 600; }
  .btn--primary { display: inline-block; padding: 12px 28px; background: #c9a84c; color: #fff; border-radius: 8px; text-decoration: none; font-weight: 700; transition: background 0.2s; }
  .btn--primary:hover { background: #b8942d; }

  .service-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-top: 24px; }
  .service-link { display: flex; flex-direction: column; gap: 4px; padding: 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .service-link:hover { border-color: #2563eb; }
  .service-link strong { color: #1e3a5f; }
  .service-link span { color: #6b7280; font-size: 0.875rem; }

  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 40px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.85rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
  .footer nav a:hover { color: #fff; }
  .main-content { padding-top: 20px; }

  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero { padding: 50px 0 40px; }
    .section--cta { padding: 40px 24px; }
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
