---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'تكلفة الطلاق في الإمارات ٢٠٢٥ — رسوم المحكمة وأتعاب المحامين';
const description =
  'كم تكلفة الطلاق في الإمارات؟ تفصيل كامل لرسوم المحكمة وأتعاب المحامين وتكاليف الوساطة — بأرقام حقيقية من دبي وأبوظبي لعام ٢٠٢٥.';

const canonical = 'https://divorceu.ae/ar/تكلفة-الطلاق-في-الامارات';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-cost-uae',
  ar: canonical,
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'تكلفة الطلاق في الإمارات' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'كم تكلفة الطلاق في الإمارات بشكل عام؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تتراوح تكلفة الطلاق بالتراضي في الإمارات بين ٤٠٠٠ و١٠٠٠٠ درهم شاملاً رسوم المحكمة وأتعاب المحامي. أما الطلاق الخلافي دون نزاع على الحضانة فيتراوح بين ١٥٠٠٠ و٤٥٠٠٠ درهم. وتتجاوز قضايا الحضانة المتنازع عليها ٢٥٠٠٠ درهم في أغلب الأحيان وقد تصل إلى ٨٠٠٠٠ درهم أو أكثر.',
      },
    },
    {
      '@type': 'Question',
      name: 'ما هي رسوم تقديم طلب الطلاق في المحاكم الإماراتية؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تتراوح رسوم المحكمة الحكومية لتقديم دعوى الطلاق في الإمارات بين ٥٠٠ و٢٠٠٠ درهم للقضايا البسيطة، وتشمل رسوم تسجيل القضية وجلسات الوساطة الأسرية. القضايا المعقدة التي تستلزم خبراء أو تقارير اجتماعية قد تصل رسومها الحكومية إلى ٥٠٠٠ درهم.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل الوساطة الأسرية إلزامية قبل الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'نعم. وفق القانون الاتحادي، تمر معظم قضايا الطلاق بمرحلة التوجيه الأسري أو الوساطة قبل نظر المحكمة في القضية. في دبي تتولى هذا الدور إدارة الخدمات الاجتماعية في المحاكم. تستغرق من جلسة إلى أربع جلسات عادةً، والرسوم بين ١٠٠ و٣٠٠ درهم لكل جلسة.',
      },
    },
    {
      '@type': 'Question',
      name: 'كيف أخفض تكلفة الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'أفضل طريقة لخفض التكلفة هي الاتفاق على أكبر قدر من البنود خارج المحكمة قبل تقديم الطلب. كل بند تتفقان عليه (النفقة، الحضانة، توزيع الأصول) يقلل عدد الجلسات ويوفر أتعاب المحامين بنسبة ٦٠-٨٠٪. كذلك احضر وثائقك مترجمة ومصادقاً عليها قبل اللقاء الأول مع المحامي لتوفير وقت الاستشارة.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل يحتاج المقيمون الأجانب إلى مزيد من المستندات وهل تزيد التكلفة؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'نعم. المقيمون الأجانب يحتاجون عادةً إلى ترجمة قانونية معتمدة لعقد الزواج ووثائق الهوية، وأحياناً تصديق من وزارة الخارجية وسفارة بلد الأصل. تكلفة الترجمة المعتمدة بين ١٠٠ و٤٠٠ درهم للوثيقة، والتصديق يضيف ٣٠٠-١٠٠٠ درهم حسب بلد المنشأ.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم تستغرق قضية الطلاق في الإمارات وكيف يؤثر ذلك على التكلفة؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'الطلاق بالتراضي يكتمل في ١-٣ أشهر عادةً. الطلاق الخلافي يستغرق ٦-١٨ شهراً. نزاعات الحضانة قد تمتد ٢٤ شهراً أو أكثر. كل شهر إضافي يعني رسوماً لمحامٍ يتقاضى ٣٠٠٠-٨٠٠٠ درهم شهرياً ومصاريف جلسات إضافية.',
      },
    },
  ],
};

const courtFees = [
  { item: 'رسوم تسجيل الدعوى', cost: '٢٠٠–٣٠٠ درهم', notes: 'تُدفع عند تقديم العريضة. تتباين قليلاً بين الإمارات.' },
  { item: 'رسوم فتح ملف القضية', cost: '١٥٠–٢٥٠ درهم', notes: 'رسوم إدارية لفتح ملف القضية في محكمة الأسرة.' },
  { item: 'جلسات الوساطة / التوجيه الأسري', cost: '١٠٠–٣٠٠ درهم/جلسة', notes: 'إلزامية في معظم القضايا الخلافية. من جلسة إلى أربع جلسات عادةً.' },
  { item: 'خبير / أخصائي اجتماعي (إذا عيّنته المحكمة)', cost: '٥٠٠–٢٥٠٠ درهم', notes: 'يُطلب في نزاعات الحضانة حين تأمر المحكمة بتقرير رعاية.' },
  { item: 'ترجمة المستندات (للوثيقة الواحدة)', cost: '١٠٠–٤٠٠ درهم', notes: 'الترجمة القانونية المعتمدة مطلوبة للوثائق الأجنبية كالجوازات وعقود الزواج.' },
  { item: 'تصديق المستندات', cost: '١٥٠–٦٠٠ درهم+', notes: 'عقود الزواج الأجنبية تحتاج تصديق وزارة الخارجية الإماراتية وسفارة البلد الأصلي.' },
];

const lawyerFees = [
  { type: 'الطلاق بالتراضي', range: '٣٠٠٠–٨٠٠٠ درهم', desc: 'يتفق الزوجان على جميع البنود. يُعدّ المحامي الاتفاقية ويُقدمها. حد أدنى من الجلسات.' },
  { type: 'طلاق خلافي (بلا أطفال)', range: '٨٠٠٠–٢٠٠٠٠ درهم', desc: 'نزاع على الأصول أو النفقة أو الممتلكات. يستلزم جلسات متعددة.' },
  { type: 'طلاق خلافي مع نزاع حضانة', range: '١٥٠٠٠–٤٥٠٠٠ درهم+', desc: 'الأكثر تعقيداً وتكلفةً. قد يمتد ١٢-٢٤ شهراً مع تقارير خبراء متعددة.' },
  { type: 'قضايا غير المسلمين / الوافدين', range: '٦٠٠٠–٢٥٠٠٠ درهم', desc: 'القضايا المنظورة وفق قانون البلد الأصلي أو تحت اختصاص DIFC تضيف تعقيدات إجرائية.' },
  { type: 'الخلع (بطلب من الزوجة)', range: '٤٠٠٠–١٢٠٠٠ درهم', desc: 'أبسط إذا وافق الزوج. يزداد تعقيداً إذا كان خلافياً وتعلق بإعادة المهر.' },
];

const faqItems = [
  {
    question: 'كم تكلفة الطلاق في الإمارات بشكل عام؟',
    answer: 'تتراوح تكلفة الطلاق بالتراضي في الإمارات بين ٤٠٠٠ و١٠٠٠٠ درهم شاملاً رسوم المحكمة وأتعاب المحامي. أما الطلاق الخلافي دون نزاع على الحضانة فيتراوح بين ١٥٠٠٠ و٤٥٠٠٠ درهم. وتتجاوز قضايا الحضانة المتنازع عليها ٢٥٠٠٠ درهم في أغلب الأحيان وقد تصل إلى ٨٠٠٠٠ درهم أو أكثر.',
  },
  {
    question: 'هل الطلاق مجاني في الإمارات إذا اتفق الزوجان؟',
    answer: 'لا تزال رسوم المحكمة سارية حتى في الطلاق بالتراضي، غير أنها محدودة (٥٠٠-١٥٠٠ درهم). الوفر الحقيقي يكون في أتعاب المحامين — الطلاق المتفق عليه يُنجز بأتعاب إجمالية ٣٠٠٠-٨٠٠٠ درهم بدلاً من ١٥٠٠٠-٤٥٠٠٠ درهم للطلاق الخلافي. يمكن كذلك أن يُعدّ محامٍ واحد الاتفاقية ويوقع عليها الطرفان.',
  },
  {
    question: 'هل يلزمني توكيل محامٍ للطلاق في الإمارات؟',
    answer: 'من الناحية النظرية لا — يمكنك تمثيل نفسك أمام المحاكم. لكن عملياً، ولا سيما للمقيمين الأجانب، فإن إجراءات التقاضي (المذكرات باللغة العربية وآداب المحكمة ومعرفة قانون الأحوال الشخصية) تجعل التمثيل الذاتي بالغ الصعوبة. تشترط المحاكم الإماراتية تقديم وثائق باللغة العربية. كما يضمن المحامي صياغة التسويات — خاصةً بنود الحضانة — بشكل صحيح وقابل للتنفيذ.',
  },
  {
    question: 'ما التكاليف الخفية التي يجب أن أضعها في الحسبان؟',
    answer: 'ثمة تكاليف كثيراً ما تفاجئ العملاء: (١) الترجمة القانونية المعتمدة لكل الوثائق الأجنبية ١٠٠-٤٠٠ درهم للوثيقة. (٢) تصديق عقود الزواج الأجنبية ٣٠٠-١٠٠٠ درهم+ حسب البلد. (٣) رسوم مأمور التبليغ إذا كان الزوج بحاجة إلى إبلاغ رسمي. (٤) إجراءات التنفيذ — إذا لم يلتزم الطرف الآخر بالحكم تحتاج طلب تنفيذ إضافي يُكلف ٢٠٠٠-٦٠٠٠ درهم.',
  },
  {
    question: 'هل تختلف التكاليف بين دبي وأبوظبي والشارقة؟',
    answer: 'الرسوم الحكومية متقاربة في مختلف الإمارات مع فوارق طفيفة. أتعاب المحامين في دبي تميل إلى الأعلى نظراً لارتفاع تكاليف المعيشة والطلب الأعلى. الشارقة وعجمان أقل تكلفةً قليلاً. المحامي ذو الخبرة في المنطقة التي تُعقد فيها المحكمة يمثل ميزة عملية تفوق أي فارق في الأتعاب.',
  },
  {
    question: 'ما نموذج الفوترة الشائع لدى محامي الطلاق في الإمارات؟',
    answer: 'يستخدم محامو الطلاق في الإمارات ثلاثة نماذج: (١) رسم ثابت للقضايا غير الخلافية ٣٠٠٠-٨٠٠٠ درهم. (٢) رسم لكل جلسة ١٥٠٠-٥٠٠٠ درهم وقد يتراكم سريعاً إذا امتدت القضية. (٣) مُحتجَز شهري ٣٠٠٠-٨٠٠٠ درهم + ساعي للقضايا الخلافية المعقدة. اطلب دائماً اتفاقية أتعاب خطية قبل التوقيع مع أي محامٍ.',
  },
];
---

<BaseLayout
  {title}
  {description}
  {canonical}
  {hreflang}
  lang="ar"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <section class="hero-section">
    <div class="hero-inner">
      <p class="hero-tag">دليل التكاليف · الإمارات ٢٠٢٥</p>
      <h1>{title}</h1>
      <p class="hero-desc">
        تفصيل كامل لما يكلفه الطلاق فعلياً في الإمارات — رسوم الحكومة، أتعاب المحامين، مدة القضية، وما يرفع الفاتورة أو يخفضها. بأرقام حقيقية من دبي وأبوظبي.
      </p>
      <p class="hero-author">بقلم <strong>ألكسي سوونينن</strong> · مستشار قانوني ومقيم في الإمارات · divorceu.ae</p>
    </div>
  </section>

  <div class="page-layout">
    <main class="main-content">

      <div class="summary-box">
        <h2>ملخص سريع — تكاليف الطلاق في الإمارات</h2>
        <div class="summary-grid">
          <div class="summary-card summary-card--highlight">
            <p class="summary-label">طلاق بالتراضي</p>
            <p class="summary-amount">٤٠٠٠–١٠٠٠٠ درهم</p>
            <p class="summary-note">إجمالاً (رسوم + محامٍ). يتفق الطرفان على كل البنود.</p>
          </div>
          <div class="summary-card">
            <p class="summary-label">طلاق خلافي</p>
            <p class="summary-amount">١٥٠٠٠–٤٥٠٠٠ درهم</p>
            <p class="summary-note">نزاع على الأصول أو النفقة أو الممتلكات. ٦-١٨ شهراً.</p>
          </div>
          <div class="summary-card">
            <p class="summary-label">نزاع حضانة</p>
            <p class="summary-amount">٢٥٠٠٠–٨٠٠٠٠ درهم+</p>
            <p class="summary-note">أعقد القضايا. قد يمتد ١٢-٢٤ شهراً أو أكثر.</p>
          </div>
        </div>
        <p class="summary-note-footer">جميع الأرقام تقديرية إجمالية تشمل رسوم المحكمة والمحامي. تكاليف الترجمة والتصديق إضافية.</p>
      </div>

      <section class="content-section">
        <h2>رسوم المحاكم الإماراتية — ما تدفعه للجهات الحكومية</h2>
        <p>رسوم المحاكم الحكومية محددة من قِبل سلطة قضاء كل إمارة وهي في العموم معقولة. الأرقام أدناه خاصة بدبي؛ أبوظبي والشارقة لهما هياكل مماثلة مع فوارق طفيفة.</p>

        <div class="table-wrapper">
          <table class="cost-table">
            <thead>
              <tr>
                <th>البند</th>
                <th>المبلغ</th>
                <th>ملاحظات</th>
              </tr>
            </thead>
            <tbody>
              {courtFees.map((row, i) => (
                <tr class={i % 2 === 0 ? '' : 'row-alt'}>
                  <td class="td-label">{row.item}</td>
                  <td class="td-cost">{row.cost}</td>
                  <td class="td-notes">{row.notes}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="table-note">تبلغ الرسوم الحكومية في مجملها ٥٠٠-٢٠٠٠ درهم للقضايا المباشرة. القضايا المعقدة التي تشمل جلسات متعددة وتعيين خبراء قد تصل رسومها الحكومية إلى ٣٠٠٠-٥٠٠٠ درهم.</p>
      </section>

      <section class="content-section">
        <h2>أتعاب المحامين — أكبر متغير في التكلفة</h2>
        <p>الأتعاب القانونية هي حيث تتباين تكاليف الطلاق تبايناً كبيراً بحسب حجم الاتفاق بينك وبين شريكك. يتقاضى محامو الإمارات عادةً رسماً ثابتاً للقضايا البسيطة أو رسماً لكل جلسة أو أتعاباً شهرية ثابتة للقضايا المتنازع عليها الطويلة.</p>

        <div class="lawyer-cards">
          {lawyerFees.map(fee => (
            <div class="lawyer-card">
              <div class="lawyer-card-header">
                <h3>{fee.type}</h3>
                <span class="lawyer-cost">{fee.range}</span>
              </div>
              <p class="lawyer-desc">{fee.desc}</p>
            </div>
          ))}
        </div>

        <div class="info-box">
          <h3>الرسم الثابت مقابل الجلسة مقابل المُحتجَز الشهري</h3>
          <p>يستخدم محامو طلاق الإمارات ثلاثة نماذج فوترة:</p>
          <ul>
            <li><strong>رسم ثابت</strong> — شائع في قضايا التراضي (٣٠٠٠-٨٠٠٠ درهم إجمالاً). واضح في الميزانية بلا مفاجآت.</li>
            <li><strong>رسم لكل جلسة</strong> — ١٥٠٠-٥٠٠٠ درهم للجلسة. إذا امتدت القضية تراكمت التكاليف سريعاً.</li>
            <li><strong>مُحتجَز + ساعي</strong> — شائع في القضايا الخلافية المعقدة. مُحتجَز شهري ٣٠٠٠-٨٠٠٠ درهم وأجر ساعي ٥٠٠-١٥٠٠ درهم لكبار المحامين.</li>
          </ul>
          <p>اطلب دائماً اتفاقية أتعاب خطية قبل توكيل أي محامٍ. التقديرات الشفهية غير ملزمة قانونياً في الإمارات.</p>
        </div>
      </section>

      <section class="content-section">
        <h2>ما يرفع تكلفة الطلاق</h2>

        <div class="driver-list">
          {[
            { factor: 'النزاع على حضانة الأطفال', impact: 'مرتفع جداً', cls: 'very-high', desc: 'تشمل قضايا الحضانة تقارير اجتماعية وتقييمات نفسية وجلسات متعددة واستئنافات في الغالب. القضية الخلافية قد تمتد ١٨-٣٦ شهراً.' },
            { factor: 'النزاع على الممتلكات والأصول', impact: 'مرتفع', cls: 'high', desc: 'إذا كانت الأملاك أو مصالح تجارية أو عقارات في الإمارات محل خلاف، فإن تقييمات الخبراء والإفصاح المالي يرفعان التكلفة بشكل ملحوظ.' },
            { factor: 'أحد الزوجين خارج الإمارات', impact: 'مرتفع', cls: 'high', desc: 'التبليغ الدولي والحصول على وثائق محاكم أجنبية وإدارة فوارق التوقيت تضيف تكاليف إجرائية وتأخيرات.' },
            { factor: 'قضايا غير المسلمين / القانون الأجنبي', impact: 'متوسط–مرتفع', cls: 'medium-high', desc: 'تطبيق قانون البلد الأصلي يستلزم تقديم بيّنة بالقانون الأجنبي، وهو ما يتطلب عادةً خبيراً قانونياً يدلي بشهادته.' },
            { factor: 'حجم وثائق الترجمة', impact: 'متوسط', cls: 'medium', desc: 'كل وثيقة أجنبية تستلزم ترجمة معتمدة وأحياناً تصديقاً. قضايا الإفصاح المالي الكبيرة تتراكم فيها تكاليف الترجمة.' },
            { factor: 'الزوج المتهرب من الإجراءات', impact: 'متوسط', cls: 'medium', desc: 'إذا تجاهل أحد الزوجين الإجراءات، تسير القضية بعد مُهل التبليغ. يضيف وقتاً وليس بالضرورة تكلفةً كبيرة إذا كان لديك محامٍ.' },
          ].map(d => (
            <div class="driver-card">
              <div class="driver-header">
                <span class="driver-factor">{d.factor}</span>
                <span class={`driver-impact driver-impact--${d.cls}`}>{d.impact}</span>
              </div>
