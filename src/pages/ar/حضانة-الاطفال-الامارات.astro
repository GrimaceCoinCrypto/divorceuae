---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'حضانة الأطفال بعد الطلاق في الإمارات — من يحصل على الحضانة؟ 2025';
const description =
  'دليل شامل لحضانة الأطفال بعد الطلاق في الإمارات. حقوق الأم والأب، أعمار الحضانة، إذن السفر، وقانون الحضانة المشتركة 2022. استشارة مجانية.';

const canonical = 'https://divorceu.ae/ar/حضانة-الاطفال-الامارات';

const hreflang = {
  en: 'https://divorceu.ae/en/child-custody-uae',
  ar: 'https://divorceu.ae/ar/حضانة-الاطفال-الامارات',
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'حضانة الأطفال في الإمارات' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'من يحصل على حضانة الأطفال في الإمارات بعد الطلاق؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'وفق قانون الأحوال الشخصية الإماراتي، تحصل الأم على الحضانة الفعلية للأولاد حتى سن 11، وللبنات حتى سن 13. بعد هذه السن، يختار الطفل أو تقرر المحكمة بناءً على مصلحته الفضلى. يحتفظ كلا الوالدين بالولاية القانونية بغض النظر عن الحضانة الفعلية.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل يمكن للأب الحصول على حضانة أطفاله في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'نعم. إذا ثبت أن الأم غير مؤهلة للحضانة — لإهمال أو إساءة أو تقصير — تنتقل الحضانة الفعلية للأب. كذلك، بعد بلوغ الأطفال السن المحددة، يحق للأطفال اختيار العيش مع الأب. يحتفظ الأب دائماً بالولاية القانونية الكاملة.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل تستطيع الأم أخذ الأطفال خارج الإمارات بعد الطلاق؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'لا — ليس بدون إذن مكتوب من الأب أو أمر قضائي بالسفر. يُعدّ أخذ الأطفال خارج الإمارات بدون إذن اختطافاً للأطفال وفق القانون الإماراتي، وهو جريمة جنائية. يجب طلب الإذن من محكمة الأحوال الشخصية إذا رفض الأب.',
      },
    },
  ],
};

const faqItems = [
  {
    question: 'من يحصل على حضانة الأطفال في الإمارات بعد الطلاق؟',
    answer: 'تحصل الأم على الحضانة الفعلية: <strong>الأولاد حتى سن 11، البنات حتى سن 13</strong>. بعد ذلك يختار الطفل أو تقرر المحكمة. يحتفظ كلا الوالدين بالولاية القانونية.',
  },
  {
    question: 'هل يمكن للأب الحصول على حضانة أطفاله في الإمارات؟',
    answer: 'نعم. إذا ثبت عدم أهلية الأم، أو بعد بلوغ الأطفال السن القانونية، يمكن للأب الحصول على الحضانة الفعلية. ويحتفظ الأب دائماً بالولاية القانونية الكاملة بصرف النظر عن الحضانة.',
  },
  {
    question: 'هل تستطيع الأم أخذ الأطفال خارج الإمارات بعد الطلاق؟',
    answer: 'لا — إلا بإذن مكتوب من الأب أو أمر قضائي. أخذ الأطفال بدون إذن جريمة جنائية في الإمارات. يجب التقدم لمحكمة الأحوال الشخصية إذا رفض الأب.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
  schema={faqSchema}
>
  <main>
    <header class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <Breadcrumb items={breadcrumbItems} lang="ar" />
          <h1 class="hero__h1">
            حضانة الأطفال بعد الطلاق في الإمارات —<br />
            من يحصل على الحضانة؟
          </h1>
          <p class="hero__sub">
            حضانة الأطفال هي المسألة الأكثر تعقيداً في الطلاق. يشرح هذا الدليل حقوق الأم والأب
            في الحضانة الفعلية والولاية القانونية، وأعمار الحضانة، وإذن السفر، وما جاء به
            قانون 2022 من تغييرات في حضانة الأطفال.
          </p>
          <ul class="hero__trust">
            <li>✓ حقوق الأم والأب كاملةً</li>
            <li>✓ أعمار الحضانة القانونية</li>
            <li>✓ قواعد السفر والولاية</li>
            <li>✓ استشارة مجانية</li>
          </ul>
        </div>
        <div class="hero__form">
          <LeadForm lang="ar" variant="hero" heading="احمِ حق حضانتك — استشارة مجانية" />
        </div>
      </div>
    </header>

    <div class="container">

      <section class="section" aria-labelledby="basics-heading">
        <h2 id="basics-heading">الفرق بين الحضانة الفعلية والولاية القانونية في الإمارات</h2>
        <div class="concept-grid">
          <div class="concept-card">
            <h3>الحضانة الفعلية (الحضانة)</h3>
            <p>من يعيش معه الطفل يومياً. تحصل عليها الأم افتراضياً للأطفال الصغار وفق قانون الأحوال الشخصية الإسلامي.</p>
          </div>
          <div class="concept-card">
            <h3>الولاية القانونية (الولاية)</h3>
            <p>حق اتخاذ القرارات المصيرية: السفر والتعليم والرعاية الصحية وجواز السفر. يحتفظ بها الأب دائماً حتى لو كانت الأم هي الحاضنة.</p>
          </div>
        </div>
        <p>
          هذا الفرق بالغ الأهمية: قد تحصل الأم على الحضانة الفعلية الكاملة ومع ذلك تحتاج
          إلى موافقة الأب لأخذ الأطفال في رحلة خارجية أو تسجيلهم في مدرسة جديدة.
        </p>
      </section>

      <section class="section" aria-labelledby="ages-heading">
        <h2 id="ages-heading">أعمار الحضانة في قانون الأحوال الشخصية الإماراتي</h2>
        <p>
          وفق قانون الأحوال الشخصية الاتحادي رقم 28 لسنة 2005:
        </p>
        <ul class="list">
          <li><strong>الأولاد:</strong> تحتفظ الأم بالحضانة الفعلية حتى يبلغ الولد <strong>11 سنة</strong></li>
          <li><strong>البنات:</strong> تحتفظ الأم بالحضانة الفعلية حتى تبلغ البنت <strong>13 سنة</strong></li>
          <li>بعد هذه السن، يختار الطفل أو تقرر المحكمة بناءً على مصلحته الفضلى</li>
          <li>تنتهي حضانة الأم إذا تزوجت من رجل غير محرم للأطفال</li>
          <li>يمكن نقل الحضانة للأب إذا ثبت عدم أهلية الأم</li>
        </ul>

        <h3>حقوق الأب في الحضانة</h3>
        <p>
          يحتفظ الأب بالولاية القانونية على جميع الأطفال بصرف النظر عن سنّهم وعن الحاضن.
          في حالات عدم أهلية الأم — إهمال أو إساءة أو مرض — يمكن للأب المطالبة بنقل الحضانة الفعلية إليه.
        </p>
      </section>

      <section class="section" aria-labelledby="travel-heading">
        <h2 id="travel-heading">إذن السفر بالأطفال بعد الطلاق في الإمارات</h2>
        <p>
          هذه من أكثر المسائل عملياً وأهمية للأسر المقيمة في الإمارات:
        </p>

        <h3>السفر خارج الإمارات</h3>
        <p>
          لا يجوز للوالد الحاضن <strong>أخذ الأطفال خارج الإمارات دون إذن مكتوب من الطرف الآخر</strong>
          أو أمر قضائي بالسفر. هذا ينطبق حتى على الرحلات القصيرة للعطل.
        </p>

        <div class="callout">
          <strong>تحذير جدي:</strong> أخذ الأطفال خارج الإمارات دون إذن يُعدّ اختطافاً للأطفال وفق
          القانون الإماراتي — وهو جريمة جنائية وليس مجرد خلاف مدني. تشمل المطارات والمنافذ الحدودية
          ربطاً مع نظام المحاكم يتيح للطرف الآخر تفعيل حظر سفر على الأطفال.
        </div>

        <h3>ماذا تفعل إذا رفض الطرف الآخر الإذن بالسفر؟</h3>
        <ol class="steps">
          <li>
            <h3>تقديم طلب لمحكمة الأحوال الشخصية</h3>
            <p>قدّم دعوى طالباً أمراً قضائياً بالسفر مع توضيح أن الرحلة تصبّ في مصلحة الطفل.</p>
          </li>
          <li>
            <h3>تحديد تفاصيل الرحلة</h3>
            <p>اذكر الوجهة والتواريخ وسبب السفر والتزامك بالعودة. المحاكم تُجيز عادةً زيارات الأقارب والرحلات التعليمية.</p>
          </li>
          <li>
            <h3>الحصول على أمر السفر</h3>
            <p>عند الموافقة، يُصدر القاضي أمراً بالسفر يحدد الوجهة والتواريخ بالضبط، ويلغي أي حظر سفر.</p>
          </li>
        </ol>
      </section>

      <section class="section" aria-labelledby="related-heading">
        <h2 id="related-heading">أدلة ذات صلة</h2>
        <div class="related-links">
          <a href="/ar/محامي-طلاق" class="related-link">
            <strong>محامي طلاق في الإمارات</strong>
            <span>احمِ حقوق حضانتك مع محامٍ متخصص</span>
          </a>
          <a href="/ar/حقوق-الزوجة-بعد-الطلاق-الامارات" class="related-link">
            <strong>حقوق الزوجة بعد الطلاق</strong>
            <span>النفقة والمهر وحق السكن</span>
          </a>
          <a href="/ar/كيفية-تقديم-الطلاق-في-الامارات" class="related-link">
            <strong>إجراءات الطلاق في الإمارات</strong>
            <span>خطوة بخطوة من التقديم للحكم</span>
          </a>
          <a href="/ar/قانون-الطلاق-في-الامارات" class="related-link">
            <strong>قانون الطلاق في الإمارات</strong>
            <span>القانون الاتحادي موضّحاً بالكامل</span>
          </a>
        </div>
      </section>

      <FAQSection items={faqItems} lang="ar" />

      <section class="section section--cta" id="contact" aria-labelledby="cta-heading">
        <h2 id="cta-heading">احمِ حق حضانتك — استشارة مجانية</h2>
        <p>تحدث مع محامي أسرة متخصص يشرح خياراتك ويدافع عن حقوقك في الحضانة أمام المحكمة.</p>
        <LeadForm lang="ar" variant="inline" />
      </section>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceUAE.ae — خدمة إحالة قانونية. ليست مكتب محاماة.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/">الرئيسية</a>
        <a href="/en/child-custody-uae">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 60px 0 50px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.7rem, 3.5vw, 2.5rem); font-weight: 800; line-height: 1.35; margin-bottom: 16px; }
  .hero__sub { font-size: 1rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.9; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.88rem; }
  .hero__trust li { opacity: 0.9; }
  .section { padding: 56px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.3rem, 2.8vw, 1.8rem); font-weight: 700; color: #1e3a5f; margin-bottom: 18px; }
  .section h3 { font-size: 1.05rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 2; margin-bottom: 14px; }
  .section a { color: #2563eb; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 56px 40px; margin-bottom: 60px; text-align: center; }
  .callout { background: #fff7ed; border-right: 4px solid #f59e0b; border-left: none; padding: 14px 18px; border-radius: 8px 0 0 8px; color: #92400e; font-size: 0.95rem; margin: 16px 0; }
  .list { margin: 10px 0 18px 0; padding-right: 20px; }
  .list li { margin-bottom: 8px; color: #374151; line-height: 1.8; }
  .concept-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0; }
  .concept-card { padding: 22px; background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; }
  .concept-card h3 { font-size: 0.97rem; font-weight: 700; color: #1e3a5f; margin: 0 0 10px; }
  .concept-card p { font-size: 0.9rem; color: #374151; margin: 0; line-height: 1.7; }
  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 16px; margin-top: 16px; }
  .steps li { counter-increment: steps; padding: 20px 68px 20px 20px; position: relative; background: #f8faff; border-radius: 10px; border-right: 4px solid #2563eb; }
  .steps li::after { content: counter(steps); position: absolute; right: 16px; top: 20px; width: 32px; height: 32px; background: #2563eb; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; }
  .steps li h3 { font-size: 0.97rem; font-weight: 700; color: #1e3a5f; margin: 0 0 6px; }
  .steps li p { font-size: 0.88rem; color: #374151; margin: 0; line-height: 1.6; }
  .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px; }
  .related-link { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .related-link:hover { border-color: #2563eb; }
  .related-link strong { color: #1e3a5f; font-size: 0.97rem; }
  .related-link span { color: #6b7280; font-size: 0.85rem; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 36px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.82rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem; }
  @media (max-width: 768px) { .hero__inner { grid-template-columns: 1fr; } .concept-grid { grid-template-columns: 1fr; } .section--cta { padding: 40px 20px; } }
</style>
