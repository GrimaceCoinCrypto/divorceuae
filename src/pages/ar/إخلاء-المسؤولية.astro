---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'إخلاء المسؤولية — DivorceU.AE';
const description = 'إخلاء المسؤولية القانونية لموقع DivorceU.AE — هذا الموقع خدمة إحالة وليس مكتب محاماة.';

const hreflang = {
  en: 'https://divorceu.ae/en/disclaimer',
  ar: 'https://divorceu.ae/ar/إخلاء-المسؤولية',
};

const breadcrumbs = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'إخلاء المسؤولية', url: 'https://divorceu.ae/ar/إخلاء-المسؤولية' },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
  noindex={true}
>
  <main class="container page">
    <Breadcrumb items={breadcrumbs} lang="ar" />

    <div class="content">
      <h1>إخلاء المسؤولية</h1>
      <p class="updated">آخر تحديث: أبريل 2025</p>

      <h2>1. ليس مكتب محاماة</h2>
      <p>
        DivorceU.AE هي خدمة إحالة ومعلومات قانونية. <strong>نحن لسنا مكتب محاماة</strong> ولا نوظّف محامين.
        لا نقدم مشورة قانونية أو تمثيلاً قانونياً أو خدمات قانونية من أي نوع بشكل مباشر.
      </p>
      <p>
        لا يُشكّل أي محتوى على هذا الموقع مشورة قانونية، ولا يُنشئ علاقة محامٍ-موكل بينك وبين
        DivorceU.AE أو أي محامٍ في شبكتنا.
      </p>

      <h2>2. لا علاقة محامٍ-موكل</h2>
      <p>
        لا يُنشئ تقديم طلب استشارة عبر هذا الموقع علاقة محامٍ-موكل بينك وبين DivorceU.AE أو بينك وبين
        أي محامٍ في شبكتنا، إلا بعد تعاقدك الرسمي مع ذلك المحامي وموافقته على تمثيلك.
      </p>

      <h2>3. دقة المعلومات</h2>
      <p>
        نبذل قصارى جهدنا لضمان دقة المعلومات الواردة في هذا الموقع وتحديثها وانتسابها إلى القانون الإماراتي.
        غير أن القوانين والأنظمة الإماراتية — بما في ذلك قوانين الأحوال الشخصية وإجراءات المحاكم — تتغير بمرور الوقت.
        لا نضمن أن تكون جميع المعلومات الواردة في هذا الموقع حديثة أو شاملة في أي وقت معين.
      </p>
      <p>
        يجب عليك دائماً التحقق من المعلومات القانونية مع محامٍ إماراتي مؤهل ومرخص قبل اتخاذ أي إجراء قانوني.
      </p>

      <h2>4. لا ضمان للنتائج</h2>
      <p>
        أي معلومات تتعلق بالجداول الزمنية النموذجية أو التكاليف أو نتائج إجراءات الطلاق في الإمارات
        مقدمة للإرشاد العام فقط. كل حالة مختلفة. لا تُقدّم DivorceU.AE أي ضمان صريح أو ضمني
        فيما يخص نتيجة أي قضية قانونية.
      </p>

      <h2>5. المحامون من أطراف ثالثة</h2>
      <p>
        المحامون ومكاتب المحاماة في شبكة إحالتنا متخصصون مستقلون. لا توظّفهم DivorceU.AE ولا تشرف
        على عملهم ولا تضمن جودة خدماتهم. بربطك بمحامٍ، لا نُوصي بأي نتيجة قانونية محددة أو مسار عمل.
      </p>
      <p>
        أي علاقة تعاقدية تنشأ بينك وبين المحامي المُحال إليه تكون حصراً بينك وبين ذلك المحامي.
        لا تتحمل DivorceU.AE أي مسؤولية عن مشورة أو أفعال أو إغفالات أي محامٍ مُحال إليه.
      </p>

      <h2>6. الروابط الخارجية</h2>
      <p>
        قد يحتوي هذا الموقع على روابط لمواقع خارجية. DivorceU.AE غير مسؤولة عن محتوى أو دقة أو
        ممارسات الخصوصية لأي موقع طرف ثالث. الروابط لا تُشكّل موافقة على تلك المواقع.
      </p>

      <h2>7. تحديد المسؤولية</h2>
      <p>
        بالقدر الأقصى المسموح به بموجب القانون الإماراتي، لن تكون DivorceU.AE أو مشغلوها أو شركاؤها
        مسؤولين عن أي أضرار مباشرة أو غير مباشرة أو عرضية أو تبعية أو عقابية ناشئة عن استخدامك
        لهذا الموقع أو اعتمادك على أي معلومات واردة فيه.
      </p>

      <h2>8. القانون الحاكم</h2>
      <p>
        يخضع هذا الإخلاء من المسؤولية لقوانين دولة الإمارات العربية المتحدة. تخضع أي نزاعات
        للاختصاص القضائي الحصري للمحاكم الإماراتية.
      </p>

      <h2>9. التواصل معنا</h2>
      <p>
        إذا كان لديك أي أسئلة حول هذا الإخلاء من المسؤولية أو المعلومات الواردة في هذا الموقع،
        يرجى التواصل معنا عبر <a href="/ar/#contact">نموذج الاستشارة</a> في الصفحة الرئيسية.
      </p>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceU.AE — خدمة إحالة قانونية. ليست مكتب محاماة. المعلومات المقدمة للإرشاد فقط ولا تشكل استشارة قانونية.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/سياسة-الخصوصية">سياسة الخصوصية</a>
        <a href="/ar/إخلاء-المسؤولية">إخلاء المسؤولية</a>
        <a href="/en/">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .page { padding: 60px 0 80px; }
  .content { max-width: 760px; }
  h1 { font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 800; color: #1e3a5f; margin-bottom: 8px; }
  .updated { color: #9ca3af; font-size: 0.875rem; margin-bottom: 48px; }
  h2 { font-size: 1.15rem; font-weight: 700; color: #1e3a5f; margin: 36px 0 12px; }
  p { color: #374151; line-height: 1.9; margin-bottom: 14px; }
  ul { margin: 0 0 16px 0; padding-right: 20px; padding-left: 0; }
  li { color: #374151; line-height: 1.7; margin-bottom: 6px; }
  a { color: #2563eb; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 40px 0; margin-top: 80px; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.85rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
  .footer nav a:hover { color: #fff; }
  @media (max-width: 768px) {
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
