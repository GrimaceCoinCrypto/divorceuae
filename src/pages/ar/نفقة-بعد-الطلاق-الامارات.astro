---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'النفقة بعد الطلاق في الإمارات — أنواعها وحسابها وحقوق المرأة ٢٠٢٥';
const description =
  'نفقة الطلاق في الإمارات: أنواع النفقة (العدة والأولاد والمتعة ومسكن الحضانة)، كيفية تحديدها أمام المحكمة، متى تسقط، وكيف تطالبين بها وفق قانون الأحوال الشخصية الإماراتي.';

const canonical = 'https://divorceu.ae/ar/نفقة-بعد-الطلاق-الامارات';

const hreflang = {
  en: 'https://divorceu.ae/en/alimony-uae',
  ar: canonical,
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'النفقة بعد الطلاق في الإمارات' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'ما هي أنواع النفقة التي تستحقها المرأة بعد الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تستحق المرأة المطلّقة في الإمارات: (١) نفقة العدة طوال فترة العدة، (٢) نفقة الأولاد إذا كانت حاضنة، (٣) مسكن الحضانة على نفقة الزوج، (٤) نفقة المتعة إذا كان الطلاق بغير سبب من جهتها. وتُحدَّد قيمة كل نوع وفق ظروف الزوجة ودخل الزوج بقرار قضائي.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم مدة نفقة العدة بعد الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تستمر نفقة العدة طوال مدة العدة الشرعية: ثلاثة أشهر قمرية (أو ثلاثة أطهار) للمطلّقة غير الحامل، وحتى الوضع إذا كانت حاملاً. وتشمل نفقة السكن والملبس والغذاء وما يحتاجه الحمل إن وُجد.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل تستحق المرأة نفقة المتعة حتى في حالة الخلع؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'لا. في حالة الخلع ترد المرأة المهر المقدَّم وتتنازل عادةً عن نفقة المتعة لأنها هي من طلبت الفسخ. أما نفقة العدة فتبقى واجبة حتى في الخلع. إذا كان الطلاق بإرادة الزوج وبدون سبب من جهة الزوجة فتستحق نفقة المتعة.',
      },
    },
    {
      '@type': 'Question',
      name: 'متى تسقط نفقة الأولاد في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تسقط نفقة الذكور ببلوغهم سن العمل (١٨–٢١ سنة عادةً) أو بزواجهم، وتسقط نفقة البنات بزواجهن. وتبقى النفقة قائمة إذا استمرت الدراسة أو ثبت عجز الولد عن الكسب. يجوز للمحكمة تمديد النفقة للدراسة الجامعية.',
      },
    },
  ],
};

const types = [
  {
    name: 'نفقة العدة',
    icon: '⏳',
    amount: 'بحسب دخل الزوج',
    duration: 'مدة العدة (٣ أشهر أو حتى الوضع)',
    detail: 'تجب لكل مطلّقة سواء كان الطلاق رجعياً أو بائناً. تشمل الغذاء والملبس والمسكن وما يلزم للحمل إن وُجد. لا تسقط إلا إذا كانت الزوجة هي التي نشزت (ثبت نشوزها قضائياً).',
    basis: 'المادة ٦٦–٦٧ من قانون الأحوال الشخصية الاتحادي',
  },
  {
    name: 'نفقة الأولاد',
    icon: '👨‍👩‍👧‍👦',
    amount: 'بحكم قضائي (نسبة من دخل الأب)',
    duration: 'حتى بلوغ الأولاد سن الاستقلال',
    detail: 'تجب على الأب بصرف النظر عن الحاضن (سواء كانت الأم أو الأب). تشمل المصاريف المدرسية والطبية والمعيشية. تُحدَّد المحكمة مبلغاً شهرياً بناءً على دخل الأب ومستوى معيشة الأسرة ومتطلبات الأولاد.',
    basis: 'المادة ٧٨–٨١ من قانون الأحوال الشخصية الاتحادي',
  },
  {
    name: 'مسكن الحضانة',
    icon: '🏠',
    amount: 'إيجار مناسب لوضع الأب',
    duration: 'طوال فترة الحضانة',
    detail: 'يلزم الأب بتوفير مسكن مناسب للحاضنة وأولاده. لا تُجبر الحاضنة على السكن في منزل الزوجية؛ يجوز للمحكمة إلزام الأب بدفع إيجار مستقل أو إتاحة وحدة سكنية مستقلة. يتوقف المبلغ على إمكانات الأب وموقع السكن.',
    basis: 'المادة ١٤٣–١٤٦ من قانون الأحوال الشخصية الاتحادي',
  },
  {
    name: 'نفقة المتعة',
    icon: '💰',
    amount: 'شهر إلى سنتين من النفقة (بحسب المحكمة)',
    duration: 'تُدفع دفعة واحدة أو على أقساط',
    detail: 'تجب للزوجة التي طُلِّقت بإرادة الزوج وبغير سبب من جهتها. تقديرها تقديري للقاضي بمراعاة مدة الزواج وحال الزوجين. لا تجب في الخلع ولا إذا ثبت نشوز الزوجة.',
    basis: 'المادة ١٤٠ من قانون الأحوال الشخصية الاتحادي',
  },
];

const faqItems = [
  {
    question: 'كيف أقدّم دعوى نفقة بعد الطلاق في الإمارات؟',
    answer: 'تُقدَّم دعوى النفقة أمام محكمة الأحوال الشخصية في إمارة إقامتك. تحتاجين إلى: شهادة الطلاق، وثائق إثبات الدخل للزوج (مذكرة راتب أو كشف حساب بنكي)، وثائق الأولاد إن وُجدوا. يُستحسن توكيل محامٍ متخصص في الأحوال الشخصية للحصول على أفضل تقدير للمبلغ. مدة إصدار الحكم الابتدائي: ٣–٦ أشهر في الغالب.',
  },
  {
    question: 'هل تستحق الزوجة الأجنبية غير المسلمة نفقة في الإمارات؟',
    answer: 'نعم، إذا كان الزواج محكوماً بالقانون الاتحادي الإماراتي (الأحوال الشخصية). تطبَّق نفس مبادئ النفقة على المقيمات الأجنبيات بصرف النظر عن الجنسية أو الديانة إذا قرر القاضي تطبيق القانون الإماراتي. إذا اخترت تطبيق قانون بلدك الأصلي قد تختلف الأحكام؛ استشيري محامياً.',
  },
  {
    question: 'ماذا يحدث إذا لم يدفع الزوج النفقة المحكوم بها؟',
    answer: 'إذا امتنع الزوج عن دفع النفقة الصادرة بها حكم قضائي، يمكن تقديم شكوى نفاذ (تنفيذ) للمحكمة. يجوز للمحكمة: تجميد أصوله وحساباته البنكية، الحجز على راتبه، ومنعه من السفر خارج الإمارات. التهرب من النفقة المحكوم بها قد يُعدّ جريمة جزائية في الإمارات.',
  },
  {
    question: 'هل يمكن زيادة مبلغ النفقة بعد صدور الحكم؟',
    answer: 'نعم. إذا تغيّرت ظروف الزوج المادية (ترقية، زيادة دخل) أو تغيّرت احتياجات الأولاد (دخول المدرسة، مصاريف طبية)، يمكن تقديم دعوى تعديل النفقة أمام المحكمة. يتعين إثبات التغيّر المادي في الظروف. كذلك يجوز خفض النفقة إذا ثبت انخفاض دخل الزوج الحقيقي.',
  },
  {
    question: 'هل تنتهي نفقة العدة إذا تزوجت المرأة من جديد؟',
    answer: 'نعم، تسقط نفقة العدة إذا انقضت العدة. أما نفقة الأولاد فلا تتأثر بزواج الأم من جديد لأنها واجبة على الأب بغض النظر عن حال الأم. مسكن الحضانة قد يُعاد النظر فيه إذا تزوجت الأم لأن ذلك يؤثر على ظروف الحضانة.',
  },
];
---

<BaseLayout
  {title}
  {description}
  {canonical}
  {hreflang}
  lang="ar"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumb items={breadcrumbItems} />
  </div>

  <section class="hero-section">
    <div class="hero-inner">
      <p class="hero-tag">دليل الطلاق · الإمارات ٢٠٢٥</p>
      <h1>{title}</h1>
      <p class="hero-desc">
        النفقة بعد الطلاق في الإمارات حق مكفول قانوناً وفق قانون الأحوال الشخصية الاتحادي رقم ٢٨ لعام ٢٠٠٥. تشمل نفقة العدة ونفقة الأولاد ومسكن الحضانة ونفقة المتعة — وكل منها له شروطه وطريقة حسابه.
      </p>
      <p class="hero-author">بقلم <strong>ألكسي سوونينن</strong> · مستشار قانوني ومقيم في الإمارات · divorceu.ae</p>
    </div>
  </section>

  <div class="page-layout">
    <main class="main-content">

      <div class="answer-box">
        <h2>ما النفقة التي تستحقينها بعد الطلاق؟</h2>
        <p>
          تستحق الزوجة المطلّقة في الإمارات حسب ظروفها: <strong>نفقة العدة</strong> (٣ أشهر أو حتى الوضع)، <strong>نفقة الأولاد ومسكنهم</strong> إذا كانت حاضنة، و<strong>نفقة المتعة</strong> إذا طلّقها الزوج بغير سبب.
          تُقدَّر المحكمة المبالغ استناداً إلى دخل الزوج واحتياجات الأسرة.
          يمكن تقديم دعوى نفقة مستقلة أو ضمن دعوى الطلاق أمام <strong>محكمة الأحوال الشخصية</strong>.
        </p>
      </div>

      <section class="content-section">
        <h2>أنواع النفقة بعد الطلاق في الإمارات</h2>
        <div class="types-list">
          {types.map(t => (
            <div class="type-card">
              <div class="type-header">
                <span class="type-icon">{t.icon}</span>
                <div>
                  <h3 class="type-name">{t.name}</h3>
                  <div class="type-meta">
                    <span class="meta-tag amount">{t.amount}</span>
                    <span class="meta-tag duration">{t.duration}</span>
                  </div>
                </div>
              </div>
              <p class="type-detail">{t.detail}</p>
              <p class="type-basis">{t.basis}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>كيف تُحسب النفقة في محاكم الإمارات؟</h2>
        <div class="factors-list">
          <div class="factor-item">
            <h3>دخل الزوج</h3>
            <p>العامل الأساسي. تطلب المحكمة عادةً مذكرة الراتب أو كشف الحساب البنكي. يُراعى الدخل الفعلي لا المُعلَن فقط — يُمكن للقاضي تقدير الدخل الحقيقي إذا اشتُبه بإخفائه.</p>
          </div>
          <div class="factor-item">
            <h3>مستوى معيشة الأسرة قبل الطلاق</h3>
            <p>تُراعى المحكمة الوضع المعيشي الذي اعتاد عليه الأولاد والزوجة. الإبقاء على مستوى معيشة مناسب يُعدّ معياراً قانونياً وليس تقديرياً فحسب.</p>
          </div>
          <div class="factor-item">
            <h3>عدد الأولاد وأعمارهم واحتياجاتهم</h3>
            <p>نفقة الرضيع تختلف عن نفقة الطالب الجامعي. المصاريف الدراسية والطبية والأنشطة تُحتسب ضمن نفقة الأولاد إذا كان مستواها متناسباً مع وضع الأب.</p>
          </div>
          <div class="factor-item">
            <h3>حال الزوجة</h3>
            <p>يُراعى القاضي وضع الزوجة الصحي وقدرتها على العمل. الزوجة العاملة لا تسقط نفقتها لمجرد ذلك، لكن دخلها قد يُؤخذ في الاعتبار عند تقدير المتعة.</p>
          </div>
        </div>
      </section>

      <FAQSection items={faqItems} />

      <section class="content-section">
        <h2>روابط ذات صلة</h2>
        <div class="related-grid">
          <a href="/ar/حقوق-الزوجة-بعد-الطلاق-الامارات" class="related-card">
            <strong>حقوق الزوجة بعد الطلاق</strong>
            <span>المهر والسكن والحضانة وتأشيرة الإقامة</span>
          </a>
          <a href="/ar/حضانة-الاطفال-الامارات" class="related-card">
            <strong>حضانة الأطفال في الإمارات</strong>
            <span>قواعد الحضانة للمسلمين وغير المسلمين</span>
          </a>
          <a href="/ar/الطلاق-في-الامارات" class="related-card">
            <strong>الطلاق في الإمارات</strong>
            <span>دليل شامل لأحكام الطلاق في الإمارات</span>
          </a>
          <a href="/ar/قانون-الطلاق-في-الامارات" class="related-card">
            <strong>قانون الطلاق في الإمارات</strong>
            <span>نص القانون الاتحادي وأبرز أحكامه</span>
          </a>
        </div>
      </section>

    </main>

    <aside class="sidebar">
      <div class="sidebar-sticky">
        <LeadForm />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .hero-section { background: #0a1628; color: #fff; padding: 3rem 1rem; }
  .hero-inner { max-width: 52rem; margin: 0 auto; }
  .hero-tag { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #c9a84c; margin-bottom: 0.75rem; }
  h1 { font-size: clamp(1.6rem, 3.5vw, 2.4rem); font-weight: 800; line-height: 1.3; margin-bottom: 1rem; }
  .hero-desc { font-size: 1.05rem; color: #d1d5db; line-height: 1.9; margin-bottom: 0.75rem; }
  .hero-author { font-size: 0.85rem; color: #9ca3af; }
  .hero-author strong { color: #fff; }

  .page-layout { max-width: 72rem; margin: 0 auto; padding: 2rem 1rem; display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; align-items: start; }
  .main-content { min-width: 0; }
  .sidebar-sticky { position: sticky; top: 1.5rem; }

  .answer-box { background: #f0fdf4; border-right: 4px solid #16a34a; border-left: none; padding: 1.25rem 1.5rem; border-radius: 12px 0 0 12px; margin-bottom: 2rem; }
  .answer-box h2 { font-size: 1.1rem; font-weight: 700; color: #064e3b; margin: 0 0 0.5rem; }
  .answer-box p { color: #1f2937; line-height: 1.9; margin: 0; font-size: 0.97rem; }
  .answer-box strong { color: #064e3b; }

  .content-section { margin-bottom: 2.5rem; }
  .content-section h2 { font-size: clamp(1.2rem, 2.5vw, 1.6rem); font-weight: 700; color: #0a1628; margin-bottom: 1rem; border-bottom: 2px solid #f3f4f6; padding-bottom: 0.5rem; }

  .types-list { display: flex; flex-direction: column; gap: 1rem; }
  .type-card { border: 1.5px solid #e5e7eb; border-radius: 12px; padding: 1.25rem; background: #fff; }
  .type-header { display: flex; gap: 0.75rem; align-items: flex-start; margin-bottom: 0.75rem; }
  .type-icon { font-size: 1.5rem; flex-shrink: 0; }
  .type-name { font-size: 1.05rem; font-weight: 700; color: #0a1628; margin: 0 0 6px; }
  .type-meta { display: flex; gap: 0.4rem; flex-wrap: wrap; }
  .meta-tag { font-size: 0.72rem; font-weight: 600; padding: 3px 8px; border-radius: 20px; }
  .meta-tag.amount { background: #fef3c7; color: #92400e; }
  .meta-tag.duration { background: #e0f2fe; color: #075985; }
  .type-detail { font-size: 0.87rem; color: #374151; line-height: 1.8; margin: 0 0 0.4rem; }
  .type-basis { font-size: 0.75rem; color: #9ca3af; margin: 0; font-style: italic; }

  .factors-list { display: flex; flex-direction: column; gap: 1rem; }
  .factor-item { border-right: 4px solid #c9a84c; padding: 1rem 1rem 1rem 0.75rem; background: #fffbeb; border-radius: 0 10px 10px 0; }
  .factor-item h3 { font-size: 0.92rem; font-weight: 700; color: #0a1628; margin: 0 0 0.35rem; }
  .factor-item p { font-size: 0.85rem; color: #4b5563; line-height: 1.75; margin: 0; }

  .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .related-card { display: flex; flex-direction: column; gap: 4px; padding: 1rem; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 8px; text-decoration: none; transition: border-color 0.2s; }
  .related-card:hover { border-color: #c9a84c; }
  .related-card strong { color: #0a1628; font-size: 0.9rem; }
  .related-card span { color: #6b7280; font-size: 0.78rem; }

  @media (max-width: 900px) {
    .page-layout { grid-template-columns: 1fr; }
    .sidebar { order: -1; }
  }
  @media (max-width: 640px) {
    .related-grid { grid-template-columns: 1fr; }
  }
</style>
