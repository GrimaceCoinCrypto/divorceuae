---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'محامي طلاق في أبوظبي — استشارة قانونية مجانية | DivorceUAE';
const description =
  'تواصل مع محامي طلاق متخصص في أبوظبي. خبرة في محكمة الأحوال الشخصية أبوظبي، قضايا الطلاق بالتراضي والخلع والحضانة. مرخّص من وزارة العدل. استشارة مجانية.';

const canonical = 'https://divorceu.ae/ar/محامي-طلاق-ابوظبي';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-lawyer-abu-dhabi',
  ar: 'https://divorceu.ae/ar/محامي-طلاق-ابوظبي',
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'محامي طلاق', url: 'https://divorceu.ae/ar/محامي-طلاق' },
  { name: 'محامي طلاق في أبوظبي' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'أين تقع محكمة الأحوال الشخصية في أبوظبي؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تقع محكمة الأحوال الشخصية في أبوظبي في مبنى قصر العدل. يمكن تسجيل القضايا إلكترونياً عبر بوابة أبوظبي للخدمات القضائية، غير أن الحضور الشخصي مطلوب لجلسات الاستماع.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل تختلف إجراءات الطلاق في أبوظبي عن دبي؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'الإطار القانوني واحد — قانون الأحوال الشخصية الاتحادي — لكن محاكم أبوظبي لها إجراءاتها الخاصة وجداولها الزمنية المختلفة. ينصح باختيار محامٍ لديه خبرة تحديداً في محكمة الأحوال الشخصية بأبوظبي.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم يستغرق الطلاق في أبوظبي؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'الطلاق بالتراضي في أبوظبي يستغرق عادةً 1–3 أشهر. الطلاق المتنازع عليه يستغرق 6–18 شهراً حسب تعقيد القضية.',
      },
    },
  ],
};

const faqItems = [
  {
    question: 'أين تقع محكمة الأحوال الشخصية في أبوظبي؟',
    answer: 'تقع في مبنى <strong>قصر العدل</strong> في أبوظبي. يمكن تسجيل القضايا إلكترونياً عبر بوابة الخدمات القضائية، لكن الحضور الشخصي مطلوب للجلسات.',
  },
  {
    question: 'هل تختلف إجراءات الطلاق في أبوظبي عن دبي؟',
    answer: 'القانون الاتحادي واحد، لكن لكل محكمة إجراءاتها وجداولها الزمنية. يُنصح باختيار محامٍ متخصص في محكمة الأحوال الشخصية بأبوظبي تحديداً.',
  },
  {
    question: 'كم يستغرق الطلاق في أبوظبي؟',
    answer: 'الطلاق بالتراضي يستغرق <strong>1–3 أشهر</strong>. الطلاق المتنازع عليه يستغرق 6–18 شهراً.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
  schema={faqSchema}
>
  <main>
    <header class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <Breadcrumb items={breadcrumbItems} lang="ar" />
          <h1 class="hero__h1">
            محامي طلاق في أبوظبي —<br />
            خبرة في محكمة الأحوال الشخصية
          </h1>
          <p class="hero__sub">
            نُوفّر لك أفضل محامي طلاق في أبوظبي مرخّصين ومتخصصين في محكمة الأحوال الشخصية.
            سواء كنت تبحث عن طلاق بالتراضي أو طلاق متنازع عليه أو خلع أو حضانة —
            نُطابقك مع المحامي المناسب لقضيتك. استشارة أولى مجانية.
          </p>
          <ul class="hero__trust">
            <li>✓ مرخّصون من وزارة العدل الإماراتية</li>
            <li>✓ خبرة في محاكم أبوظبي</li>
            <li>✓ دعم كامل باللغة العربية</li>
            <li>✓ استشارة أولى مجانية</li>
          </ul>
        </div>
        <div class="hero__form">
          <LeadForm lang="ar" variant="hero" heading="تواصل مع محامي طلاق أبوظبي الآن" />
        </div>
      </div>
    </header>

    <div class="container">

      <section class="section" aria-labelledby="court-heading">
        <h2 id="court-heading">محكمة الأحوال الشخصية أبوظبي — ما تحتاج معرفته</h2>
        <p>
          تنظر محكمة الأحوال الشخصية في أبوظبي في جميع قضايا الطلاق والحضانة والنفقة للمقيمين
          في إمارة أبوظبي وتوابعها كالعين والظفرة. تعمل وفق قانون الأحوال الشخصية الاتحادي
          رقم 28 لسنة 2005 مع تعديلات 2022 للمقيمين غير المسلمين.
        </p>

        <h3>الفرق بين محاكم أبوظبي ودبي</h3>
        <p>
          رغم أن القانون الاتحادي واحد في كلا الإمارتين، تختلف الجداول الزمنية وأسلوب إدارة
          القضايا بين محاكم أبوظبي ودبي. محامٍ معتاد على إجراءات محكمة أبوظبي تحديداً
          يُوفّر وقتاً وجهداً كبيرَين.
        </p>

        <h3>خطوات الطلاق في أبوظبي</h3>
        <ol class="steps">
          <li>
            <h3>استشارة محامٍ متخصص في أبوظبي</h3>
            <p>قبل أي إجراء، تأكّد أن محاميك على دراية بإجراءات محكمة الأحوال الشخصية في أبوظبي تحديداً.</p>
          </li>
          <li>
            <h3>تجميع المستندات وتقديم الدعوى</h3>
            <p>عقد الزواج الموثّق، جوازات السفر، بطاقة الهوية الإماراتية، إثبات الإقامة في أبوظبي.</p>
          </li>
          <li>
            <h3>جلسة المصالحة الإلزامية</h3>
            <p>مستشار اجتماعي معيّن من المحكمة يجتمع بالطرفين. إن فشلت المصالحة تنتقل القضية للقاضي.</p>
          </li>
          <li>
            <h3>جلسات الاستماع وصدور الحكم</h3>
            <p>للطلاق بالتراضي جلسة واحدة في الغالب. للمتنازع عليه جلسات متعددة حتى صدور الحكم النهائي.</p>
          </li>
        </ol>
      </section>

      <section class="section" aria-labelledby="services-heading">
        <h2 id="services-heading">خدمات محامي الطلاق في أبوظبي</h2>
        <div class="service-grid">
          <div class="service-card">
            <h3>الطلاق بالتراضي</h3>
            <p>إعداد اتفاق الطلاق المشترك وتقديمه بصورة تحمي حقوق الطرفين قانونياً.</p>
          </div>
          <div class="service-card">
            <h3>الطلاق المتنازع عليه</h3>
            <p>التمثيل الكامل في جلسات الاستماع والدفاع عن موقفك في شأن الحضانة والنفقة والأصول.</p>
          </div>
          <div class="service-card">
            <h3>الخلع</h3>
            <p>رفع دعوى الخلع وإدارة مفاوضات استرداد المهر وضمان صدور الحكم سريعاً.</p>
          </div>
          <div class="service-card">
            <h3>حضانة الأطفال</h3>
            <p>التفاوض على ترتيبات الحضانة وحق الزيارة في ضوء مصلحة الطفل الفضلى.</p>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="costs-heading">
        <h2 id="costs-heading">تكاليف الطلاق في أبوظبي</h2>
        <p>فيما يلي تقدير واقعي لتكاليف الطلاق أمام محاكم أبوظبي:</p>
        <div class="cost-table-wrapper">
          <table class="cost-table">
            <thead>
              <tr><th>نوع القضية</th><th>أتعاب المحامي</th><th>رسوم المحكمة</th><th>المدة الزمنية</th></tr>
            </thead>
            <tbody>
              <tr><td><strong>طلاق بالتراضي</strong></td><td>5,000–15,000 درهم</td><td>600–1,500 درهم</td><td>1–3 أشهر</td></tr>
              <tr><td><strong>طلاق متنازع عليه</strong></td><td>15,000–40,000+ درهم</td><td>1,000–2,500 درهم</td><td>6–18 شهراً</td></tr>
              <tr><td><strong>الخلع</strong></td><td>6,000–15,000 درهم</td><td>600–1,500 درهم</td><td>2–4 أشهر</td></tr>
              <tr><td><strong>نزاع حضانة فقط</strong></td><td>8,000–25,000 درهم</td><td>500–1,500 درهم</td><td>3–12 شهراً</td></tr>
            </tbody>
          </table>
        </div>
        <p class="table-note">الأرقام تقديرية. ترجمة المستندات وتصديقها: 500–2,000 درهم إضافية. الاستشارة الأولى مجانية.</p>
      </section>

      <section class="section" aria-labelledby="related-heading">
        <h2 id="related-heading">أدلة قانونية ذات صلة</h2>
        <div class="related-links">
          <a href="/ar/محامي-طلاق" class="related-link">
            <strong>محامي طلاق في الإمارات</strong>
            <span>دليل شامل لاختيار المحامي</span>
          </a>
          <a href="/ar/محامي-طلاق-دبي" class="related-link">
            <strong>محامي طلاق في دبي</strong>
            <span>خدمات الطلاق في دبي</span>
          </a>
          <a href="/ar/حضانة-الاطفال-الامارات" class="related-link">
            <strong>حضانة الأطفال في الإمارات</strong>
            <span>حقوقك القانونية كاملةً</span>
          </a>
          <a href="/ar/كيفية-تقديم-الطلاق-في-الامارات" class="related-link">
            <strong>إجراءات الطلاق في الإمارات</strong>
            <span>خطوة بخطوة من التقديم للحكم</span>
          </a>
        </div>
      </section>

      <FAQSection items={faqItems} lang="ar" />

      <section class="section section--cta" id="contact" aria-labelledby="cta-heading">
        <h2 id="cta-heading">تواصل مع محامي طلاق في أبوظبي — مجاناً</h2>
        <p>نُطابق حالتك مع محامٍ متخصص في محاكم أبوظبي خلال 24 ساعة.</p>
        <LeadForm lang="ar" variant="inline" />
      </section>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceU.AE — خدمة إحالة قانونية. ليست مكتب محاماة.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/محامي-طلاق">محامي طلاق الإمارات</a>
        <a href="/en/divorce-lawyer-dubai">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 60px 0 50px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.7rem, 3.5vw, 2.6rem); font-weight: 800; line-height: 1.35; margin-bottom: 16px; }
  .hero__sub { font-size: 1.02rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.9; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.88rem; }
  .hero__trust li { opacity: 0.9; }
  .section { padding: 56px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.35rem, 2.8vw, 1.85rem); font-weight: 700; color: #1e3a5f; margin-bottom: 18px; }
  .section h3 { font-size: 1.05rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 2; margin-bottom: 14px; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 56px 40px; margin-bottom: 60px; text-align: center; }
  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 20px; margin-top: 20px; }
  .steps li { counter-increment: steps; padding: 22px 70px 22px 22px; position: relative; background: #f8faff; border-radius: 12px; border-right: 4px solid #2563eb; }
  .steps li::after { content: counter(steps); position: absolute; right: 18px; top: 22px; width: 34px; height: 34px; background: #2563eb; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; }
  .steps li h3 { font-size: 1rem; font-weight: 700; color: #1e3a5f; margin: 0 0 6px; }
  .steps li p { font-size: 0.9rem; color: #374151; margin: 0; line-height: 1.7; }
  .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 24px; }
  .service-card { padding: 22px; background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; }
  .service-card h3 { font-size: 0.97rem; font-weight: 700; color: #1e3a5f; margin: 0 0 8px; }
  .service-card p { font-size: 0.9rem; color: #6b7280; margin: 0; line-height: 1.7; }
  .cost-table-wrapper { overflow-x: auto; margin: 20px 0; }
  .cost-table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
  .cost-table th { background: #1e3a5f; color: #fff; padding: 11px 14px; text-align: right; font-weight: 600; }
  .cost-table td { padding: 10px 14px; border-bottom: 1px solid #e5e7eb; color: #374151; text-align: right; }
  .cost-table tr:nth-child(even) td { background: #f8faff; }
  .table-note { font-size: 0.8rem; color: #9ca3af; margin: 8px 0 0; }
  .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px; }
  .related-link { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .related-link:hover { border-color: #2563eb; }
  .related-link strong { color: #1e3a5f; font-size: 0.97rem; }
  .related-link span { color: #6b7280; font-size: 0.85rem; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 36px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.82rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem; }
  @media (max-width: 768px) { .hero__inner { grid-template-columns: 1fr; } .section--cta { padding: 40px 20px; } }
</style>
