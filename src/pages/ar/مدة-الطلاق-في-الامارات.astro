---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'كم يستغرق الطلاق في الإمارات ٢٠٢٥ — المدة حسب نوع القضية';
const description =
  'كم يستغرق الطلاق في الإمارات؟ دليل شامل لمدة الطلاق بالتراضي والطلاق الخلافي وقضايا الحضانة — مرحلة بمرحلة من تقديم الطلب حتى صدور الحكم، مع أسباب التأخير وكيفية تفاديها.';

const canonical = 'https://divorceu.ae/ar/مدة-الطلاق-في-الامارات';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-timeline-uae',
  ar: canonical,
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'مدة الطلاق في الإمارات' },
];

const timelineCards = [
  { type: 'الطلاق بالتراضي', duration: '١–٣ أشهر', cost: '٤,٠٠٠–١٠,٠٠٠ درهم', hearings: '١–٢', note: 'كلا الطرفين يتفقان على جميع الشروط قبل التقدم بالطلب. الطريق الأسرع للحصول على الحكم.' },
  { type: 'طلاق خلافي — بدون أطفال', duration: '٦–١٢ شهراً', cost: '١٠,٠٠٠–٢٥,٠٠٠ درهم', hearings: '٤–٨', note: 'نزاعات على النفقة أو الأصول. قد يتطلب تقييماً مالياً متخصصاً.' },
  { type: 'طلاق خلافي — مع نزاع على الحضانة', duration: '١٢–٢٤ شهراً', cost: '٢٠,٠٠٠–٦٠,٠٠٠ درهم+', hearings: '٨–١٥+', note: 'تقارير الرعاية الاجتماعية وشهادات الخبراء والتأجيلات المتعددة شائعة.' },
  { type: 'الخلع (بطلب من الزوجة)', duration: '٢–٦ أشهر', cost: '٥,٠٠٠–١٥,٠٠٠ درهم', hearings: '٢–٤', note: 'أسرع إذا وافق الزوج. الخلع الخلافي قد يمتد إلى ٩–١٢ شهراً.' },
  { type: 'طلاق مدني لغير المسلمين', duration: '١–٤ أشهر', cost: '٣,٥٠٠–١٢,٠٠٠ درهم', hearings: '١–٣', note: 'طلاق مدني دون إثبات ذنب لغير المسلمين بموجب المرسوم بقانون رقم ٤١ لعام ٢٠٢٢.' },
];

const stages = [
  {
    num: 1,
    title: 'جلسة التوجيه الأسري / المصالحة',
    duration: '٢–٦ أسابيع من تقديم الطلب',
    desc: 'تمر جميع قضايا الطلاق في الإمارات بمرحلة التوجيه الأسري الإلزامية. يسعى المختص إلى الإصلاح بين الزوجين؛ فإن فشل أصدر شهادة تُجيز المضي في الإجراءات القضائية. في دبي تتولى هذا الدور إدارة الخدمات الاجتماعية في محاكم دبي، وفي أبوظبي يقوم به دائرة القضاء. في القضايا الخلافية قد تُعقد من جلسة إلى أربع جلسات.',
  },
  {
    num: 2,
    title: 'الجلسة الأولى أمام المحكمة',
    duration: '٤–٨ أسابيع بعد التوجيه الأسري',
    desc: 'يستعرض القاضي صحيفة الدعوى ويتأكد من تمثيل الطرفين، ثم يحدد جدولاً إجرائياً للقضية. في الطلاق بالتراضي قد يُصدر الحكم في هذه الجلسة أو يحددها للتأكيد فحسب. أما القضايا الخلافية فتنتقل إلى مرحلة تبادل المستندات والأدلة.',
  },
  {
    num: 3,
    title: 'تبادل المستندات وتقارير الخبراء',
    duration: '٢–٦ أشهر (القضايا الخلافية فقط)',
    desc: 'يقدم كل طرف مستنداته من كشوفات مالية وشهادات شهود وتقييمات عقارية. إذا كان هناك أطفال، قد تُعيّن المحكمة أخصائياً اجتماعياً أو نفسياً لإعداد تقرير رعاية. هذه المرحلة هي المسبب الرئيسي للتأخير في القضايا الخلافية.',
  },
  {
    num: 4,
    title: 'الجلسات والمرافعات',
    duration: 'متكررة — ١–٢ جلسة شهرياً',
    desc: 'تُحدد المحكمة جلسات دورية. التأجيلات بسبب نقص المستندات أو غياب أحد الطرفين أو طلب أدلة إضافية شائعة وتضيف ٣–٦ أسابيع لكل منها. المحامون المتمرسون يقللون التأجيلات بإعداد كامل المستندات قبل كل جلسة.',
  },
  {
    num: 5,
    title: 'صدور الحكم',
    duration: '١–٤ أسابيع بعد الجلسة الأخيرة',
    desc: 'يُصدر القاضي حكماً مكتوباً. في قضايا التراضي يصدر الحكم عادةً في جلسة الختام نفسها. في القضايا الخلافية قد يحجز القاضي الحكم ليُصدره في جلسة مستقلة. لكل طرف الحق في الطعن خلال ٣٠ يوماً.',
  },
  {
    num: 6,
    title: 'إصدار وثيقة الطلاق',
    duration: '١–٣ أسابيع بعد الحكم النهائي',
    desc: 'بمجرد صيرورة الحكم نهائياً — بانقضاء مهلة الطعن أو تنازل الطرفين عنها — تُصدر المحكمة وثيقة الطلاق الرسمية. هذه الوثيقة ضرورية لإجراءات الإقامة وتغيير الاسم والزواج مجدداً وتحديث السجلات في بلد المنشأ.',
  },
];

const delayFactors = [
  { factor: 'مستندات ناقصة أو غير مصادق عليها', impact: '+٣–٨ أسابيع لكل حادثة', tip: 'احرص على ترجمة جميع وثائقك والمصادقة عليها قبل أول جلسة.' },
  { factor: 'غياب أحد الطرفين عن الجلسة', impact: '+٣–٦ أسابيع لكل غياب', tip: 'يجب حضور كلا الطرفين أو تمثيلهما في كل موعد محدد.' },
  { factor: 'تقرير خبير يأمر به القاضي', impact: '+٦–١٦ أسبوعاً', tip: 'شائع في نزاعات الحضانة. الاتفاق على الحضانة قبل رفع الدعوى يُجنّب هذا التأخير.' },
  { factor: 'الطعن في الحكم بعد صدوره', impact: '+٣–٦ أشهر', tip: 'مهلة الطعن ٣٠ يوماً. إذا تنازل الطرفان تصبح الوثيقة نهائية فوراً.' },
  { factor: 'النزاع على الإفصاح المالي', impact: '+٢–٤ أشهر', tip: 'أعدّ جدولاً شاملاً للأصول مع محاميك قبل بدء الإجراءات.' },
];

const emirateDiffs = [
  { emirate: 'دبي', typical: '١–٣ أشهر (بالتراضي)', note: 'أعلى حجم قضايا في الإمارات. جلسات التوجيه الأسري تُحدد أحياناً في غضون ٢–٣ أسابيع. المحاكم مجهزة جيداً للتعامل مع قضايا الطلاق المدني لغير المسلمين بعد إصلاحات ٢٠٢٢.' },
  { emirate: 'أبوظبي', typical: '٢–٤ أشهر (بالتراضي)', note: 'متوسط مدة القضايا الخلافية أطول قليلاً. الاعتماد على تقارير خبراء الرعاية أعلى في قضايا حضانة المواطنين.' },
  { emirate: 'الشارقة', typical: '٢–٥ أشهر (بالتراضي)', note: 'عملية المصالحة أكثر نشاطاً؛ قد تُحدد المحاكم عدة جلسات توجيه أسري قبل الشروع في إجراءات التقاضي.' },
  { emirate: 'الإمارات الشمالية', typical: '٢–٤ أشهر (بالتراضي)', note: 'عدد القضايا أقل مما قد يُتيح تحديد مواعيد أسرع، غير أن القضايا المعقدة قد تستغرق وقتاً أطول لقِلة القضاة المتخصصين.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'كم يستغرق الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'يستغرق الطلاق بالتراضي في الإمارات عادةً ١–٣ أشهر من تقديم الطلب حتى صدور الحكم النهائي. أما الطلاق الخلافي بدون نزاع على الحضانة فيمتد ٦–١٢ شهراً. وتُعدّ قضايا الحضانة الأطول، إذ تستغرق في العادة ١٢–٢٤ شهراً. أهم متغير هو ما إذا كان الطرفان متفقَين على جميع الشروط قبل التقدم بالطلب.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم تستغرق مدة الطلاق بالتراضي في دبي؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'يستغرق الطلاق بالتراضي المُعدّ جيداً في دبي عادةً ٤–١٢ أسبوعاً من تاريخ تقديم الطلب الأول حتى صدور الحكم. يشمل ذلك جلسة التوجيه الأسري الإلزامية (٢–٤ أسابيع) إضافةً إلى ١–٢ جلستَين قضائيتين. إعداد جميع المستندات مترجمةً ومصادقاً عليها قبل التقدم هو أفضل وسيلة لتقليص المدة الإجمالية.',
      },
    },
    {
      '@type': 'Question',
      name: 'ما أسباب تأخر الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'أكثر أسباب التأخير شيوعاً هي: نقص المستندات أو عدم مصادقتها، والتأجيلات بسبب غياب أحد الطرفين، والنزاعات التي تستلزم تقارير خبراء (تقييمات مالية أو تقارير رعاية)، والطعن في الحكم بعد صدوره. كل تأجيل يُضيف ٣–٦ أسابيع في المعدل. المحامي المتمرس يُقلل التأجيلات بالاستعداد الكامل لكل مرحلة.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل يمكن إتمام الطلاق في الإمارات بجلسة واحدة؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'لا يمكن الاستغناء كلياً عن الإجراءات القضائية، غير أن الطلاق بالتراضي المُعدّ جيداً يُمكن إنجازه في ١–٢ جلستين. يجب أولاً إتمام جلسة التوجيه الأسري الإلزامية. إذا قدّم الزوجان اتفاقية فراق موقعة تتضمن الحضانة والنفقة والممتلكات، فإن الجلسة القضائية تكون عادةً مختصرة — ٣٠–٦٠ دقيقة في القضايا غير الخلافية.',
      },
    },
    {
      '@type': 'Question',
      name: 'كم هي مدة العدة بعد الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'وفق قانون الأحوال الشخصية الإماراتي، تعتد المرأة المسلمة المطلقة ثلاثة قروء (نحو ثلاثة أشهر) قبل أن يحق لها الزواج مجدداً. أما الرجل المسلم فيجوز له الزواج فور صدور الحكم. وتخضع المرأة غير المسلمة لقانون بلدها في مسألة فترة الانتظار قبل الزواج، مع اشتراط الحصول على وثيقة الطلاق الإماراتية الرسمية.',
      },
    },
    {
      '@type': 'Question',
      name: 'ماذا يحدث للإقامة إذا كانت مرتبطة بكفالة الزوج؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'إذا كانت إقامتك مرتبطة بكفالة زوجك، فأمامك ٣٠ يوماً من تاريخ صدور حكم الطلاق لترتيب وضعك القانوني. الخيارات تشمل: الانتقال إلى كفالة صاحب العمل، أو تأشيرة المستثمر/المستقل، أو تأشيرة الوالدين إذا كان الأطفال من مواطني الإمارات. خطط لذلك قبل الجلسة الأخيرة وليس بعدها.',
      },
    },
  ],
};

const faqItems = faqSchema.mainEntity.map((q) => ({
  question: q.name,
  answer: q.acceptedAnswer.text,
}));
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ar"
  hreflang={hreflang}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Breadcrumb items={breadcrumbItems} />

  <section class="hero-section">
    <div class="container">
      <p class="overline">دليل الطلاق في الإمارات · ٢٠٢٥</p>
      <h1>كم يستغرق الطلاق في الإمارات؟ — المدة الكاملة حسب نوع القضية</h1>
      <p class="hero-sub">من جلسات التوجيه الأسري الإلزامية حتى صدور الحكم النهائي — دليل مرحلة بمرحلة لكل أنواع الطلاق في الإمارات، مع أبرز أسباب التأخير وكيفية تجنبها.</p>
      <div class="hero-meta">
        <span>تحديث: مايو ٢٠٢٥</span>
        <span class="sep">·</span>
        <span>بقلم أليكسي سوونينن، مستشار قانوني ومقيم في الإمارات</span>
      </div>
    </div>
  </section>

  <main class="main-content">
    <div class="container">

      <div class="highlight-box">
        <h2>مدة الطلاق في الإمارات — مرجع سريع</h2>
        <div class="timeline-cards">
          {timelineCards.map(c => (
            <div class="tl-card">
              <div class="tl-type">{c.type}</div>
              <div class="tl-duration">{c.duration}</div>
              <div class="tl-meta">
                <span>{c.hearings} جلسات</span>
                <span class="sep">·</span>
                <span>{c.cost}</span>
              </div>
              <div class="tl-note">{c.note}</div>
            </div>
          ))}
        </div>
      </div>

      <section class="content-section">
        <h2>مراحل الطلاق في الإمارات — ماذا يحدث في كل خطوة؟</h2>
        <p>تمر جميع قضايا الطلاق في الإمارات بالتسلسل الإجرائي ذاته بصرف النظر عن نوعها. الفرق بين قضية تنتهي في ٦ أسابيع وأخرى تمتد سنتين يكمن تقريباً في ما يحدث في المرحلتين الثالثة والرابعة.</p>
        <div class="stages-list">
          {stages.map(s => (
            <div class="stage-card">
              <div class="stage-header">
                <div class="stage-num">{s.num}</div>
                <div class="stage-head-text">
                  <h3>{s.title}</h3>
                  <span class="stage-duration">{s.duration}</span>
                </div>
              </div>
              <p>{s.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>أسباب التأخير وكيفية تجنبها</h2>
        <p>معظم حالات تأخر إجراءات الطلاق في الإمارات قابلة للتفادي. الجدول أدناه يستعرض أبرز خمسة أسباب للتأخير وما يمكن فعله حيال كل منها.</p>
        <div class="delay-table">
          <div class="delay-header">
            <span>سبب التأخير</span>
            <span>الأثر المعتاد</span>
            <span>كيف تتجنبه</span>
          </div>
          {delayFactors.map(d => (
            <div class="delay-row">
              <span class="delay-factor">{d.factor}</span>
              <span class="delay-impact">{d.impact}</span>
              <span class="delay-tip">{d.tip}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>المدة حسب الإمارة</h2>
        <p>تُطبق جميع محاكم الإمارات قانون الأحوال الشخصية الاتحادي ذاته، غير أن أوقات المعالجة والإجراءات المحلية تتفاوت من إمارة إلى أخرى.</p>
        <div class="emirate-grid">
          {emirateDiffs.map(e => (
            <div class="emirate-card">
              <h3>{e.emirate}</h3>
              <div class="emirate-typical">{e.typical}</div>
              <p>{e.note}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>مدة الطلاق لغير المسلمين المقيمين في الإمارات</h2>
        <p>أحدث المرسوم بقانون اتحادي رقم ٤١ لعام ٢٠٢٢ تحولاً جوهرياً في منظومة الطلاق للوافدين غير المسلمين، وقلّص المدة تقليصاً ملموساً مقارنةً بالوضع السابق.</p>
        <div class="expat-box">
          <div class="expat-item">
            <span class="expat-label">طلاق بدون إثبات ذنب</span>
            <p>لم يعد غير المسلمين بحاجة إلى إثبات أسباب الطلاق. يحق لأي من الطرفين التقدم بطلب انفرادي دون تبرير.</p>
          </div>
          <div class="expat-item">
            <span class="expat-label">المدة المعتادة</span>
            <p>١–٤ أشهر للقضايا المباشرة. أسرع بكثير مما كان معمولاً به في ظل المنظومة القديمة التي كانت تُلزم بتطبيق قانون البلد الأصلي.</p>
          </div>
          <div class="expat-item">
            <span class="expat-label">الممتلكات والحضانة</span>
            <p>النزاعات على الممتلكات والحضانة لا تزال تُطيل المدة إلى ٦–١٨ شهراً. قانون ٢٠٢٢ لا يُلغي متطلبات الوساطة الأسرية.</p>
          </div>
          <div class="expat-item">
            <span class="expat-label">محاكم مركز دبي المالي</span>
            <p>للمقيمين ذوي الثروات الكبيرة الذين لديهم ارتباطات بمركز دبي المالي، تتيح محاكمه اختصاصاً بديلاً بموجب القانون العام يُعالج المسائل المالية في بعض الأحيان بشكل أسرع.</p>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>أثر مدة الطلاق على الإقامة</h2>
        <p>إذا كانت تأشيرة إقامتك مرتبطة بكفالة زوجك، فالمهلة تبدأ من يوم صدور حكم الطلاق. لديك <strong>٣٠ يوماً</strong> فقط لترتيب وضعك القانوني.</p>
        <p>هذا يعني أنه في قضايا الطلاق الخلافي التي لا يمكن التنبؤ بموعد صدور حكمها، عليك الاستعداد لتأشيرة بديلة قبل الجلسة الأخيرة وليس بعدها. اطلع على دليلنا الكامل: <a href="/ar/الطلاق-في-الامارات">الطلاق في الإمارات — دليل المقيمين الأجانب</a>.</p>
      </section>

      <section class="content-section">
        <h2>الأسئلة الشائعة</h2>
        <FAQSection items={faqItems} />
      </section>

      <div class="cta-box">
        <h2>قلق من طول مدة قضيتك؟ استشر محامياً متخصصاً</h2>
