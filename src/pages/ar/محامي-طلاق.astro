---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'محامي طلاق في الإمارات — استشارة مجانية | DivorceUAE';
const description =
  'تواصل مع أفضل محامي طلاق معتمد في الإمارات. خبرة في قضايا الطلاق بالتراضي والمتنازع عليه والخلع وحضانة الأطفال. استشارة مجانية باللغة العربية.';

const canonical = 'https://divorceu.ae/ar/محامي-طلاق';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-lawyer-dubai',
  ar: 'https://divorceu.ae/ar/محامي-طلاق',
};

const breadcrumbItems = [
  { name: 'الرئيسية', url: 'https://divorceu.ae/ar/' },
  { name: 'محامي طلاق' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'كم تكلفة محامي الطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'تتراوح أتعاب محامي الطلاق في الإمارات بين 5,000 و15,000 درهم للطلاق بالتراضي، وبين 20,000 و80,000 درهم أو أكثر للقضايا المتنازع عليها. يقدم معظم المحامين استشارة أولى مجانية. رسوم المحكمة منفصلة وتتراوح بين 600 و2,000 درهم.',
      },
    },
    {
      '@type': 'Question',
      name: 'هل أحتاج محامياً للطلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'لا يُلزمك القانون بتوكيل محامٍ في محكمة الأحوال الشخصية، لكن وجود محامٍ متخصص يحمي حقوقك ويحسّن نتائج القضية بشكل ملحوظ. في القضايا المتعلقة بالحضانة أو النفقة أو الأصول المتنازع عليها، التمثيل القانوني ضروري.',
      },
    },
    {
      '@type': 'Question',
      name: 'كيف أجد أفضل محامي طلاق في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'ابحث عن محامٍ مرخّص من وزارة العدل الإماراتية، متخصص في قانون الأسرة والأحوال الشخصية، ولديه خبرة في نوع قضيتك. اطلب استشارة مجانية أولاً لتقييم مدى ملاءمته لحالتك.',
      },
    },
    {
      '@type': 'Question',
      name: 'ما الفرق بين الطلاق والخلع في الإمارات؟',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'الطلاق يصدر من الزوج عادةً. الخلع هو الطلاق الذي تطلبه الزوجة من القضاء مقابل إعادة المهر. في حالة الخلع، لا يحق للزوج الاعتراض على إنهاء العقد، لكنه يحق له استرداد المهر المسمى في عقد الزواج.',
      },
    },
  ],
};

const faqItems = [
  {
    question: 'كم تكلفة محامي الطلاق في الإمارات؟',
    answer:
      'تتراوح أتعاب محامي الطلاق بين <strong>5,000 و15,000 درهم</strong> للطلاق بالتراضي، وبين 20,000 و80,000 درهم أو أكثر للقضايا المتنازع عليها. رسوم المحكمة منفصلة: 600–2,000 درهم.',
  },
  {
    question: 'هل أحتاج محامياً للطلاق في الإمارات؟',
    answer:
      'لا يُلزمك القانون بتوكيل محامٍ، لكنه يحمي حقوقك ويحسّن نتائج القضية. في قضايا الحضانة والنفقة والأصول المتنازع عليها، التمثيل القانوني ضروري.',
  },
  {
    question: 'كيف أجد أفضل محامي طلاق في الإمارات؟',
    answer:
      'ابحث عن محامٍ مرخّص من وزارة العدل الإماراتية، متخصص في قانون الأسرة، ولديه خبرة في نوع قضيتك. استخدم نموذج التواصل للحصول على توصية مجانية الآن.',
  },
  {
    question: 'ما الفرق بين الطلاق والخلع في الإمارات؟',
    answer:
      'الطلاق يصدر من الزوج. الخلع هو طلب الزوجة من القضاء إنهاء الزواج مقابل إعادة المهر. لا يحق للزوج الاعتراض على الخلع لكن يحق له استرداد المهر.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="ar"
  dir="rtl"
  hreflang={hreflang}
  schema={faqSchema}
>
  <main>
    <header class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <Breadcrumb items={breadcrumbItems} lang="ar" />
          <h1 class="hero__h1">
            محامي طلاق في الإمارات —<br />
            استشارة قانونية مجانية
          </h1>
          <p class="hero__sub">
            هل تواجه قضية طلاق في الإمارات؟ سواء كنت تبحث عن طلاق بالتراضي أو طلاق مُتنازع عليه
            أو خلع أو حضانة أطفال — شبكتنا من محامي الطلاق المرخّصين من وزارة العدل الإماراتية
            مستعدة لمساعدتك. خبرة في القضايا العربية والدولية. استشارة مجانية.
          </p>
          <ul class="hero__trust">
            <li>✓ مرخّصون من وزارة العدل الإماراتية</li>
            <li>✓ خبرة في الطلاق والخلع والحضانة</li>
            <li>✓ دعم كامل باللغة العربية</li>
            <li>✓ استشارة أولى مجانية</li>
          </ul>
        </div>
        <div class="hero__form">
          <LeadForm lang="ar" variant="hero" heading="تحدث مع محامي طلاق اليوم" />
        </div>
      </div>
    </header>

    <div class="container">

      <!-- ===== لماذا تحتاج محامياً ===== -->
      <section class="section" aria-labelledby="why-heading">
        <h2 id="why-heading">لماذا تحتاج إلى محامي طلاق في الإمارات؟</h2>
        <p>
          قانون الأحوال الشخصية في الإمارات معقد ومتشعّب. سواء كنت تقدّم دعوى طلاق أو تردّ عليها،
          وجود محامٍ متخصص يحمي حقوقك القانونية ويتجنب الأخطاء التي يصعب تداركها بعد صدور الحكم.
        </p>

        <div class="callout">
          <strong>حقيقة مهمة:</strong> في قضايا الطلاق المتنازع عليها، يحقق الأطراف الممثَّلون بمحامٍ
          نتائج أفضل بشكل ملحوظ في شأن الحضانة والتسويات المالية مقارنةً بمن يمثّلون أنفسهم.
        </div>

        <h3>متى يكون توكيل محامٍ ضرورياً؟</h3>
        <ul class="list">
          <li>أنت وزوجك/زوجتك لا تتفقان على أي شرط من شروط الطلاق</li>
          <li>هناك أطفال وتريد ضمان حقوق الحضانة</li>
          <li>لديك أصول أو عقارات أو مصالح تجارية في الإمارات</li>
          <li>الطرف الآخر قدّم بالفعل دعوى قضائية ضدك</li>
          <li>تحتاج إلى الاعتراف بالطلاق في دولة أخرى</li>
        </ul>
      </section>

      <!-- ===== ما يفعله المحامي ===== -->
      <section class="section" aria-labelledby="services-heading">
        <h2 id="services-heading">ما الذي يفعله محامي الطلاق في الإمارات؟</h2>

        <div class="service-grid">
          <div class="service-card">
            <h3>تقديم الدعوى والإعداد</h3>
            <p>صياغة وتقديم عريضة الطلاق، وجمع الوثائق المطلوبة، والتحقق من اختصاص المحكمة الصحيح.</p>
          </div>
          <div class="service-card">
            <h3>جلسة المصالحة</h3>
            <p>تحضيرك لجلسة المصالحة الإلزامية وضمان ألا تضر إجاباتك بقضيتك في الجلسات اللاحقة.</p>
          </div>
          <div class="service-card">
            <h3>حضانة الأطفال وحق الزيارة</h3>
            <p>الدفاع عن ترتيبات الحضانة التي تصبّ في مصلحة طفلك، والتفاوض على جداول الزيارة.</p>
          </div>
          <div class="service-card">
            <h3>النفقة والتسوية المالية</h3>
            <p>المطالبة بالنفقة والمهر المؤجل وحق السكن وتقسيم الأصول وفق القانون المعمول به.</p>
          </div>
          <div class="service-card">
            <h3>توثيق حكم الطلاق</h3>
            <p>ترتيب التصديق الرسمي على حكم الطلاق ومعادلته لدى الجهات المعنية في بلدك الأصلي.</p>
          </div>
          <div class="service-card">
            <h3>الإقامة بعد الطلاق</h3>
            <p>إرشادك خلال الـ30 يوماً المتاحة لتغيير وضعك الوظيفي وخياراتك للإقامة بعد الطلاق.</p>
          </div>
        </div>
      </section>

      <!-- ===== أنواع قضايا الطلاق ===== -->
      <section class="section" aria-labelledby="types-heading">
        <h2 id="types-heading">أنواع قضايا الطلاق في الإمارات</h2>

        <h3>الطلاق بالتراضي</h3>
        <p>
          إذا اتفقتما على الطلاق وحسمتما جميع الشروط — الحضانة والنفقة وتقسيم الأصول —
          يمكنكما تقديم طلب طلاق مشترك. تستمر المحكمة في اشتراط جلسة المصالحة، لكن العملية
          أسرع بكثير: عادةً 1–3 أشهر.
        </p>

        <h3>الطلاق للضرر</h3>
        <p>
          تستطيع الزوجة طلب الطلاق للضرر إذا أثبتت وجود ضرر لحق بها من زوجها، كالإساءة
          أو الإهمال أو العجز عن الإنفاق. يستدعي هذا النوع تقديم أدلة أمام المحكمة وقد يستغرق أشهراً.
        </p>
        <p>
          <a href="/ar/طلاق-للضرر">دليل مفصّل: الطلاق للضرر في الإمارات ←</a>
        </p>

        <h3>الخلع</h3>
        <p>
          الخلع هو طلب الزوجة من القضاء إنهاء الزواج مقابل إعادة المهر للزوج. لا يحق للزوج
          الاعتراض على منح الخلع، لكنه يحق له المطالبة باسترداد المهر. يستغرق الخلع عادةً 1–3 أشهر.
        </p>

        <h3>الطلاق الغيابي</h3>
        <p>
          إذا كان أحد الزوجين خارج الإمارات ورفض التواصل أو التعاون، يمكن رفع دعوى طلاق
          غيابية. تتطلب هذه الحالة إجراءات تبليغ خاصة ويُستحسن الاستعانة بمحامٍ ذي خبرة.
        </p>

        <div class="cta-inline">
          <p>لست متأكداً من نوع قضيتك؟</p>
          <a href="#contact" class="btn btn--primary">احصل على تقييم قانوني مجاني</a>
        </div>
      </section>

      <!-- ===== روابط ذات صلة ===== -->
      <section class="section" aria-labelledby="related-heading">
        <h2 id="related-heading">أدلة قانونية ذات صلة</h2>
        <div class="related-links">
          <a href="/ar/كيفية-تقديم-الطلاق-في-الامارات" class="related-link">
            <strong>كيفية تقديم الطلاق في الإمارات</strong>
            <span>دليل خطوة بخطوة لمحكمة الأحوال الشخصية</span>
          </a>
          <a href="/ar/حضانة-الاطفال-الامارات" class="related-link">
            <strong>حضانة الأطفال في الإمارات</strong>
            <span>من يحصل على الحضانة وكيف تقرر المحاكم</span>
          </a>
          <a href="/ar/حقوق-الزوجة-بعد-الطلاق-الامارات" class="related-link">
            <strong>حقوق الزوجة بعد الطلاق</strong>
            <span>النفقة والمهر وحق السكن</span>
          </a>
          <a href="/ar/طلاق-للضرر" class="related-link">
            <strong>الطلاق للضرر</strong>
            <span>الشروط والإجراءات في الإمارات</span>
          </a>
        </div>
      </section>

      <!-- ===== أسئلة شائعة ===== -->
      <FAQSection items={faqItems} lang="ar" />

      <!-- ===== CTA ===== -->
      <section class="section section--cta" id="contact" aria-labelledby="cta-heading">
        <h2 id="cta-heading">تواصل مع محامي طلاق الآن — مجاناً</h2>
        <p>يُطابق فريقنا حالتك مع محامي طلاق مرخّص في الإمارات خلال 24 ساعة. سري تماماً.</p>
        <LeadForm lang="ar" variant="inline" />
      </section>

    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>© 2025 DivorceUAE.ae — خدمة إحالة قانونية. ليست مكتب محاماة. المعلومات للإرشاد فقط ولا تشكل استشارة قانونية.</p>
      <nav aria-label="تنقل التذييل">
        <a href="/ar/سياسة-الخصوصية">سياسة الخصوصية</a>
        <a href="/ar/إخلاء-المسؤولية">إخلاء المسؤولية</a>
        <a href="/en/divorce-lawyer-dubai">English</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%);
    color: #fff; padding: 60px 0 50px;
  }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.7rem, 3.5vw, 2.6rem); font-weight: 800; line-height: 1.35; margin-bottom: 16px; }
  .hero__sub { font-size: 1.02rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.9; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.88rem; }
  .hero__trust li { opacity: 0.9; }
  .section { padding: 56px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.35rem, 2.8vw, 1.85rem); font-weight: 700; color: #1e3a5f; margin-bottom: 18px; }
  .section h3 { font-size: 1.1rem; font-weight: 700; color: #1e3a5f; margin: 28px 0 10px; }
  .section p { color: #374151; line-height: 2; margin-bottom: 14px; }
  .section a { color: #2563eb; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 56px 40px; margin-bottom: 60px; text-align: center; }
  .callout {
    background: #eff6ff; border-right: 4px solid #2563eb; border-left: none;
    padding: 14px 18px; border-radius: 8px 0 0 8px;
    color: #1e3a5f; font-size: 0.95rem; margin: 20px 0;
  }
  .list { margin: 10px 0 18px 0; padding-right: 20px; }
  .list li { margin-bottom: 8px; color: #374151; line-height: 1.8; }
  .service-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 24px; }
  .service-card { padding: 24px; background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; }
  .service-card h3 { font-size: 0.97rem; font-weight: 700; color: #1e3a5f; margin: 0 0 8px; }
  .service-card p { font-size: 0.9rem; color: #6b7280; margin: 0; line-height: 1.7; }
  .cta-inline { display: flex; align-items: center; gap: 20px; margin-top: 28px; flex-wrap: wrap; }
  .cta-inline p { margin: 0; font-weight: 600; color: #1e3a5f; }
  .btn--primary {
    display: inline-block; padding: 12px 28px;
    background: #c9a84c; color: #fff;
    border-radius: 8px; text-decoration: none; font-weight: 700;
  }
  .btn--primary:hover { background: #b8942d; }
  .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px; }
  .related-link {
    display: flex; flex-direction: column; gap: 4px;
    padding: 18px 20px; background: #fff;
    border: 1.5px solid #e5e7eb; border-radius: 10px;
    text-decoration: none; transition: border-color 0.2s;
  }
  .related-link:hover { border-color: #2563eb; }
  .related-link strong { color: #1e3a5f; font-size: 0.97rem; }
  .related-link span { color: #6b7280; font-size: 0.85rem; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 36px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.82rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem; }
  .footer nav a:hover { color: #fff; }
  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 36px; }
    .hero { padding: 44px 0 36px; }
    .section--cta { padding: 40px 20px; }
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
