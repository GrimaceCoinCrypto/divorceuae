---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'Divorce Lawyer Sharjah — Sharjah Family Court Guide 2025';
const description =
  'Looking for a divorce lawyer in Sharjah? How Sharjah Personal Status Courts work, what to expect, costs, and the key differences from Dubai — a practical guide for expats and UAE nationals.';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-lawyer-sharjah',
  ar: 'https://divorceu.ae/ar/',
};

const breadcrumbs = [
  { name: 'Home', url: 'https://divorceu.ae/en/' },
  { name: 'Divorce Lawyer Sharjah', url: 'https://divorceu.ae/en/divorce-lawyer-sharjah' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Where do I file for divorce in Sharjah?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Divorce cases in Sharjah are filed at the Sharjah Personal Status Court, located within the Sharjah Courts complex. For Emiratis, cases may also be handled through the Family Guidance and Reconciliation Centre first. Expats file in the emirate of their registered residence — if you live in Sharjah, you file in Sharjah regardless of where the marriage took place.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is divorce harder to get in Sharjah than in Dubai?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sharjah courts apply the same UAE Federal Personal Status Law as Dubai, but Sharjah is known for a more conservative interpretation in practice. Reconciliation is emphasised more strongly. Khula cases (wife-initiated divorce) may take longer in Sharjah courts compared to Dubai. However, the legal framework is identical — both use Federal Law No. 28 of 2005.',
      },
    },
    {
      '@type': 'Question',
      name: 'How much does a divorce lawyer cost in Sharjah?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Divorce lawyer fees in Sharjah are broadly similar to Dubai: AED 3,000–8,000 for uncontested mutual consent divorce, AED 8,000–25,000 for contested divorce without children, and AED 20,000–50,000+ for contested cases involving custody. Some Sharjah lawyers offer lower rates than Dubai counterparts due to lower overhead.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can an expat divorce in Sharjah if married in another country?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. If you are registered as a resident in Sharjah, you file for divorce in Sharjah regardless of where you married. Your foreign marriage certificate must be officially translated into Arabic and attested by your home country\'s embassy and the UAE Ministry of Foreign Affairs before the court can process it. Your lawyer handles this.',
      },
    },
  ],
};

const differences = [
  { factor: 'Legal framework', sharjah: 'Federal Personal Status Law No. 28 of 2005 (same as all UAE)', dubai: 'Same federal law' },
  { factor: 'Reconciliation emphasis', sharjah: 'Strong — multiple mandatory sessions standard', dubai: 'Mandatory but typically 1–3 sessions' },
  { factor: 'Khula (wife-initiated)', sharjah: 'Granted but may take longer; more sessions typical', dubai: 'Processed faster in practice; more liberal interpretation' },
  { factor: 'Non-Muslim expat cases', sharjah: 'Courts apply UAE law by default; limited DIFC option', dubai: 'Dubai Courts + DIFC Courts as an alternative venue' },
  { factor: 'Court language', sharjah: 'Arabic only — official translation of all documents required', dubai: 'Arabic only — same requirement' },
];

const lawyerChecklist = [
  'Licensed by the Sharjah Legal Affairs Department — verify the Bar number',
  'Specialist in Personal Status law, not a general commercial lawyer',
  'Fluent in your language or provides a dedicated interpreter (not just a paralegal)',
  'Transparent about fee structure — per-hearing billing vs. fixed fee',
  'Has handled cases in Sharjah courts specifically, not only Dubai',
  'Can advise on asset division under UAE law vs. home country law implications',
  'Explains your options clearly — talaq, khula, or judicial divorce — before committing to a strategy',
];

const faqItems = [
  {
    question: 'Do I need a lawyer for divorce in Sharjah?',
    answer: 'Technically you can represent yourself, but practically it is very difficult — especially for expats. All court proceedings and documents must be in Arabic. Personal Status courts have procedural rules that require knowledge to navigate. For contested cases or cases involving children, having a licensed Sharjah lawyer is essential. Even for uncontested divorce, a lawyer significantly reduces the risk of procedural errors that delay the case.',
  },
  {
    question: 'How long does divorce take in Sharjah?',
    answer: 'An uncontested mutual consent divorce in Sharjah takes 1–3 months including the mandatory reconciliation sessions. A contested divorce (disputes over assets, alimony, or custody) typically takes 6–18 months. Cases involving complex international asset issues or disputes over applicable law can run 2+ years. Sharjah courts are slightly slower than Dubai on average due to lower case volumes but more emphasis on reconciliation.',
  },
  {
    question: 'What is the Sharjah Family Guidance Centre?',
    answer: 'The Sharjah Family Guidance and Reconciliation Centre is a mandatory step before most divorce cases in Sharjah can proceed to court. Its function is to attempt reconciliation between spouses. For UAE nationals especially, this step is taken seriously and multiple sessions may be required. If reconciliation genuinely fails, the centre issues a certificate allowing the court case to proceed. Expats may also be referred to this centre depending on the case type.',
  },
  {
    question: 'Does Sharjah law allow non-Muslim expats to divorce under home country law?',
    answer: 'UAE Personal Status Law applies to all residents by default unless both spouses are non-Muslims and their home country law is invoked. In Dubai, the DIFC Courts offer an alternative English-language forum for international divorces. Sharjah does not have an equivalent — non-Muslim expats in Sharjah who wish to divorce under their home country law typically need to return to their home country or use Dubai Courts / DIFC as the applicable venue, depending on circumstances.',
  },
  {
    question: 'Will my Sharjah divorce be recognised in my home country?',
    answer: 'A UAE court divorce decree (from any emirate) is a legally valid document with an official court stamp. Recognition abroad requires an apostille from the UAE Ministry of Foreign Affairs, a certified translation from Arabic, and — depending on your country — registration with your embassy or home country civil register. Your lawyer can prepare the apostille package. Most European, North American, and Commonwealth countries recognise UAE divorce decrees through this process.',
  },
];
---

<BaseLayout
  {title}
  {description}
  canonical="https://divorceu.ae/en/divorce-lawyer-sharjah"
  {hreflang}
  lang="en"
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="hero-section">
    <div class="hero-inner">
      <p class="hero-tag">Divorce Guide · Sharjah 2025</p>
      <h1>{title}</h1>
      <p class="hero-desc">
        Divorcing in Sharjah follows UAE Federal Personal Status Law — the same law as Dubai — but with a stronger emphasis on reconciliation. This guide covers how Sharjah courts work, what to look for in a Sharjah divorce lawyer, costs, and the key differences you need to know as an expat or UAE national.
      </p>
      <p class="hero-author">By <strong>Aleksi Suoninen</strong> · UAE Expat &amp; Legal Consultant · divorceu.ae</p>
    </div>
  </section>

  <div class="page-layout">
    <main class="main-content">

      <div class="answer-box">
        <h2>Quick summary — divorcing in Sharjah</h2>
        <p>
          Divorce in Sharjah is governed by <strong>UAE Federal Personal Status Law</strong> — the same legal framework as Dubai and all other emirates.
          File at the <strong>Sharjah Personal Status Court</strong> if you are a Sharjah resident.
          Mandatory reconciliation through the Family Guidance Centre applies before the case can proceed.
          Lawyer fees: <strong>AED 3,000–50,000+</strong> depending on case complexity.
          Timeline: <strong>1–3 months</strong> uncontested; <strong>6–18+ months</strong> contested.
        </p>
      </div>

      <section class="content-section">
        <h2>Sharjah vs. Dubai Divorce Courts — Key Differences</h2>
        <div class="compare-table">
          <div class="compare-header">
            <div>Factor</div>
            <div>Sharjah</div>
            <div>Dubai</div>
          </div>
          {differences.map((row, i) => (
            <div class={`compare-row${i % 2 === 1 ? ' alt' : ''}`}>
              <div class="compare-factor">{row.factor}</div>
              <div class="compare-sharjah">{row.sharjah}</div>
              <div class="compare-dubai">{row.dubai}</div>
            </div>
          ))}
        </div>
      </section>

      <section class="content-section">
        <h2>What to Look for in a Sharjah Divorce Lawyer</h2>
        <ul class="checklist">
          {lawyerChecklist.map(item => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="content-section">
        <h2>Divorce Lawyer Fees in Sharjah</h2>
        <div class="fee-grid">
          <div class="fee-card">
            <p class="fee-type">Uncontested / Mutual Consent</p>
            <p class="fee-amount">AED 3,000–8,000</p>
            <p class="fee-detail">Both spouses agree on all terms. Lawyer prepares and files the agreement.</p>
          </div>
          <div class="fee-card">
            <p class="fee-type">Contested (no children)</p>
            <p class="fee-amount">AED 8,000–25,000</p>
            <p class="fee-detail">Asset disputes, alimony disagreements. Multiple hearings likely.</p>
          </div>
          <div class="fee-card">
            <p class="fee-type">Contested with custody</p>
            <p class="fee-amount">AED 20,000–50,000+</p>
            <p class="fee-detail">Custody battles are the most expensive and time-intensive cases.</p>
          </div>
          <div class="fee-card">
            <p class="fee-type">Khula (wife-initiated)</p>
            <p class="fee-amount">AED 5,000–15,000</p>
            <p class="fee-detail">Slightly higher in Sharjah than Dubai due to more reconciliation sessions.</p>
          </div>
        </div>
      </section>

      <FAQSection items={faqItems} />

      <section class="content-section">
        <h2>Related Guides</h2>
        <div class="related-grid">
          <a href="/en/divorce-lawyer-dubai" class="related-card">
            <strong>Divorce Lawyer Dubai</strong>
            <span>Finding and working with a divorce lawyer in Dubai</span>
          </a>
          <a href="/en/divorce-lawyer-abu-dhabi" class="related-card">
            <strong>Divorce Lawyer Abu Dhabi</strong>
            <span>Abu Dhabi Personal Status Courts and lawyer guide</span>
          </a>
          <a href="/en/how-to-file-for-divorce-in-dubai" class="related-card">
            <strong>How to File for Divorce in Dubai</strong>
            <span>Step-by-step filing guide for Dubai courts</span>
          </a>
          <a href="/en/divorce-cost-uae" class="related-card">
            <strong>Divorce Cost UAE</strong>
            <span>Court fees, lawyer fees, and what drives your total bill</span>
          </a>
        </div>
      </section>

    </main>

    <aside class="sidebar">
      <div class="sidebar-sticky">
        <LeadForm />
      </div>
    </aside>
  </div>
</BaseLayout>

<style>
  .hero-section { background: #0a1628; color: #fff; padding: 3rem 1rem; }
  .hero-inner { max-width: 52rem; margin: 0 auto; }
  .hero-tag { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #c9a84c; margin-bottom: 0.75rem; }
  h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
  .hero-desc { font-size: 1.05rem; color: #d1d5db; line-height: 1.8; margin-bottom: 0.75rem; }
  .hero-author { font-size: 0.85rem; color: #9ca3af; }
  .hero-author strong { color: #fff; }

  .page-layout { max-width: 72rem; margin: 0 auto; padding: 2rem 1rem; display: grid; grid-template-columns: 1fr 340px; gap: 2.5rem; align-items: start; }
  .main-content { min-width: 0; }
  .sidebar-sticky { position: sticky; top: 1.5rem; }

  .answer-box { background: #f0fdf4; border-left: 4px solid #16a34a; padding: 1.25rem 1.5rem; border-radius: 0 12px 12px 0; margin-bottom: 2rem; }
  .answer-box h2 { font-size: 1.1rem; font-weight: 700; color: #064e3b; margin: 0 0 0.5rem; }
  .answer-box p { color: #1f2937; line-height: 1.8; margin: 0; font-size: 0.97rem; }
  .answer-box strong { color: #064e3b; }

  .content-section { margin-bottom: 2.5rem; }
  .content-section h2 { font-size: clamp(1.2rem, 2.5vw, 1.6rem); font-weight: 700; color: #0a1628; margin-bottom: 1rem; border-bottom: 2px solid #f3f4f6; padding-bottom: 0.5rem; }

  .compare-table { border: 1.5px solid #e5e7eb; border-radius: 10px; overflow: hidden; overflow-x: auto; }
  .compare-header { display: grid; grid-template-columns: 1fr 1.4fr 1.4fr; background: #0a1628; color: #fff; font-size: 0.75rem; font-weight: 700; padding: 10px 14px; gap: 10px; min-width: 480px; }
  .compare-row { display: grid; grid-template-columns: 1fr 1.4fr 1.4fr; padding: 10px 14px; gap: 10px; border-top: 1px solid #f3f4f6; font-size: 0.85rem; min-width: 480px; }
  .compare-row.alt { background: #fafafa; }
  .compare-factor { font-weight: 700; color: #0a1628; }
  .compare-sharjah { color: #374151; }
  .compare-dubai { color: #6b7280; }

  .checklist { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .checklist li { font-size: 0.9rem; color: #374151; line-height: 1.65; padding-left: 1.4rem; position: relative; }
  .checklist li::before { content: '✓'; position: absolute; left: 0; color: #c9a84c; font-weight: 700; }

  .fee-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .fee-card { background: #f9fafb; border: 1.5px solid #e5e7eb; border-radius: 10px; padding: 1.1rem; }
  .fee-type { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; margin: 0 0 4px; }
  .fee-amount { font-size: 1.15rem; font-weight: 800; color: #0a1628; margin: 0 0 4px; }
  .fee-detail { font-size: 0.82rem; color: #6b7280; margin: 0; line-height: 1.5; }

  .related-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  .related-card { display: flex; flex-direction: column; gap: 4px; padding: 1rem; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 8px; text-decoration: none; transition: border-color 0.2s; }
  .related-card:hover { border-color: #c9a84c; }
  .related-card strong { color: #0a1628; font-size: 0.9rem; }
  .related-card span { color: #6b7280; font-size: 0.78rem; }

  @media (max-width: 900px) {
    .page-layout { grid-template-columns: 1fr; }
    .sidebar { order: -1; }
  }
  @media (max-width: 640px) {
    .fee-grid, .related-grid { grid-template-columns: 1fr; }
  }
</style>
