---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'Child Custody UAE — Who Gets Custody After Divorce (2025 Guide)';
const description =
  "Complete guide to child custody in UAE after divorce. UAE custody law for Muslims and non-Muslims, who gets physical custody, father's rights, travel permission, and the 2022 joint custody rules.";

const canonical = 'https://divorceu.ae/en/child-custody-uae';

const hreflang = {
  en: 'https://divorceu.ae/en/child-custody-uae',
  ar: 'https://divorceu.ae/ar/حضانة-الاطفال-الامارات',
};

const breadcrumbItems = [
  { name: 'Home', url: 'https://divorceu.ae/en/' },
  { name: 'Child Custody UAE' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Who gets child custody in UAE after divorce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Under UAE personal status law, mothers typically receive physical custody of young children: boys until age 11 and girls until age 13. After those ages, the child may choose or the court decides. Both parents retain legal guardianship regardless of who has physical custody. For non-Muslim expats under the 2022 law, joint custody is the default.",
      },
    },
    {
      '@type': 'Question',
      name: "What are the father's rights in UAE child custody?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: "Even when the mother has physical custody, the father retains full legal guardianship in UAE. This means the father must consent to major decisions: international travel, school enrollment, passport applications, and medical procedures. The father also has a legal right to regular visitation.",
      },
    },
    {
      '@type': 'Question',
      name: 'Can a mother take children out of UAE after divorce?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "A custodial mother cannot take children out of the UAE without the father's written consent or a court order permitting travel. Taking children abroad without permission is treated as parental abduction under UAE law. Travel permission must be obtained through the Personal Status Court if the father refuses.",
      },
    },
    {
      '@type': 'Question',
      name: 'What is joint custody under the 2022 UAE law?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Under Federal Law No. 41 of 2022, non-Muslim expats divorce with joint parental custody as the default. Both parents share physical time with the children equally or near-equally, and both retain equal decision-making authority. The court may deviate from equal custody if it is not in the best interests of the child.',
      },
    },
  ],
};

const faqItems = [
  {
    question: 'Who gets child custody in UAE after divorce?',
    answer: "Under UAE personal status law, mothers get physical custody: <strong>boys until age 11, girls until age 13</strong>. After those ages, the child chooses or the court decides. Both parents retain legal guardianship. For non-Muslim expats under the 2022 law, joint custody is the default.",
  },
  {
    question: "What are the father's rights in UAE child custody?",
    answer: "The father retains <strong>full legal guardianship</strong> even when the mother has physical custody. He must consent to international travel, school enrollment, passport applications, and major medical procedures. He has a legal right to regular visitation.",
  },
  {
    question: 'Can a mother take children out of UAE after divorce?',
    answer: "No — not without the father's written consent or a court travel order. Taking children abroad without permission is parental abduction under UAE law. Apply to the Personal Status Court if the father refuses.",
  },
  {
    question: 'What is joint custody under the 2022 UAE law?',
    answer: 'Under Federal Law No. 41 of 2022, non-Muslim expats get joint physical and legal custody by default — equal time and equal decision-making. The court can deviate if equal custody is not in the best interests of the child.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  lang="en"
  dir="ltr"
  hreflang={hreflang}
  schema={faqSchema}
>
  <main>
    <header class="hero">
      <div class="container hero__inner">
        <div class="hero__content">
          <Breadcrumb items={breadcrumbItems} lang="en" />
          <h1 class="hero__h1">
            Child Custody UAE —<br />
            Who Gets Custody After Divorce?
          </h1>
          <p class="hero__sub">
            Child custody is the most contested aspect of divorce in the UAE.
            This guide explains UAE custody law for both Muslim and non-Muslim parents —
            who gets physical custody, what guardianship means, travel rules, and how
            the 2022 law changed everything for expats.
          </p>
          <ul class="hero__trust">
            <li>✓ Muslim & non-Muslim rules explained</li>
            <li>✓ 2022 joint custody law</li>
            <li>✓ Father's & mother's rights</li>
            <li>✓ Travel permission rules</li>
          </ul>
        </div>
        <div class="hero__form">
          <LeadForm lang="en" variant="hero" heading="Protect Your Custody Rights — Free Advice" />
        </div>
      </div>
    </header>

    <div class="container">

      <section class="section" aria-labelledby="overview-heading">
        <h2 id="overview-heading">UAE Child Custody Law — The Basics</h2>
        <p>
          UAE custody law distinguishes between two concepts that are often confused:
        </p>
        <div class="concept-grid">
          <div class="concept-card">
            <h3>Physical Custody (Hadana)</h3>
            <p>Who the child lives with day-to-day. Under Islamic personal status law, this defaults to the mother for young children. Under the 2022 civil law for non-Muslims, it is shared equally by default.</p>
          </div>
          <div class="concept-card">
            <h3>Legal Guardianship (Wilaya)</h3>
            <p>The right to make major decisions about the child's life — school, travel, medical care, passport. Under both Islamic and civil law in UAE, the father retains legal guardianship even when the mother has physical custody.</p>
          </div>
        </div>
        <p>
          This distinction is critical: a mother can have full physical custody and still need the
          father's consent to travel internationally with the child or enroll them in a new school.
        </p>
      </section>

      <section class="section" aria-labelledby="muslim-heading">
        <h2 id="muslim-heading">Child Custody for Muslim Parents in UAE</h2>
        <p>
          Under UAE Federal Personal Status Law (No. 28 of 2005), custody for Muslim families follows
          Islamic jurisprudence:
        </p>

        <h3>Mother's Physical Custody Rights</h3>
        <ul class="list">
          <li>Mothers are entitled to physical custody of <strong>boys until age 11</strong></li>
          <li>Mothers are entitled to physical custody of <strong>girls until age 13</strong></li>
          <li>After these ages, the child may express a preference and the court decides</li>
          <li>The mother's custody right ends if she remarries a man who is not the children's mahram (close male relative)</li>
          <li>Custody can be transferred to the father if the mother is found unfit</li>
        </ul>

        <h3>Father's Guardianship Rights</h3>
        <p>
          The father retains <em>wilaya</em> (legal guardianship) over all children regardless of age
          and regardless of who has physical custody. In practice, this means:
        </p>
        <ul class="list">
          <li>Father must consent to international travel for children</li>
          <li>Father must consent to school enrollment changes</li>
          <li>Father must consent to passport applications and renewals</li>
          <li>Father must consent to significant medical procedures</li>
        </ul>

        <h3>Visitation Rights</h3>
        <p>
          The non-custodial parent has a legal right to regular visitation. UAE courts typically order
          visitation on weekends and for extended periods during school holidays. Denial of visitation
          is a serious legal matter that can result in custody being reconsidered.
        </p>
      </section>

      <section class="section" aria-labelledby="nonmuslim-heading">
        <h2 id="nonmuslim-heading">Joint Custody for Non-Muslim Expats — 2022 Law</h2>
        <p>
          Under <strong>Federal Law No. 41 of 2022</strong>, non-Muslim expat parents divorce with
          joint custody as the starting point. This is a significant departure from Islamic custody rules:
        </p>
        <ul class="list">
          <li><strong>Equal physical time:</strong> children live with each parent roughly equally</li>
          <li><strong>Equal decision-making:</strong> both parents have equal authority on school, travel, and medical decisions</li>
          <li><strong>No age-based default:</strong> there is no rule that mothers get custody until age 11/13</li>
          <li><strong>Best interests standard:</strong> the court can deviate from equal custody if it is not in the child's best interest</li>
        </ul>
        <p>
          <a href="/en/divorce-in-uae-for-expats">More: 2022 expat divorce law explained →</a>
        </p>
      </section>

      <section class="section" aria-labelledby="travel-heading">
        <h2 id="travel-heading">Travel Permission for Children After UAE Divorce</h2>
        <p>
          This is one of the most practically important custody issues for expat families in the UAE:
        </p>

        <h3>Taking Children Abroad</h3>
        <p>
          A custodial parent <strong>cannot take children outside the UAE without written consent from the other parent</strong>
          or a court-issued travel order. This applies even for short holidays.
        </p>
        <p>
          UAE airports and border points are linked to the court system. A non-custodial parent can
          file a travel ban on the children, which prevents them from leaving the UAE without court approval.
        </p>

        <h3>What to Do If the Other Parent Refuses Travel Permission</h3>
        <ol class="steps">
          <li>
            <h3>Apply to the Personal Status Court</h3>
            <p>File a petition requesting court-ordered travel permission. You must show the trip is in the child's best interests.</p>
          </li>
          <li>
            <h3>Specify the Trip Details</h3>
            <p>Include destination, dates, reason for travel, and return commitment. Courts are more likely to grant permission for family visits and educational trips.</p>
          </li>
          <li>
            <h3>Obtain a Travel Order</h3>
            <p>If granted, the court issues a travel order specifying the exact dates and destination. This overrides any travel ban the other parent has placed.</p>
          </li>
        </ol>

        <div class="callout">
          <strong>Warning:</strong> Taking children out of the UAE without permission is a criminal offence
          in the UAE — not just a civil matter. Parents have been arrested at airports for attempting to
          leave with children without the required documentation.
        </div>
      </section>

      <section class="section" aria-labelledby="related-heading">
        <h2 id="related-heading">Related Guides</h2>
        <div class="related-links">
          <a href="/en/divorce-lawyer-dubai" class="related-link">
            <strong>Find a Divorce Lawyer</strong>
            <span>Get matched with a custody specialist</span>
          </a>
          <a href="/en/divorce-in-uae-for-expats" class="related-link">
            <strong>Divorce for Expats</strong>
            <span>2022 civil law — joint custody explained</span>
          </a>
          <a href="/en/how-to-file-for-divorce-in-dubai" class="related-link">
            <strong>How to File for Divorce</strong>
            <span>Step-by-step Personal Status Court guide</span>
          </a>
          <a href="/en/uae-divorce-law" class="related-link">
            <strong>UAE Divorce Law</strong>
            <span>Federal personal status law overview</span>
          </a>
        </div>
      </section>

      <FAQSection items={faqItems} lang="en" />

      <section class="section section--cta" id="contact" aria-labelledby="cta-heading">
        <h2 id="cta-heading">Protect Your Custody Rights — Free Consultation</h2>
        <p>Speak to a family lawyer who specialises in UAE child custody cases. Free, confidential, within 24 hours.</p>
        <LeadForm lang="en" variant="inline" />
      </section>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>&copy; 2025 DivorceU.AE — Legal referral service. Not a law firm.</p>
      <nav aria-label="Footer navigation">
        <a href="/en/privacy-policy">Privacy Policy</a>
        <a href="/ar/حضانة-الاطفال-الامارات">العربية</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 60px 0 50px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.7rem, 3.5vw, 2.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
  .hero__sub { font-size: 1.02rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.7; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.88rem; }
  .hero__trust li { opacity: 0.9; }
  .section { padding: 56px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.35rem, 2.8vw, 1.85rem); font-weight: 700; color: #1e3a5f; margin-bottom: 18px; }
  .section h3 { font-size: 1.05rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 1.8; margin-bottom: 14px; }
  .section a { color: #2563eb; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 56px 40px; margin-bottom: 60px; text-align: center; }
  .callout { background: #fff7ed; border-left: 4px solid #f59e0b; padding: 14px 18px; border-radius: 0 8px 8px 0; color: #92400e; font-size: 0.95rem; margin: 16px 0; }
  .list { margin: 10px 0 18px 20px; }
  .list li { margin-bottom: 8px; color: #374151; line-height: 1.6; }
  .concept-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 20px 0; }
  .concept-card { padding: 24px; background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; }
  .concept-card h3 { font-size: 0.97rem; font-weight: 700; color: #1e3a5f; margin: 0 0 10px; }
  .concept-card p { font-size: 0.9rem; color: #374151; margin: 0; line-height: 1.6; }
  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 16px; margin-top: 16px; }
  .steps li { counter-increment: steps; padding: 20px 20px 20px 68px; position: relative; background: #f8faff; border-radius: 10px; border-left: 4px solid #2563eb; }
  .steps li::before { content: counter(steps); position: absolute; left: 16px; top: 20px; width: 32px; height: 32px; background: #2563eb; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; }
  .steps li h3 { font-size: 0.97rem; font-weight: 700; color: #1e3a5f; margin: 0 0 6px; }
  .steps li p { font-size: 0.88rem; color: #374151; margin: 0; line-height: 1.6; }
  .related-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 20px; }
  .related-link { display: flex; flex-direction: column; gap: 4px; padding: 18px 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .related-link:hover { border-color: #2563eb; }
  .related-link strong { color: #1e3a5f; font-size: 0.97rem; }
  .related-link span { color: #6b7280; font-size: 0.85rem; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 36px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.82rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.82rem; }
  @media (max-width: 768px) { .hero__inner { grid-template-columns: 1fr; } .concept-grid { grid-template-columns: 1fr; } .section--cta { padding: 40px 20px; } }
</style>
