---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'Child Support UAE — How Much, Who Pays & How to Claim';
const description =
  'Child support in UAE is the father\'s legal obligation regardless of custody. Learn how UAE courts calculate amounts, what is covered, and how to enforce non-payment — for both Muslim and non-Muslim families.';

const hreflang = {
  en: 'https://divorceu.ae/en/child-support-uae',
  ar: 'https://divorceu.ae/ar/نفقة-الاطفال-الامارات',
};

const breadcrumbs = [
  { name: 'Home', url: 'https://divorceu.ae/en/' },
  { name: 'Child Support UAE', url: 'https://divorceu.ae/en/child-support-uae' },
];

const whatIsCovered = [
  {
    category: 'Food & basic needs',
    detail: 'Reasonable food, clothing, and essential household items for the child. Courts assess this against the family\'s established standard of living, not a minimum subsistence level.',
    required: true,
  },
  {
    category: 'School fees & education',
    detail: 'Tuition fees, books, uniforms, school transport, and extracurricular activities. The school tier must be consistent with what the child was accustomed to during the marriage.',
    required: true,
  },
  {
    category: 'Medical expenses',
    detail: 'Routine medical, dental, and optical care. Emergency medical costs. Health insurance premiums. Courts treat medical care as a mandatory component of child support.',
    required: true,
  },
  {
    category: 'Housing',
    detail: 'The custodial parent is entitled to suitable housing for themselves and the children at the father\'s expense — or a housing allowance if the marital home is unavailable. This continues for the duration of the custody period.',
    required: true,
  },
  {
    category: 'Domestic help',
    detail: 'If the family employed domestic help during the marriage, courts can include the cost of a housekeeper/nanny in child support — particularly when the custodial mother is also employed.',
    required: false,
  },
  {
    category: 'Enrichment activities',
    detail: 'Sports, tutoring, music lessons, and similar activities the child was engaged in before the divorce. Courts consider continuity important for children\'s welfare.',
    required: false,
  },
];

const calculationFactors = [
  { factor: "Father's net monthly income", weight: 'Primary', detail: "The most important variable. UAE courts look at verified salary certificates, bank statements, and business income. Undeclared or hidden income is taken seriously — courts can investigate." },
  { factor: 'Standard of living during marriage', weight: 'High', detail: "Child support aims to maintain the child's established standard of living, not reduce it dramatically. A child who attended private school during the marriage is entitled to private school fees." },
  { factor: 'Number of children', weight: 'High', detail: "More children = higher total support, though the amount per child is not simply multiplied. Courts assess the total reasonable needs of all children together." },
  { factor: "Children's ages", weight: 'Medium', detail: "Older children (teenagers) typically have higher costs than younger children. School fees, medical costs, and activity costs all tend to increase with age." },
  { factor: "Mother's income", weight: 'Medium', detail: "Under UAE law, the father bears primary financial responsibility regardless of the mother's income. However, a high-earning mother may affect discretionary additions beyond basic necessities." },
  { factor: 'Custody arrangement', weight: 'Low', detail: "The father pays child support whether or not he has custody. If the father has full custody, support obligations transfer to him directly. Shared custody arrangements are assessed individually." },
];

const durations = [
  { who: 'Boys', until: 'Age 11 (custody), financial support until 18 (adulthood)', note: 'After age 11, custody typically transfers to the father under UAE law. Financial support continues until the son can support himself.' },
  { who: 'Girls', until: 'Marriage or financial independence', note: 'Daughters remain in the mother\'s custody longer. Financial support continues until marriage or until the daughter has her own income.' },
  { who: 'Disabled children', until: 'Indefinitely', note: 'Children who cannot support themselves due to disability receive lifelong support regardless of age.' },
  { who: 'Students', until: 'Completion of education (if enrolled)', note: 'UAE courts can extend support beyond 18 for children enrolled in higher education — the father is expected to support university study.' },
];

const faqItems = [
  {
    question: 'How much is child support in UAE?',
    answer:
      "There is no fixed amount — UAE courts determine child support based on the father's income, the child's needs, and the family's standard of living. As a rough guide, courts typically award 15–30% of the father's verified monthly income per child. For a father earning AED 20,000/month, one child might receive AED 4,000–6,000/month in total support (covering school fees, housing, medical, and basic needs combined). High-earner cases can result in AED 10,000–25,000/month per child.",
  },
  {
    question: 'Does the father pay child support if the mother has custody?',
    answer:
      'Yes — and this is the most important thing to understand about UAE child support law. The father\'s financial obligation to support his children exists regardless of who has custody. If the mother has custody, the father pays child support to her to fund the children\'s care. This is not optional — it is a legal obligation enforceable by the court.',
  },
  {
    question: 'At what age does child support stop in UAE?',
    answer:
      'For boys, financial support generally continues until adulthood (age 18) and beyond if the son is enrolled in university. For girls, support continues until marriage or financial independence. Disabled children receive support indefinitely. Note that custody (who the child lives with) has different age limits from financial support — they are separate questions.',
  },
  {
    question: 'What if the father refuses to pay child support in UAE?',
    answer:
      'Non-payment of court-ordered child support in UAE is treated as a serious legal violation. Enforcement mechanisms include: wage garnishment (direct deduction from salary), travel ban (preventing the father from leaving the country), freezing of bank accounts, and in serious cases criminal prosecution under UAE family abandonment laws. Contact a lawyer immediately — courts act swiftly on non-payment of child support.',
  },
  {
    question: 'Is child support different for non-Muslim expats in UAE?',
    answer:
      'The principle is similar — the father bears primary financial responsibility — but the 2022 civil personal status law for non-Muslim expats provides more flexibility. Courts applying the 2022 law consider both parents\' incomes more symmetrically and can order shared financial responsibility. The calculation is less formulaic than under Islamic law and gives judges more discretion to reach equitable outcomes.',
  },
  {
    question: 'Can child support be increased after it is set?',
    answer:
      'Yes. Child support orders in UAE are not permanent — either parent can apply to the court to modify the amount if circumstances change significantly. Grounds for increase: the father\'s income has risen substantially, the child\'s needs have grown (higher school fees, medical condition), or inflation has significantly eroded the original amount. Grounds for decrease: the father has suffered a genuine loss of income. You need a lawyer to file a modification application.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  dir="ltr"
  hreflang={hreflang}
>
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <Breadcrumb items={breadcrumbs} lang="en" />
        <h1 class="hero__h1">
          Child Support in UAE —<br />How Much, Who Pays &amp; How to Claim
        </h1>
        <p class="hero__sub">
          Under UAE law, the father is legally obligated to financially support his children
          regardless of who has custody. This guide explains what is covered, how courts calculate
          amounts, and what to do if payments stop.
        </p>
        <ul class="hero__trust">
          <li>✓ Muslim &amp; non-Muslim rules</li>
          <li>✓ Enforcement options</li>
          <li>✓ Free first consultation</li>
          <li>✓ 100% confidential</li>
        </ul>
        <p class="hero__author">Guide by <strong>Aleksi Suoninen</strong>, UAE Expat &amp; Legal Consultant</p>
      </div>
      <div class="hero__form">
        <LeadForm lang="en" variant="hero" />
      </div>
    </div>
  </header>

  <main class="container main-content">

    <!-- Key principle -->
    <section class="section" aria-labelledby="principle-heading">
      <h2 id="principle-heading">The Fundamental Rule: Father Pays, Regardless of Custody</h2>
      <p>
        The most important thing to understand about child support in UAE: <strong>the father's obligation
        to financially support his children exists regardless of who has custody.</strong>
      </p>
      <p>
        Under both Islamic personal status law and the 2022 civil law for non-Muslim expats, the father is the
        primary financial provider for his children. If the mother has custody, the father pays her child
        support to fund the children's care. If the father has custody, the financial obligations fall on him
        directly. Custody and financial support are two separate legal questions.
      </p>
      <div class="key-box">
        <div class="key-stat">
          <span class="key-num">15–30%</span>
          <span class="key-label">of father's income — typical child support range per child</span>
        </div>
        <div class="key-stat">
          <span class="key-num">Age 18+</span>
          <span class="key-label">support continues through university for enrolled students</span>
        </div>
        <div class="key-stat">
          <span class="key-num">Travel ban</span>
          <span class="key-label">primary enforcement tool for non-payment</span>
        </div>
      </div>
    </section>

    <img
      src="/images/child-custody-uae.webp"
      alt="Child's hand in parent's hand — child support UAE"
      width="900" height="507"
      loading="lazy" decoding="async"
      class="article-img"
    />

    <!-- What is covered -->
    <section class="section" aria-labelledby="covered-heading">
      <h2 id="covered-heading">What Child Support Covers in UAE</h2>
      <p>
        UAE courts assess child support as a package covering all of the child's reasonable needs —
        not just basic subsistence. Here is what is typically included:
      </p>
      <div class="coverage-grid">
        {whatIsCovered.map((item) => (
          <div class="coverage-card">
            <div class="coverage-header">
              <h3>{item.category}</h3>
              <span class={`coverage-badge ${item.required ? 'badge--required' : 'badge--discretionary'}`}>
                {item.required ? 'Mandatory' : 'Discretionary'}
              </span>
            </div>
            <p>{item.detail}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- How courts calculate -->
    <section class="section" aria-labelledby="calc-heading">
      <h2 id="calc-heading">How UAE Courts Calculate Child Support</h2>
      <p>
        There is no fixed formula — judges have discretion. However, these six factors consistently
        drive the outcome:
      </p>
      <div class="factors-table">
        {calculationFactors.map((item) => (
          <div class="factor-row">
            <div class="factor-info">
              <h3>{item.factor}</h3>
              <p>{item.detail}</p>
            </div>
            <span class={`factor-weight ${item.weight === 'Primary' || item.weight === 'High' ? 'weight--high' : 'weight--medium'}`}>
              {item.weight}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- How long -->
    <section class="section" aria-labelledby="duration-heading">
      <h2 id="duration-heading">How Long Does Child Support Last?</h2>
      <p>
        The duration of child support in UAE depends on the child's gender, circumstances, and educational status.
        Note that custody age limits (when the child moves to the other parent) are different from support
        duration — support often continues long after custody changes.
      </p>
      <div class="duration-table">
        <div class="duration-header">
          <div>Who</div>
          <div>Support Duration</div>
          <div>Notes</div>
        </div>
        {durations.map((row) => (
          <div class="duration-row">
            <div class="duration-who">{row.who}</div>
            <div class="duration-until">{row.until}</div>
            <div class="duration-note">{row.note}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- How to claim -->
    <section class="section" aria-labelledby="claim-heading">
      <h2 id="claim-heading">How to Claim Child Support in UAE</h2>
      <ol class="steps">
        <li>
          <h3>File at the Personal Status Court in your emirate</h3>
          <p>
            Child support claims are filed at the Personal Status Court in the emirate where you reside.
            You can file a standalone child support claim — you do not need to be in the middle of divorce
            proceedings, though the two are often filed together.
          </p>
        </li>
        <li>
          <h3>Gather financial evidence</h3>
          <p>
            The court needs evidence of the father's income (salary certificate, bank statements, tax
            documents if applicable) and evidence of the child's current costs (school fee invoices,
            medical bills, rent, tuition receipts). The more documentation you have, the stronger your case.
          </p>
        </li>
        <li>
          <h3>Your lawyer files the nafaqa claim</h3>
          <p>
            Your lawyer submits the maintenance claim (nafaqa al-awlad) with supporting documentation.
            The court can issue an interim maintenance order while the full case is heard — you do not
            have to wait months with no income.
          </p>
        </li>
        <li>
          <h3>Court hearing and judgment</h3>
          <p>
            Both parties present their financial positions. The judge sets a monthly support amount
            and issues a formal order. This is legally enforceable immediately.
          </p>
        </li>
        <li>
          <h3>Enforce the order if payments stop</h3>
          <p>
            If the father stops paying, return to court. The enforcement tools available include
            wage garnishment, travel ban, and account freezing. Non-payment is not treated leniently
            by UAE courts — act quickly rather than waiting and hoping payments resume.
          </p>
        </li>
      </ol>
      <div class="cta-inline">
        <p>Need help filing a child support claim?</p>
        <a href="#contact" class="btn btn--primary">Get Free Consultation</a>
      </div>
    </section>

    <!-- Related links -->
    <section class="section" aria-labelledby="related-heading">
      <h2 id="related-heading">Related Legal Guides</h2>
      <div class="service-links">
        <a href="/en/child-custody-uae" class="service-link">
          <strong>Child Custody UAE</strong>
          <span>Who gets custody and how courts decide</span>
        </a>
        <a href="/en/alimony-uae" class="service-link">
          <strong>Alimony in UAE</strong>
          <span>Financial entitlements for the wife after divorce</span>
        </a>
        <a href="/en/wife-rights-after-divorce-uae" class="service-link">
          <strong>Wife's Rights After Divorce</strong>
          <span>Full overview of all post-divorce rights</span>
        </a>
        <a href="/en/divorce-cost-uae" class="service-link">
          <strong>Divorce Cost UAE</strong>
          <span>Court fees and total cost breakdown</span>
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <FAQSection items={faqItems} lang="en" />

    <!-- Bottom CTA -->
    <section id="contact" class="section section--cta" aria-labelledby="cta-heading">
      <h2 id="cta-heading">Speak to a UAE Family Lawyer About Child Support</h2>
      <p>
        Child support claims are time-sensitive — file early to secure interim maintenance.
        Get a free confidential consultation today.
      </p>
      <LeadForm lang="en" variant="inline" />
    </section>

  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>&copy; 2025 DivorceU.AE — Legal referral service. Not a law firm. Information provided is for guidance only and does not constitute legal advice.</p>
      <nav aria-label="Footer navigation">
        <a href="/en/privacy-policy">Privacy Policy</a>
        <a href="/en/disclaimer">Disclaimer</a>
        <a href="/ar/">العربية</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .article-img { width: 100%; height: 320px; object-fit: cover; border-radius: 12px; margin-bottom: 2rem; display: block; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  .hero {
    background: linear-gradient(rgba(10,22,40,0.68), rgba(10,22,40,0.68)), url('/images/hero-dubai-office.webp') center/cover no-repeat;
    color: #fff; padding: 80px 0 60px;
  }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
  .hero__sub { font-size: 1.05rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.7; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.9rem; }
  .hero__trust li { opacity: 0.9; }
  .hero__author { font-size: 0.85rem; opacity: 0.7; margin-top: 16px; margin-bottom: 0; }

  .section { padding: 60px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #1e3a5f; margin-bottom: 20px; }
  .section h3 { font-size: 1.05rem; font-weight: 700; color: #1e3a5f; margin: 16px 0 6px; }
  .section p { color: #374151; line-height: 1.8; margin-bottom: 16px; }
  .section strong { color: #1e3a5f; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 60px 40px; margin-bottom: 60px; text-align: center; }

  .key-box { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; background: #1e3a5f; border-radius: 16px; padding: 32px; margin-top: 28px; }
  .key-stat { text-align: center; }
  .key-num { display: block; font-size: 1.6rem; font-weight: 800; color: #c9a84c; margin-bottom: 6px; }
  .key-label { font-size: 0.8rem; color: rgba(255,255,255,0.8); line-height: 1.4; }

  .coverage-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin-top: 24px; }
  .coverage-card { background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; padding: 20px; }
  .coverage-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 8px; margin-bottom: 10px; flex-wrap: wrap; }
  .coverage-card h3 { font-size: 0.95rem; font-weight: 700; color: #1e3a5f; margin: 0; }
  .coverage-badge { font-size: 0.65rem; font-weight: 700; border-radius: 20px; padding: 3px 8px; flex-shrink: 0; }
  .badge--required { background: #dcfce7; color: #166534; }
  .badge--discretionary { background: #fef3c7; color: #92400e; }
  .coverage-card p { font-size: 0.85rem; color: #374151; line-height: 1.65; margin: 0; }

  .factors-table { display: flex; flex-direction: column; border: 1.5px solid #e5e7eb; border-radius: 12px; overflow: hidden; margin-top: 24px; }
  .factor-row { display: flex; justify-content: space-between; align-items: center; gap: 16px; padding: 16px 20px; border-bottom: 1px solid #f3f4f6; background: #fff; }
  .factor-row:last-child { border-bottom: none; }
  .factor-row:nth-child(even) { background: #f8faff; }
  .factor-info h3 { font-size: 0.9rem; font-weight: 700; color: #1e3a5f; margin: 0 0 4px; }
  .factor-info p { font-size: 0.8rem; color: #6b7280; margin: 0; line-height: 1.5; }
  .factor-weight { font-size: 0.7rem; font-weight: 700; border-radius: 20px; padding: 4px 10px; white-space: nowrap; flex-shrink: 0; }
  .weight--high { background: #fee2e2; color: #991b1b; }
  .weight--medium { background: #fef3c7; color: #92400e; }

  .duration-table { border: 1.5px solid #e5e7eb; border-radius: 12px; overflow: hidden; margin-top: 24px; }
  .duration-header { display: grid; grid-template-columns: 1fr 1.5fr 2fr; background: #1e3a5f; color: #fff; font-size: 0.8rem; font-weight: 700; padding: 12px 16px; gap: 16px; }
  .duration-row { display: grid; grid-template-columns: 1fr 1.5fr 2fr; padding: 14px 16px; gap: 16px; border-top: 1px solid #f3f4f6; font-size: 0.85rem; }
  .duration-row:nth-child(even) { background: #f8faff; }
  .duration-who { font-weight: 700; color: #1e3a5f; }
  .duration-until { color: #374151; }
  .duration-note { color: #6b7280; }

  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 20px; margin-top: 24px; }
  .steps li {
    counter-increment: steps;
    padding: 24px 24px 24px 72px;
    position: relative;
    background: #f8faff;
    border-radius: 12px;
    border-left: 4px solid #2563eb;
  }
  .steps li::before {
    content: counter(steps);
    position: absolute; left: 20px; top: 24px;
    width: 36px; height: 36px;
    background: #2563eb; color: #fff;
    border-radius: 50%; display: flex;
    align-items: center; justify-content: center;
    font-weight: 700; font-size: 1rem;
  }
  .steps li h3 { font-size: 1rem; font-weight: 700; color: #1e3a5f; margin-bottom: 6px; }
  .steps li p { font-size: 0.9rem; color: #374151; margin: 0; line-height: 1.7; }

  .cta-inline { display: flex; align-items: center; gap: 20px; margin-top: 32px; flex-wrap: wrap; }
  .cta-inline p { margin: 0; font-weight: 600; color: #1e3a5f; }
  .btn--primary { display: inline-block; padding: 12px 28px; background: #c9a84c; color: #fff; border-radius: 8px; text-decoration: none; font-weight: 700; transition: background 0.2s; }
  .btn--primary:hover { background: #b8942d; }

  .service-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 24px; }
  .service-link { display: flex; flex-direction: column; gap: 4px; padding: 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s, box-shadow 0.2s; }
  .service-link:hover { border-color: #2563eb; box-shadow: 0 4px 16px rgba(37,99,235,0.1); }
  .service-link strong { color: #1e3a5f; font-size: 0.95rem; }
  .service-link span { color: #6b7280; font-size: 0.8rem; }

  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 40px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.85rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
  .footer nav a:hover { color: #fff; }
  .main-content { padding-top: 20px; }

  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero { padding: 50px 0 40px; }
    .key-box { grid-template-columns: 1fr; gap: 16px; }
    .section--cta { padding: 40px 24px; }
    .duration-header, .duration-row { grid-template-columns: 1fr; }
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
