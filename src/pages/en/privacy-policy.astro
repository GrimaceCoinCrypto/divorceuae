---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'Privacy Policy — DivorceU.AE';
const description = 'Privacy Policy for DivorceU.AE — how we collect, use, and protect your personal information.';

const hreflang = {
  en: 'https://divorceu.ae/en/privacy-policy',
  ar: 'https://divorceu.ae/ar/سياسة-الخصوصية',
};

const breadcrumbs = [
  { name: 'Home', url: 'https://divorceu.ae/en/' },
  { name: 'Privacy Policy', url: 'https://divorceu.ae/en/privacy-policy' },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  dir="ltr"
  hreflang={hreflang}
  noindex={true}
>
  <main class="container page">
    <Breadcrumb items={breadcrumbs} lang="en" />

    <div class="content">
      <h1>Privacy Policy</h1>
      <p class="updated">Last updated: April 2025</p>

      <h2>1. Who We Are</h2>
      <p>
        DivorceU.AE ("we", "our", "us") is a legal referral service operating at
        <strong>https://divorceu.ae</strong>. We are not a law firm and do not provide legal advice
        directly. We connect individuals seeking divorce and family law assistance with qualified,
        licensed lawyers in the UAE.
      </p>

      <h2>2. What Information We Collect</h2>
      <p>When you submit a consultation request through our website, we collect:</p>
      <ul>
        <li>Full name</li>
        <li>Phone number (including WhatsApp)</li>
        <li>Email address</li>
        <li>A brief description of your situation (if provided)</li>
        <li>Language preference</li>
      </ul>
      <p>
        We also collect standard technical data automatically via Google Analytics, including your
        approximate location, browser type, device type, pages visited, and time spent on the site.
        This data is anonymised and aggregated — it does not identify you personally.
      </p>

      <h2>3. How We Use Your Information</h2>
      <p>We use the information you provide solely to:</p>
      <ul>
        <li>Connect you with a qualified UAE divorce lawyer from our network</li>
        <li>Respond to your consultation request within 24 hours</li>
        <li>Follow up on your enquiry if we have not heard back from you</li>
      </ul>
      <p>We do not use your personal data for marketing purposes without your explicit consent.</p>

      <h2>4. How We Share Your Information</h2>
      <p>
        Your information is shared only with the lawyer or law firm we connect you with in response
        to your consultation request. We do not sell, rent, or trade your personal data to any
        third parties for commercial purposes.
      </p>
      <p>We use the following third-party services to operate the website:</p>
      <ul>
        <li><strong>Web3Forms</strong> — processes form submissions and delivers them to us by email. Your data passes through their servers. See their privacy policy at web3forms.com.</li>
        <li><strong>Google Analytics</strong> — anonymised website traffic analytics. See Google's privacy policy at policies.google.com.</li>
        <li><strong>Cloudflare</strong> — website hosting and security. See Cloudflare's privacy policy at cloudflare.com.</li>
      </ul>

      <h2>5. Data Retention</h2>
      <p>
        We retain your personal information for as long as is necessary to fulfil your consultation
        request and any follow-up communications. If you ask us to delete your data, we will do so
        within 30 days, unless we are required to retain it by law.
      </p>

      <h2>6. Your Rights</h2>
      <p>You have the right to:</p>
      <ul>
        <li>Request access to the personal data we hold about you</li>
        <li>Request correction of inaccurate data</li>
        <li>Request deletion of your data</li>
        <li>Withdraw consent to be contacted at any time</li>
      </ul>
      <p>
        To exercise any of these rights, contact us via the consultation form on our website and
        include "Data Request" in your message.
      </p>

      <h2>7. Security</h2>
      <p>
        We take reasonable steps to protect your personal information from unauthorised access,
        loss, or disclosure. All data is transmitted over encrypted HTTPS connections. However, no
        internet transmission is 100% secure, and we cannot guarantee absolute security.
      </p>

      <h2>8. Cookies</h2>
      <p>
        Our website uses Google Analytics cookies to understand how visitors use the site. These
        cookies do not identify you personally. You can disable cookies in your browser settings
        at any time, though this may affect site functionality.
      </p>

      <h2>9. Children's Privacy</h2>
      <p>
        Our services are intended for adults aged 18 and over. We do not knowingly collect personal
        information from children under 18.
      </p>

      <h2>10. Changes to This Policy</h2>
      <p>
        We may update this Privacy Policy from time to time. The "Last updated" date at the top of
        this page will reflect any changes. Continued use of the website after changes are posted
        constitutes acceptance of the updated policy.
      </p>

      <h2>11. Governing Law</h2>
      <p>
        This Privacy Policy is governed by the laws of the United Arab Emirates. Any disputes
        relating to this policy shall be subject to the jurisdiction of UAE courts.
      </p>
    </div>
  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>&copy; 2025 DivorceU.AE — Legal referral service. Not a law firm. Information provided is for guidance only and does not constitute legal advice.</p>
      <nav aria-label="Footer navigation">
        <a href="/en/privacy-policy">Privacy Policy</a>
        <a href="/en/disclaimer">Disclaimer</a>
        <a href="/ar/">العربية</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .page { padding: 60px 0 80px; }
  .content { max-width: 760px; }
  h1 { font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 800; color: #1e3a5f; margin-bottom: 8px; }
  .updated { color: #9ca3af; font-size: 0.875rem; margin-bottom: 48px; }
  h2 { font-size: 1.15rem; font-weight: 700; color: #1e3a5f; margin: 36px 0 12px; }
  p { color: #374151; line-height: 1.8; margin-bottom: 14px; }
  ul { margin: 0 0 16px 20px; }
  li { color: #374151; line-height: 1.7; margin-bottom: 6px; }
  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 40px 0; margin-top: 80px; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.85rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
  .footer nav a:hover { color: #fff; }
  @media (max-width: 768px) {
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
