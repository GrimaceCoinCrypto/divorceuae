---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = "Wife's Rights After Divorce in UAE — Alimony, Housing & Financial Entitlements";
const description =
  "Complete guide to a wife's rights after divorce in UAE: alimony, mahr, housing, child support, and financial entitlements for Muslim and non-Muslim women.";

const hreflang = {
  en: 'https://divorceu.ae/en/wife-rights-after-divorce-uae',
  ar: 'https://divorceu.ae/ar/حقوق-الزوجة-بعد-الطلاق-الامارات',
};

const breadcrumbs = [
  { name: 'Home', url: 'https://divorceu.ae/en/' },
  { name: "Wife's Rights After Divorce UAE", url: 'https://divorceu.ae/en/wife-rights-after-divorce-uae' },
];

const faqItems = [
  {
    question: "What financial rights does a wife have after divorce in UAE?",
    answer:
      "A Muslim wife is entitled to: unpaid mahr (dowry), iddah maintenance (3 months living expenses), child support if she has custody, and mutaa (consolation gift) in some cases. Under the 2022 civil law for non-Muslims, she is also entitled to 50% of marital assets.",
  },
  {
    question: "How long does a husband pay alimony in UAE?",
    answer:
      "Under Islamic law, the husband must pay maintenance during the iddah period (approximately 3 months). Extended alimony beyond iddah is not automatic under UAE Islamic law — it depends on the specific circumstances. Under the 2022 civil law, courts can order longer-term alimony.",
  },
  {
    question: "Can a wife stay in the marital home after divorce in UAE?",
    answer:
      "A wife with child custody is entitled to suitable housing for herself and the children during the custody period. The court can order the husband to provide or pay for accommodation. After custody ends, the housing entitlement also ends.",
  },
  {
    question: "What is mutaa in UAE divorce?",
    answer:
      "Mutaa is a consolation payment from the husband to the wife upon divorce, particularly when the husband initiates the divorce (talaq) without fault on the wife's part. UAE courts can order mutaa based on the length of the marriage and the husband's financial capacity.",
  },
  {
    question: "Does a non-Muslim wife get half the assets in UAE divorce?",
    answer:
      "Yes — under Federal Law No. 41 of 2022 for non-Muslim expats, marital assets acquired during the marriage are divided equally (50/50) by default. This applies unless a prenuptial agreement specifies otherwise.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  dir="ltr"
  hreflang={hreflang}
>
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <Breadcrumb items={breadcrumbs} lang="en" />
        <h1 class="hero__h1">Wife's Rights After Divorce in UAE</h1>
        <p class="hero__sub">
          If you are going through a divorce in the UAE, it is critical to understand your full
          financial and legal entitlements. These rights differ significantly depending on whether
          you are Muslim or non-Muslim, and the circumstances of the divorce.
        </p>
        <ul class="hero__trust">
          <li>✓ Muslim &amp; non-Muslim rights</li>
          <li>✓ Alimony, mahr &amp; housing</li>
          <li>✓ 2022 civil law changes</li>
          <li>✓ Free legal consultation</li>
        </ul>
      </div>
      <div class="hero__form">
        <LeadForm lang="en" variant="hero" heading="Know Your Rights — Free Consultation" />
      </div>
    </div>
  </header>

  <main class="container main-content">

    <img
      src="/images/woman-dubai-skyline.webp"
      alt="Woman looking at Dubai skyline — wife rights after divorce UAE"
      width="900" height="507"
      loading="lazy" decoding="async"
      class="article-img"
    />

    <!-- Quick summary -->
    <section class="section" aria-labelledby="summary-heading">
      <h2 id="summary-heading">Summary of Wife's Rights After Divorce in UAE</h2>
      <div class="rights-grid">
        <div class="right-card right-card--green">
          <span class="right-icon">💍</span>
          <h3>Mahr (Dowry)</h3>
          <p>Full unpaid mahr is due upon divorce. If mahr was deferred, it becomes payable immediately.</p>
        </div>
        <div class="right-card right-card--blue">
          <span class="right-icon">🏠</span>
          <h3>Housing</h3>
          <p>The wife with custody is entitled to suitable housing for herself and the children throughout the custody period.</p>
        </div>
        <div class="right-card right-card--gold">
          <span class="right-icon">💰</span>
          <h3>Iddah Maintenance</h3>
          <p>The husband must pay full living expenses for the 3-month iddah period (Muslim divorces).</p>
        </div>
        <div class="right-card right-card--purple">
          <span class="right-icon">👶</span>
          <h3>Child Support</h3>
          <p>The father pays child support (nafaqat al-awlad) covering food, education, medical care, and housing.</p>
        </div>
        <div class="right-card right-card--teal">
          <span class="right-icon">🎁</span>
          <h3>Mutaa</h3>
          <p>A consolation gift may be ordered by the court if the husband initiates divorce without fault.</p>
        </div>
        <div class="right-card right-card--orange">
          <span class="right-icon">⚖️</span>
          <h3>Asset Division (Non-Muslims)</h3>
          <p>Under the 2022 law, non-Muslim wives receive 50% of all marital assets by default.</p>
        </div>
      </div>
    </section>

    <!-- Mahr -->
    <section class="section" aria-labelledby="mahr-heading">
      <h2 id="mahr-heading">Mahr (Dowry) — Your Most Important Financial Right</h2>
      <p>
        Mahr is the mandatory gift specified in the Islamic marriage contract, payable by the husband
        to the wife. It consists of two parts:
      </p>
      <ul class="list">
        <li><strong>Prompt mahr (muqaddam):</strong> Paid at the time of marriage contract</li>
        <li><strong>Deferred mahr (muakhar):</strong> Agreed to be paid upon divorce or death</li>
      </ul>
      <p>
        Upon divorce, any unpaid deferred mahr becomes immediately due. The wife has the right to
        pursue this through the Personal Status Court if the husband refuses to pay. The mahr amount
        is specified in the marriage contract and forms part of the divorce financial settlement.
      </p>
      <p>
        <strong>Important:</strong> If the wife initiates khul'a (wife-initiated divorce), she typically
        must return the mahr she received as compensation for the release. However, if she files for
        judicial divorce (tafreeq) on grounds of harm, abandonment, or non-payment, she retains the
        right to her mahr.
      </p>
    </section>

    <!-- Alimony and Maintenance -->
    <section class="section" aria-labelledby="alimony-heading">
      <h2 id="alimony-heading">Alimony &amp; Maintenance After Divorce</h2>

      <h3>Iddah Maintenance (Muslim Women)</h3>
      <p>
        During the iddah period (approximately 3 months after divorce), the husband is obligated to
        pay the wife's full living expenses regardless of who initiated the divorce. This covers:
      </p>
      <ul class="list">
        <li>Accommodation (or equivalent rental amount)</li>
        <li>Food and clothing</li>
        <li>Medical expenses</li>
      </ul>

      <h3>Extended Alimony</h3>
      <p>
        Under UAE Islamic personal status law, the wife's right to maintenance from her ex-husband
        generally ends after the iddah period. Extended alimony (beyond 3 months) is not automatically
        granted — the court assesses whether the wife is able to financially support herself.
      </p>
      <p>
        Under the 2022 civil law for non-Muslim expats, courts have broader discretion to award
        long-term alimony based on factors such as duration of marriage, standard of living, and
        each party's earning capacity — similar to alimony principles in Western jurisdictions.
      </p>

      <h3>Child Support — Separate From Alimony</h3>
      <p>
        Child support (nafaqa) is separate from the wife's alimony. The father is obligated to pay
        child support regardless of who has custody. This includes:
      </p>
      <ul class="list">
        <li>Education fees and school supplies</li>
        <li>Medical and healthcare costs</li>
        <li>Food and clothing for the children</li>
        <li>Housing for the custodial parent</li>
      </ul>

      <div class="cta-inline">
        <p>Not sure what you're entitled to?</p>
        <a href="#contact" class="btn btn--primary">Get Free Legal Advice</a>
      </div>
    </section>

    <!-- Housing Rights -->
    <section class="section" aria-labelledby="housing-heading">
      <h2 id="housing-heading">Housing Rights After Divorce</h2>
      <p>
        A divorced wife who has custody of the children is entitled to suitable housing — either
        within the marital home or in alternative accommodation provided or paid for by the father.
      </p>
      <p>
        The housing right is tied to custody. Once custody of the children transfers (when children
        reach the age at which they choose or must legally transfer to the father), the housing
        entitlement ends.
      </p>

      <div class="info-box">
        <h3>Important: Visa Status After Divorce</h3>
        <p>
          If you were on your spouse's visa, you have <strong>30 days</strong> after the divorce
          is finalised to change your visa status. You can apply for:
        </p>
        <ul>
          <li>Employment visa (if you have or find a job)</li>
          <li>Investor visa</li>
          <li>1-year divorce/custody visa (if you have children in UAE)</li>
        </ul>
        <p>Speak to a lawyer immediately to protect your residency status.</p>
      </div>
    </section>

    <!-- Non-Muslim specific -->
    <section class="section" aria-labelledby="nonmuslim-heading">
      <h2 id="nonmuslim-heading">Rights for Non-Muslim Wives (2022 Civil Law)</h2>
      <p>
        The 2022 UAE Personal Status Law for non-Muslims introduced significantly stronger financial
        protections for wives compared to the Islamic law framework:
      </p>

      <div class="two-col">
        <div class="info-box info-box--blue">
          <h3>Equal Asset Division</h3>
          <p>All assets acquired during the marriage are split 50/50 by default. This includes property, investments, savings, and business interests established during the marriage — regardless of whose name they are in.</p>
        </div>
        <div class="info-box info-box--gold">
          <h3>No-Fault Divorce</h3>
          <p>Either spouse can initiate divorce without proving harm or fault. The wife does not need to return any dowry (as there is no mahr requirement under civil law). The divorce proceeds on equal terms.</p>
        </div>
      </div>

      <p style="margin-top: 24px;">
        <a href="/en/divorce-in-uae-for-expats">Full guide: Non-Muslim divorce under the 2022 law →</a>
      </p>
    </section>

    <!-- Related -->
    <section class="section" aria-labelledby="related-heading">
      <h2 id="related-heading">Related Guides</h2>
      <div class="service-links">
        <a href="/en/uae-divorce-law" class="service-link">
          <strong>UAE Divorce Law Guide</strong>
          <span>Full overview of personal status law</span>
        </a>
        <a href="/en/child-custody-uae" class="service-link">
          <strong>Child Custody UAE</strong>
          <span>Custody rights and court process</span>
        </a>
        <a href="/en/divorce-in-uae-for-expats" class="service-link">
          <strong>Divorce for Expats</strong>
          <span>Non-Muslim 2022 law explained</span>
        </a>
        <a href="/en/how-to-file-for-divorce-in-dubai" class="service-link">
          <strong>How to File for Divorce</strong>
          <span>Step-by-step court guide</span>
        </a>
        <a href="/en/property-division-divorce-uae" class="service-link">
          <strong>Property Division in UAE Divorce</strong>
          <span>Who keeps the home, accounts, and assets</span>
        </a>
        <a href="/en/divorce-for-harm-uae" class="service-link">
          <strong>Judicial Divorce for Harm</strong>
          <span>Tatliq lil-darar -- grounds, evidence, mahr rights</span>
        </a>
      </div>
    </section>

    <FAQSection items={faqItems} lang="en" />

    <section class="section section--cta" aria-labelledby="bottom-cta-heading" id="contact">
      <h2 id="bottom-cta-heading">Protect Your Rights — Free Legal Consultation</h2>
      <p>Speak to a qualified divorce lawyer within 24 hours. Completely confidential. English and Arabic support.</p>
      <LeadForm lang="en" variant="inline" />
    </section>

  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>&copy; 2025 DivorceU.AE — Legal referral service. Not a law firm. Information provided is for guidance only and does not constitute legal advice.</p>
      <nav aria-label="Footer navigation">
        <a href="/en/privacy-policy">Privacy Policy</a>
        <a href="/en/disclaimer">Disclaimer</a>
        <a href="/ar/">العربية</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .article-img { width: 100%; height: auto; border-radius: 12px; margin-bottom: 2rem; display: block; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 80px 0 60px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
  .hero__sub { font-size: 1.05rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.7; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.9rem; }
  .hero__trust li { opacity: 0.9; }

  .section { padding: 60px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #1e3a5f; margin-bottom: 20px; }
  .section h3 { font-size: 1.1rem; font-weight: 700; color: #1e3a5f; margin: 24px 0 10px; }
  .section p { color: #374151; line-height: 1.8; margin-bottom: 16px; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 60px 40px; margin-bottom: 60px; text-align: center; }

  .rights-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 24px; }
  .right-card { padding: 24px 20px; border-radius: 12px; border: 2px solid; }
  .right-card--green { background: #f0fdf4; border-color: #22c55e; }
  .right-card--blue { background: #eff6ff; border-color: #2563eb; }
  .right-card--gold { background: #fffbeb; border-color: #c9a84c; }
  .right-card--purple { background: #faf5ff; border-color: #a855f7; }
  .right-card--teal { background: #f0fdfa; border-color: #14b8a6; }
  .right-card--orange { background: #fff7ed; border-color: #f97316; }
  .right-icon { font-size: 1.6rem; display: block; margin-bottom: 10px; }
  .right-card h3 { font-size: 0.95rem; font-weight: 700; color: #1e3a5f; margin-bottom: 8px; }
  .right-card p { font-size: 0.875rem; color: #374151; margin: 0; line-height: 1.6; }

  .list { margin: 12px 0 20px 20px; }
  .list li { margin-bottom: 8px; color: #374151; line-height: 1.6; }

  .info-box { background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; padding: 28px 24px; margin-top: 24px; }
  .info-box--blue { background: #eff6ff; border-color: #2563eb; }
  .info-box--gold { background: #fffbeb; border-color: #c9a84c; }
  .info-box h3 { font-size: 1rem; font-weight: 700; color: #1e3a5f; margin-bottom: 10px; }
  .info-box p, .info-box ul { font-size: 0.9rem; color: #374151; margin-bottom: 8px; }
  .info-box ul { padding-left: 18px; }
  .info-box li { margin-bottom: 4px; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 24px; }

  .cta-inline { display: flex; align-items: center; gap: 20px; margin-top: 32px; flex-wrap: wrap; }
  .cta-inline p { margin: 0; font-weight: 600; }
  .btn--primary { display: inline-block; padding: 12px 28px; background: #c9a84c; color: #fff; border-radius: 8px; text-decoration: none; font-weight: 700; transition: background 0.2s; }
  .btn--primary:hover { background: #b8942d; }

  .service-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 24px; }
  .service-link { display: flex; flex-direction: column; gap: 4px; padding: 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .service-link:hover { border-color: #2563eb; }
  .service-link strong { color: #1e3a5f; }
  .service-link span { color: #6b7280; font-size: 0.875rem; }

  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 40px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.85rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
  .footer nav a:hover { color: #fff; }
  .main-content { padding-top: 20px; }

  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero { padding: 50px 0 40px; }
    .two-col { grid-template-columns: 1fr; }
    .section--cta { padding: 40px 24px; }
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
