---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LeadForm from '../../components/ui/LeadForm.astro';
import FAQSection from '../../components/ui/FAQSection.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';

const title = 'Divorce Lawyer Abu Dhabi — Family Law Specialists | Free Consultation';
const description =
  'Find a qualified divorce lawyer in Abu Dhabi. Expert family law advice for Muslim and non-Muslim expats at Abu Dhabi Personal Status Court. Free first consultation.';

const hreflang = {
  en: 'https://divorceu.ae/en/divorce-lawyer-abu-dhabi',
  ar: 'https://divorceu.ae/ar/محامي-طلاق-ابوظبي',
};

const breadcrumbs = [
  { name: 'Home', url: 'https://divorceu.ae/en/' },
  { name: 'Divorce Lawyer Abu Dhabi', url: 'https://divorceu.ae/en/divorce-lawyer-abu-dhabi' },
];

const faqItems = [
  {
    question: 'Where is the divorce court in Abu Dhabi?',
    answer:
      "Abu Dhabi's Personal Status Court is part of the Abu Dhabi Judicial Department (ADJD), located in Abu Dhabi city. The Family Guidance Department at the ADJD handles reconciliation sessions before cases proceed to hearings.",
  },
  {
    question: 'How long does divorce take in Abu Dhabi?',
    answer:
      'An uncontested divorce in Abu Dhabi typically takes 1–3 months from filing to final decree. Contested divorces involving custody or asset disputes can take 6–18 months depending on complexity.',
  },
  {
    question: 'Can I use a Dubai divorce lawyer for my Abu Dhabi case?',
    answer:
      'Yes, many UAE family lawyers are licensed to practice across all emirates. However, cases must be filed in the emirate where you reside. An Abu Dhabi-based case must go to Abu Dhabi Personal Status Court.',
  },
  {
    question: 'What documents do I need to file for divorce in Abu Dhabi?',
    answer:
      "You'll need: original marriage certificate (and certified Arabic translation if in another language), passports of both parties, UAE Emirates IDs, and proof of Abu Dhabi residence. Your lawyer will advise on any additional documents specific to your case.",
  },
  {
    question: 'What is the cost of divorce in Abu Dhabi?',
    answer:
      'Court filing fees in Abu Dhabi are typically AED 600–2,000 for the initial application. Lawyer fees for an uncontested divorce range from AED 5,000–15,000. Contested divorces with custody disputes cost significantly more.',
  },
];
---

<BaseLayout
  title={title}
  description={description}
  lang="en"
  dir="ltr"
  hreflang={hreflang}
>
  <header class="hero">
    <div class="container hero__inner">
      <div class="hero__content">
        <Breadcrumb items={breadcrumbs} lang="en" />
        <h1 class="hero__h1">Divorce Lawyer Abu Dhabi</h1>
        <p class="hero__sub">
          Going through a divorce in Abu Dhabi? Our network of qualified family lawyers handles
          cases at the Abu Dhabi Personal Status Court for both Muslim and non-Muslim expats.
          Get expert legal advice with your first consultation free.
        </p>
        <ul class="hero__trust">
          <li>✓ Abu Dhabi Personal Status Court</li>
          <li>✓ Muslim &amp; non-Muslim cases</li>
          <li>✓ English &amp; Arabic</li>
          <li>✓ Free first consultation</li>
        </ul>
      </div>
      <div class="hero__form">
        <LeadForm lang="en" variant="hero" heading="Get Free Legal Consultation in Abu Dhabi" />
      </div>
    </div>
  </header>

  <main class="container main-content">

    <!-- Why Abu Dhabi -->
    <section class="section" aria-labelledby="why-heading">
      <h2 id="why-heading">Divorce Law in Abu Dhabi — What You Need to Know</h2>
      <p>
        Abu Dhabi follows the same federal personal status law as the rest of the UAE. Divorce
        cases are handled by the <strong>Abu Dhabi Personal Status Court</strong> under the
        Abu Dhabi Judicial Department (ADJD). For non-Muslim expats, the 2022 civil personal
        status law applies, offering equal asset division and joint custody defaults.
      </p>
      <div class="cards">
        <div class="card">
          <span class="card__icon">⚖️</span>
          <h3>Licensed Abu Dhabi Lawyers</h3>
          <p>Our lawyers are licensed with UAE Ministry of Justice and experienced in Abu Dhabi Personal Status Court procedures.</p>
        </div>
        <div class="card">
          <span class="card__icon">🌐</span>
          <h3>Bilingual Support</h3>
          <p>Full case handling in English and Arabic. We represent both expats and UAE nationals in Abu Dhabi courts.</p>
        </div>
        <div class="card">
          <span class="card__icon">🏛️</span>
          <h3>Court Representation</h3>
          <p>We handle all court filings, reconciliation sessions, and hearing appearances at Abu Dhabi ADJD on your behalf.</p>
        </div>
        <div class="card">
          <span class="card__icon">👨‍👩‍👧</span>
          <h3>Custody &amp; Assets</h3>
          <p>Expert handling of child custody, asset division, mahr, alimony, and all financial matters in your case.</p>
        </div>
      </div>
    </section>

    <!-- Abu Dhabi Process -->
    <section class="section" aria-labelledby="process-heading">
      <h2 id="process-heading">How to File for Divorce in Abu Dhabi</h2>
      <ol class="steps">
        <li>
          <h3>Consult a Family Lawyer</h3>
          <p>Before filing, speak to a qualified Abu Dhabi family lawyer. Your first consultation is free. We assess your situation and advise on the best legal approach.</p>
        </li>
        <li>
          <h3>Submit Application at Abu Dhabi ADJD</h3>
          <p>The divorce application is filed at the Abu Dhabi Personal Status Court. Required documents include your marriage certificate, Emirates IDs, and passports.</p>
        </li>
        <li>
          <h3>Family Guidance Session</h3>
          <p>The Abu Dhabi Judicial Department requires at least one family guidance (reconciliation) session. A trained counsellor meets with both parties. If reconciliation fails, the case proceeds.</p>
        </li>
        <li>
          <h3>Court Hearings</h3>
          <p>Uncontested cases typically require one hearing. Contested cases (custody, assets) require multiple hearings over several months.</p>
        </li>
        <li>
          <h3>Final Divorce Decree</h3>
          <p>The court issues the divorce decree. For expats, this must be attested and may need legalisation for use in your home country.</p>
        </li>
      </ol>

      <div class="cost-box">
        <h3>Estimated Costs for Divorce in Abu Dhabi</h3>
        <table>
          <thead>
            <tr><th>Type</th><th>Court Fees</th><th>Lawyer Fees (est.)</th><th>Timeline</th></tr>
          </thead>
          <tbody>
            <tr><td>Uncontested divorce</td><td>AED 600–1,500</td><td>AED 5,000–12,000</td><td>1–3 months</td></tr>
            <tr><td>Contested divorce</td><td>AED 1,000–2,500</td><td>AED 15,000–40,000+</td><td>6–18 months</td></tr>
            <tr><td>Custody dispute only</td><td>AED 500–1,500</td><td>AED 8,000–25,000</td><td>3–12 months</td></tr>
          </tbody>
        </table>
        <p class="table-note">Fees are estimates. Consult a lawyer for a precise quote for your specific case.</p>
      </div>
    </section>

    <!-- Abu Dhabi vs Dubai -->
    <section class="section" aria-labelledby="compare-heading">
      <h2 id="compare-heading">Abu Dhabi vs Dubai Divorce — Key Differences</h2>
      <p>
        The law is the same across both emirates (federal personal status law), but there are some
        practical differences in court procedures and timelines:
      </p>
      <div class="comparison-table">
        <table>
          <thead>
            <tr><th>Factor</th><th>Abu Dhabi (ADJD)</th><th>Dubai Personal Status Court</th></tr>
          </thead>
          <tbody>
            <tr><td>Governing authority</td><td>Abu Dhabi Judicial Department</td><td>Dubai Courts</td></tr>
            <tr><td>Reconciliation body</td><td>Family Guidance Department (ADJD)</td><td>Family Guidance Section (Dubai Courts)</td></tr>
            <tr><td>Online services</td><td>ADJD Smart Services portal</td><td>Dubai Courts portal</td></tr>
            <tr><td>Average uncontested time</td><td>6–10 weeks</td><td>4–8 weeks</td></tr>
            <tr><td>Filing jurisdiction</td><td>Must reside in Abu Dhabi emirate</td><td>Must reside in Dubai emirate</td></tr>
          </tbody>
        </table>
      </div>
      <p style="margin-top: 20px;">
        Cases must be filed in the emirate where the couple resides. If you live in Abu Dhabi,
        your case goes to Abu Dhabi ADJD regardless of where you were married.
      </p>
    </section>

    <!-- Related -->
    <section class="section" aria-labelledby="related-heading">
      <h2 id="related-heading">Related Services</h2>
      <div class="service-links">
        <a href="/en/divorce-lawyer-dubai" class="service-link">
          <strong>Divorce Lawyer Dubai</strong>
          <span>Filing at Dubai Personal Status Court</span>
        </a>
        <a href="/en/child-custody-uae" class="service-link">
          <strong>Child Custody UAE</strong>
          <span>Custody rights across all emirates</span>
        </a>
        <a href="/en/wife-rights-after-divorce-uae" class="service-link">
          <strong>Wife's Rights After Divorce</strong>
          <span>Alimony, mahr, and housing</span>
        </a>
        <a href="/en/divorce-in-uae-for-expats" class="service-link">
          <strong>Divorce for Expats</strong>
          <span>2022 civil law for non-Muslims</span>
        </a>
        <a href="/en/how-to-file-for-divorce-in-dubai" class="service-link">
          <strong>Filing Guide</strong>
          <span>Full step-by-step process</span>
        </a>
      </div>
    </section>

    <FAQSection items={faqItems} lang="en" />

    <section class="section section--cta" aria-labelledby="bottom-cta-heading" id="contact">
      <h2 id="bottom-cta-heading">Book Your Free Abu Dhabi Consultation</h2>
      <p>Speak to a divorce lawyer experienced in Abu Dhabi courts. Completely confidential. Available in English and Arabic.</p>
      <LeadForm lang="en" variant="inline" />
    </section>

  </main>

  <footer class="footer">
    <div class="container footer__inner">
      <p>&copy; 2025 DivorceU.AE — Legal referral service. Not a law firm. Information provided is for guidance only and does not constitute legal advice.</p>
      <nav aria-label="Footer navigation">
        <a href="/en/privacy-policy">Privacy Policy</a>
        <a href="/en/disclaimer">Disclaimer</a>
        <a href="/ar/">العربية</a>
      </nav>
    </div>
  </footer>
</BaseLayout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .hero { background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 100%); color: #fff; padding: 80px 0 60px; }
  .hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .hero__h1 { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; line-height: 1.2; margin-bottom: 16px; }
  .hero__sub { font-size: 1.05rem; opacity: 0.9; margin-bottom: 24px; line-height: 1.7; }
  .hero__trust { list-style: none; display: flex; flex-wrap: wrap; gap: 8px 24px; font-size: 0.9rem; }
  .hero__trust li { opacity: 0.9; }

  .section { padding: 60px 0; border-bottom: 1px solid #f3f4f6; }
  .section h2 { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: #1e3a5f; margin-bottom: 20px; }
  .section h3 { font-size: 1.05rem; font-weight: 700; color: #1e3a5f; margin-bottom: 8px; }
  .section p { color: #374151; line-height: 1.8; margin-bottom: 16px; }
  .section--cta { border-bottom: none; background: #f0f4ff; border-radius: 16px; padding: 60px 40px; margin-bottom: 60px; text-align: center; }

  .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 24px; }
  .card { padding: 24px; background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; }
  .card__icon { font-size: 1.6rem; display: block; margin-bottom: 10px; }
  .card h3 { font-size: 0.95rem; font-weight: 700; color: #1e3a5f; margin-bottom: 6px; }
  .card p { font-size: 0.875rem; color: #6b7280; margin: 0; }

  .steps { list-style: none; counter-reset: steps; display: flex; flex-direction: column; gap: 20px; margin-top: 24px; }
  .steps li { counter-increment: steps; padding: 20px 20px 20px 68px; position: relative; background: #f8faff; border-radius: 12px; border-left: 4px solid #2563eb; }
  .steps li::before { content: counter(steps); position: absolute; left: 18px; top: 20px; width: 32px; height: 32px; background: #2563eb; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.9rem; }
  .steps li h3 { font-size: 0.95rem; font-weight: 700; color: #1e3a5f; margin-bottom: 6px; }
  .steps li p { font-size: 0.875rem; color: #374151; margin: 0; }

  .cost-box { background: #f8faff; border: 1.5px solid #e5e7eb; border-radius: 12px; padding: 28px 24px; margin-top: 32px; }
  .cost-box h3 { font-size: 1rem; font-weight: 700; color: #1e3a5f; margin-bottom: 16px; }
  .cost-box table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .cost-box th { background: #1e3a5f; color: #fff; padding: 10px 14px; text-align: left; }
  .cost-box td { padding: 10px 14px; border-bottom: 1px solid #e5e7eb; color: #374151; }
  .cost-box tr:nth-child(even) td { background: #fff; }
  .table-note { font-size: 0.8rem; color: #9ca3af; margin: 12px 0 0; }

  .comparison-table { margin-top: 20px; overflow-x: auto; }
  .comparison-table table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .comparison-table th { background: #1e3a5f; color: #fff; padding: 10px 14px; text-align: left; }
  .comparison-table td { padding: 10px 14px; border-bottom: 1px solid #e5e7eb; color: #374151; }
  .comparison-table tr:nth-child(even) td { background: #f8faff; }

  .service-links { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px; margin-top: 24px; }
  .service-link { display: flex; flex-direction: column; gap: 4px; padding: 20px; background: #fff; border: 1.5px solid #e5e7eb; border-radius: 10px; text-decoration: none; transition: border-color 0.2s; }
  .service-link:hover { border-color: #2563eb; }
  .service-link strong { color: #1e3a5f; }
  .service-link span { color: #6b7280; font-size: 0.875rem; }

  .footer { background: #1e3a5f; color: rgba(255,255,255,0.7); padding: 40px 0; }
  .footer__inner { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px; }
  .footer p { font-size: 0.85rem; margin: 0; }
  .footer nav { display: flex; gap: 20px; }
  .footer nav a { color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.85rem; }
  .footer nav a:hover { color: #fff; }
  .main-content { padding-top: 20px; }

  @media (max-width: 768px) {
    .hero__inner { grid-template-columns: 1fr; gap: 40px; }
    .hero { padding: 50px 0 40px; }
    .section--cta { padding: 40px 24px; }
    .footer__inner { flex-direction: column; text-align: center; }
  }
</style>
